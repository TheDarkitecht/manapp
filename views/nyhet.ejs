<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= broadcast.subject %> — Nyheter — Joakim Jaksen</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📣</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <style>
    .nyd-wrap { max-width: 680px; margin: 0 auto; padding: 2rem 1.25rem; }
    .nyd-back {
      display: inline-block;
      color: #a5b4fc;
      text-decoration: none;
      font-size: 0.9rem;
      margin-bottom: 1.25rem;
    }
    .nyd-back:hover { text-decoration: underline; }

    .nyd-card {
      background: linear-gradient(145deg, #1e293b, #0f172a);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 2rem 2.25rem;
    }
    .nyd-meta {
      display: flex; gap: 0.75rem; align-items: center;
      flex-wrap: wrap;
      font-size: 0.82rem;
      color: #94a3b8;
      margin-bottom: 0.75rem;
    }
    .nyd-date { color: #64748b; font-variant-numeric: tabular-nums; }
    .nyd-segment {
      display: inline-block;
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      background: rgba(99,102,241,0.15);
      color: #a5b4fc;
      border: 1px solid rgba(99,102,241,0.25);
    }
    .nyd-segment-premium { background: rgba(34,197,94,0.15);  color: #4ade80; border-color: rgba(34,197,94,0.25); }
    .nyd-segment-pro     { background: rgba(251,191,36,0.15); color: #fbbf24; border-color: rgba(251,191,36,0.25); }
    .nyd-segment-paid    { background: rgba(251,191,36,0.12); color: #fbbf24; border-color: rgba(251,191,36,0.25); }
    .nyd-segment-free    { background: rgba(100,116,139,0.15); color: #94a3b8; border-color: rgba(100,116,139,0.25); }

    .nyd-subject {
      color: #f1f5f9;
      font-size: 1.6rem;
      font-weight: 800;
      line-height: 1.25;
      margin: 0 0 1.5rem;
    }

    .nyd-body {
      color: #cbd5e1;
      line-height: 1.7;
      font-size: 1rem;
    }
    .nyd-body p { margin: 0 0 1rem; }
    .nyd-body a { color: #a5b4fc; }
    .nyd-body a:hover { text-decoration: underline; }
    .nyd-body ul, .nyd-body ol { padding-left: 1.5rem; margin: 0 0 1rem; }
    .nyd-body li { margin-bottom: 0.35rem; }
    .nyd-body strong { color: #f1f5f9; }
    .nyd-body h1, .nyd-body h2, .nyd-body h3 { color: #f1f5f9; margin: 1.5rem 0 0.75rem; }

    .nyd-footer {
      margin-top: 2rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(255,255,255,0.06);
      color: #64748b;
      font-size: 0.82rem;
      text-align: center;
    }
    .nyd-footer a { color: #a5b4fc; text-decoration: none; }
  </style>
</head>
<body class="block-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/nyheter" class="learn-nav-back">← Nyheter</a>
    <span class="learn-nav-title">📣 <%= broadcast.subject.slice(0, 40) %><%= broadcast.subject.length > 40 ? '…' : '' %></span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="nyd-wrap">

    <a href="/nyheter" class="nyd-back">← Tillbaka till alla nyheter</a>

    <article class="nyd-card">
      <%
        const dt = new Date(broadcast.sent_at);
        const dateStr = dt.toLocaleDateString('sv-SE', { year: 'numeric', month: 'long', day: 'numeric' });
        const segLabel = broadcast.segment === 'premium' ? '✓ Premium' :
                         broadcast.segment === 'pro'     ? '⚡ Pro'     :
                         broadcast.segment === 'paid'    ? '⭐ Betalande' :
                         broadcast.segment === 'free'    ? 'Gratis' :
                         'Alla';
      %>
      <div class="nyd-meta">
        <span class="nyd-date"><%= dateStr %></span>
        <span class="nyd-segment nyd-segment-<%= broadcast.segment %>"><%= segLabel %></span>
      </div>

      <h1 class="nyd-subject"><%= broadcast.subject %></h1>

      <div class="nyd-body">
        <%- rendered %>
      </div>
    </article>

    <div class="nyd-footer">
      Meddelandet skickades till <%= broadcast.sent_count %> mottagare · <a href="/nyheter">alla announcements →</a>
    </div>

  </main>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
