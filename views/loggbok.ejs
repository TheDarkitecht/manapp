<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Loggboken — Joakim Jaksen</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📓</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/gamification.css" />
</head>
<body class="block-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/dashboard" class="learn-nav-back">← Dashboard</a>
    <span class="learn-nav-title">📓 Loggboken</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="loggbok-wrap">

    <div class="loggbok-header">
      <div class="loggbok-eyebrow">Real-world action</div>
      <h1>📓 Loggboken</h1>
      <p>Här loggar du verkliga säljhandlingar — samtal, möten, LinkedIn-poster, affärer. Det är <strong>verklig handling</strong>, inte konsumtion, som bygger dig.</p>
      <% if (saved) { %>
        <div class="lb-saved">✓ Handling loggad</div>
      <% } %>
    </div>

    <!-- Statistik -->
    <% if (stats && prefs.gamification_enabled !== false) { %>
      <div class="loggbok-stats">
        <div class="lb-stat">
          <div class="lb-stat-value"><%= stats.totalActionsThisWeek %></div>
          <div class="lb-stat-label">denna vecka</div>
        </div>
        <div class="lb-stat">
          <div class="lb-stat-value"><%= stats.totalActionsLogged %></div>
          <div class="lb-stat-label">totalt</div>
        </div>
        <div class="lb-stat">
          <div class="lb-stat-value">🔥 <%= stats.streak.current %></div>
          <div class="lb-stat-label">dagars streak</div>
        </div>
        <div class="lb-stat">
          <div class="lb-stat-value"><%= stats.xp %></div>
          <div class="lb-stat-label">XP</div>
        </div>
      </div>
    <% } %>

    <!-- Logga-formulär -->
    <div class="lb-form-card">
      <h2>Logga en handling</h2>
      <form method="POST" action="/loggbok" class="lb-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label class="lb-label">
          <span>Vad gjorde du?</span>
          <select name="category" id="lbCategory" required onchange="updateLbForm()">
            <option value="">— välj kategori —</option>
            <% categories.forEach(function(c) { %>
              <option value="<%= c.id %>"
                data-needs-count="<%= c.needsCount ? '1' : '0' %>"
                data-needs-block="<%= c.needsBlock ? '1' : '0' %>"
                data-xp="<%= c.xp || (c.xpPerUnit + '/st, max ' + c.xpMax) %>">
                <%= c.icon %> <%= c.name %>
              </option>
            <% }); %>
          </select>
          <span class="lb-category-desc" id="lbCategoryDesc"></span>
        </label>

        <label class="lb-label" id="lbCountRow" style="display:none;">
          <span>Antal</span>
          <input type="number" name="count" value="1" min="1" max="999" />
        </label>

        <label class="lb-label" id="lbBlockRow" style="display:none;">
          <span>Vilket block tillämpade du?</span>
          <select name="block_id">
            <option value="">— välj block —</option>
            <% blocks.forEach(function(b) { %>
              <option value="<%= b.id %>"><%= b.icon %> <%= b.title %></option>
            <% }); %>
          </select>
        </label>

        <label class="lb-label">
          <span>Notering (valfritt)</span>
          <textarea name="note" rows="2" maxlength="500" placeholder="T.ex. 'Testade förvirrad ton på vag kund — hon öppnade upp direkt.'"></textarea>
        </label>

        <button type="submit" class="lb-submit">Logga handling →</button>
      </form>
    </div>

    <!-- Loggade handlingar -->
    <div class="lb-history">
      <h2>Tidigare loggat</h2>
      <% if (!actions.length) { %>
        <div class="empty-state">
          <div class="empty-state-icon">📓</div>
          <h3>Här börjar det — bokstavligen</h3>
          <p>Loggboken är tom. Varje loggad handling är ett steg mot mästerskap. Ring ett samtal, skicka ett mejl, publicera på LinkedIn — logga det och se din progression växa.</p>
          <a href="#lbCategory" onclick="document.getElementById('lbCategory').focus();return false;" class="jc-btn">Logga din första handling ↑</a>
        </div>
      <% } else { %>
        <div class="lb-list">
          <% actions.forEach(function(a) { %>
            <% const cat = categories.find(c => c.id === a.category); %>
            <div class="lb-item">
              <div class="lb-item-icon"><%= cat ? cat.icon : '✨' %></div>
              <div class="lb-item-body">
                <div class="lb-item-title">
                  <strong><%= cat ? cat.name : a.category %></strong>
                  <% if (a.count > 1) { %><span class="lb-item-count">×<%= a.count %></span><% } %>
                </div>
                <% if (a.note) { %><p class="lb-item-note"><%= a.note %></p><% } %>
                <div class="lb-item-date"><%= new Date(a.created_at).toLocaleString('sv-SE', { dateStyle: 'short', timeStyle: 'short' }) %></div>
              </div>
              <form method="POST" action="/loggbok/<%= a.id %>/delete" class="lb-item-delete" onsubmit="return confirm('Radera denna logg?');">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" aria-label="Radera">✕</button>
              </form>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

  </main>

  <!-- Toast-container (skapas dynamiskt via JS om cookie finns) -->
  <div id="flashToastContainer" class="flash-toast-container" aria-live="polite"></div>

  <script>
    function updateLbForm() {
      const select = document.getElementById('lbCategory');
      const opt = select.options[select.selectedIndex];
      if (!opt || !opt.value) {
        document.getElementById('lbCountRow').style.display = 'none';
        document.getElementById('lbBlockRow').style.display = 'none';
        document.getElementById('lbCategoryDesc').textContent = '';
        return;
      }
      document.getElementById('lbCountRow').style.display = opt.dataset.needsCount === '1' ? '' : 'none';
      document.getElementById('lbBlockRow').style.display = opt.dataset.needsBlock === '1' ? '' : 'none';
      document.getElementById('lbCategoryDesc').textContent = '+ ' + opt.dataset.xp + ' XP';
    }

    // Toast-feedback efter loggad action — läs cookie + rensa den
    (function() {
      function getCookie(name) {
        const m = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        return m ? decodeURIComponent(m[2]) : null;
      }
      function clearCookie(name) {
        document.cookie = name + '=; Max-Age=0; path=/; SameSite=Lax';
      }
      const raw = getCookie('flashToast');
      if (!raw) return;
      clearCookie('flashToast');
      let data;
      try { data = JSON.parse(raw); } catch (_) { return; }
      if (!data || !data.xpGained) return;

      const container = document.getElementById('flashToastContainer');
      if (!container) return;

      const toast = document.createElement('div');
      toast.className = 'flash-toast' + (data.leveledUp ? ' flash-toast-levelup' : '');
      toast.innerHTML = `
        <div class="ft-icon">${data.leveledUp ? '🏆' : data.icon || '✨'}</div>
        <div class="ft-body">
          ${data.leveledUp
            ? `<div class="ft-title">Ny nivå: <strong>${data.newLevelName}</strong></div>
               <div class="ft-sub">+${data.xpGained} XP loggad</div>`
            : `<div class="ft-title">+${data.xpGained} XP</div>
               <div class="ft-sub">${data.nextLevelName
                  ? `${data.progressPct}% till ${data.nextLevelName}`
                  : 'Toppnivå uppnådd'}</div>`}
          ${data.challengeCompleted ? '<div class="ft-challenge">🎯 Dagens challenge klar!</div>' : ''}
        </div>
        <button class="ft-close" aria-label="Stäng">✕</button>
      `;
      container.appendChild(toast);

      const remove = () => {
        toast.classList.add('flash-toast-exit');
        setTimeout(() => toast.remove(), 300);
      };
      toast.querySelector('.ft-close').addEventListener('click', remove);
      setTimeout(remove, data.leveledUp ? 6000 : 4000);

      // Animate in
      requestAnimationFrame(() => toast.classList.add('flash-toast-enter'));
    })();
  </script>

</body>
</html>
