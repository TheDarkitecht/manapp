  <script>
    // Sticky nav
    window.addEventListener('scroll', () => {
      document.getElementById('lpNav').classList.toggle('lp-nav-scrolled', window.scrollY > 60);
    });

    // Mobile menu
    function toggleMenu() {
      document.getElementById('lpMobileMenu').classList.toggle('open');
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        e.preventDefault();
        const target = document.querySelector(a.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // Cookie consent banner
    (function() {
      if (!localStorage.getItem('cookieConsent')) {
        setTimeout(() => document.getElementById('cookieBanner').classList.add('visible'), 1200);
      }
    })();

    function dismissCookies(accepted) {
      localStorage.setItem('cookieConsent', accepted ? 'all' : 'essential');
      document.getElementById('cookieBanner').classList.remove('visible');
    }

    function openPrivacyCookie(e) {
      e.preventDefault();
      openPrivacy();
    }
  </script>

