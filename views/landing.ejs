      <p class="lp-section-sub">Från första intrycket till mental styrka. Teori, videogenomgång och prov i varje block.</p>

      <div class="lp-blocks-preview">
        <% blocks.forEach(function(block, i) { %>
          <div class="lp-block-card" style="--lp-card-gradient: <%= block.gradient %>;">
            <div class="lp-block-num"><%= i + 1 %></div>
            <div class="lp-block-icon"><%= block.icon %></div>
            <div class="lp-block-info">
              <h4><%= block.title %></h4>
              <p><%= block.subtitle %></p>
            </div>
            <% if (i === 0) { %>
              <span class="lp-block-badge lp-badge-free">Gratis</span>
            <% } else { %>
              <span class="lp-block-badge lp-badge-premium">Premium</span>
            <% } %>
          </div>
        <% }); %>
      </div>

      <div class="lp-academy-cta">
        <a href="/register" class="lp-btn-primary">Börja med Block 1 gratis →</a>
        <p class="lp-academy-cta-sub">Inget betalkort. Uppgradera när du vill.</p>
      </div>
