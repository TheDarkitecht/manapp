    <a href="/register" class="lp-sticky-btn">Börja gratis →</a>
    <span class="lp-sticky-sub">Inget betalkort</span>
  </div>

  <!-- ══ GDPR COOKIE BANNER ══════════════════════════════════════════════════ -->
  <div class="cookie-banner" id="cookieBanner">
    <p>Vi använder nödvändiga cookies för att sajten ska fungera. Inga spårningscookies används utan ditt samtycke.
       <a href="#" onclick="openPrivacyCookie(event)">Läs integritetspolicyn</a></p>
    <div class="cookie-banner-btns">
      <button class="cookie-btn-decline" onclick="dismissCookies(false)">Bara nödvändiga</button>
      <button class="cookie-btn-accept" onclick="dismissCookies(true)">Okej →</button>
    </div>
  </div>

  </main>

  <!-- ══ FOOTER ══════════════════════════════════════════════════════════════ -->
  <footer class="lp-footer">
    <div class="lp-footer-inner">
      <div class="lp-footer-brand">
        <div class="lp-footer-logo">🎯 Joakim Jaksen</div>
        <p>Säljutbildning som faktiskt fungerar.<br>Byggt av en säljare, för säljare.</p>
      </div>
      <div class="lp-footer-links">
        <a href="#akademin">Akademin</a>
        <a href="#pris">Prissättning</a>
        <a href="/login">Logga in</a>
        <a href="/register">Skapa konto</a>
        <a href="/terms">Användarvillkor</a>
        <a href="/integritetspolicy">Integritetspolicy</a>
      </div>
    </div>
    <div class="lp-footer-bottom">
      <p>© 2026 Joakim Jaksen / Brilliant Values Global AB. Alla rättigheter förbehållna.</p>
    </div>
  </footer>

  <script>
    // Account deleted toast
    if (new URLSearchParams(location.search).get('deleted') === '1') {
      const t = document.getElementById('deletedToast');
      t.style.display = 'flex';
      setTimeout(() => t.style.display = 'none', 6000);
    }

    // Sticky nav + mobile sticky bar
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY > 60;
      document.getElementById('lpNav').classList.toggle('lp-nav-scrolled', scrolled);
      // Show mobile sticky bar after scrolling past hero (~500px)
      const bar = document.getElementById('lpStickyBar');
      if (bar) {
        bar.classList.toggle('visible', window.scrollY > 500);
      }
    });

    // Mobile menu
    function toggleMenu() {
      const menu = document.getElementById('lpMobileMenu');
      const btn  = document.getElementById('lpHamburger');
      const isOpen = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      btn.textContent = isOpen ? '✕' : '☰';
      btn.setAttribute('aria-label', isOpen ? 'Stäng meny' : 'Öppna meny');
    }

    // Smooth scroll for anchor links (respects prefers-reduced-motion)
    (function() {
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
          e.preventDefault();
          const target = document.querySelector(a.getAttribute('href'));
          if (target) target.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
        });
      });
    })();

    // Cookie consent banner
    (function() {
      if (!localStorage.getItem('cookieConsent')) {
        setTimeout(() => document.getElementById('cookieBanner').classList.add('visible'), 1200);
      }
    })();

    function dismissCookies(accepted) {
      localStorage.setItem('cookieConsent', accepted ? 'all' : 'essential');
      document.getElementById('cookieBanner').classList.remove('visible');
    }

    function openPrivacyCookie(e) {
      e.preventDefault();
      window.open('/integritetspolicy', '_blank');
    }

    // Animated counter for stats
    (function() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const counters = [
        { el: document.querySelector('.lp-stat:nth-child(1) .lp-stat-num'), target: 200, suffix: '+', duration: 1200 },
        { el: document.querySelector('.lp-stat:nth-child(3) .lp-stat-num'), target: 22,  suffix: '+', duration: 900 },
        { el: document.querySelector('.lp-stat:nth-child(5) .lp-stat-num'), target: 1000, suffix: '+', duration: 1100 },
      ];

      function animateCounter(el, target, suffix, duration) {
        const start = performance.now();
        function update(now) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(update);
        }
        requestAnimationFrame(update);
      }

      const statsSection = document.querySelector('.lp-stats');
      if (!statsSection) return;
      const obs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) {
          counters.forEach(c => { if (c.el) animateCounter(c.el, c.target, c.suffix, c.duration); });
          obs.disconnect();
        }
      }, { threshold: 0.5 });
      obs.observe(statsSection);
    })();

    // FAQ accordion (landing page)
    function toggleLpFaq(btn) {
      const item = btn.closest('.lp-faq-item');
      const answer = item.querySelector('.lp-faq-a');
      const arrow = btn.querySelector('.lp-faq-arrow');
      const isOpen = item.classList.contains('open');
      // Close all open items
      document.querySelectorAll('.lp-faq-item.open').forEach(el => {
        el.classList.remove('open');
        el.querySelector('.lp-faq-a').style.maxHeight = null;
        el.querySelector('.lp-faq-arrow').textContent = '▾';
        el.querySelector('.lp-faq-q').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        arrow.textContent = '▴';
        btn.setAttribute('aria-expanded', 'true');
      }
    }
  </script>

  <!-- Scroll-reveal animations (respects prefers-reduced-motion) -->
  <script>
    (function() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const els = document.querySelectorAll(
        '.lp-about-grid, .lp-why-item, .lp-block-card, .lp-price-card, .lp-quote, .lp-faq-item, .lp-stat'
      );
      // Precompute index map to avoid O(n) lookup inside observer callback
      const indexMap = new Map();
      els.forEach((el, i) => {
        indexMap.set(el, i);
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      });
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const delay = 60 * (indexMap.get(e.target) % 4); // stagger siblings
            setTimeout(() => {
              e.target.style.opacity = '1';
              e.target.style.transform = 'translateY(0)';
            }, delay);
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      els.forEach(el => obs.observe(el));
    })();
  </script>

  <!-- Plausible Analytics (privacy-first, no cookies) -->
  <script defer data-domain="joakimjaksen.se" src="https://plausible.io/js/script.js"></script>

