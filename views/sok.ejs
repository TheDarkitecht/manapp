<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sök — Joakim Jaksen</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔍</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/gamification.css" />
</head>
<body class="block-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/dashboard" class="learn-nav-back">← Dashboard</a>
    <span class="learn-nav-title">🔍 Sök</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="search-wrap">

    <div class="search-header">
      <h1>🔍 Sök i utbildningen</h1>
      <p>Sök över alla block, tekniker, scenarier och säljtermer.</p>
    </div>

    <form method="GET" action="/sok" class="search-form">
      <input type="search" name="q" class="search-input" value="<%= query %>" placeholder="T.ex. 'förvirrad ton', 'BATNA', 'Columbo', 'invändning' …" autofocus maxlength="100" />
      <button type="submit" class="search-btn">Sök</button>
    </form>

    <% if (query && query.length >= 2) { %>
      <% const totalResults = blockResults.length + glossaryResults.length; %>
      <% if (totalResults === 0) { %>
        <div class="search-empty">
          <div style="font-size:2.5rem;margin-bottom:0.5rem;">🤷</div>
          <h3 style="color:#f1f5f9;">Inget matchade "<%= query %>"</h3>
          <p>Testa en annan formulering eller bläddra direkt i blocken.</p>
        </div>
      <% } %>

      <% if (blockResults.length) { %>
        <section class="search-section">
          <h2>📚 Block <span class="search-count">(<%= blockResults.length %>)</span></h2>
          <% blockResults.forEach(function(r) { %>
            <a href="/learn/<%= r.block.id %>" class="search-result">
              <span class="search-result-tag">Block <%= r.index %></span>
              <h3><%- highlightMatch(r.block.title, query) %></h3>
              <p><%- highlightMatch(r.snippet, query) %></p>
              <div style="margin-top:0.5rem;font-size:0.75rem;color:#64748b;">
                Matchade i:
                <% if (r.hits.title) { %> <strong style="color:#a5b4fc;">titel</strong><% } %>
                <% if (r.hits.subtitle) { %> <strong style="color:#a5b4fc;">underrubrik</strong><% } %>
                <% if (r.hits.theory) { %> teori<% } %>
                <% if (r.hits.quiz) { %> prov<% } %>
                <% if (r.hits.roleplay) { %> rollspel<% } %>
                <% if (r.hits.mission) { %> uppdrag<% } %>
              </div>
            </a>
          <% }); %>
        </section>
      <% } %>

      <% if (glossaryResults.length) { %>
        <section class="search-section">
          <h2>📖 Säljordboken <span class="search-count">(<%= glossaryResults.length %>)</span></h2>
          <% glossaryResults.forEach(function(t) { %>
            <a href="/ordbok#<%= encodeURIComponent(t.term) %>" class="search-result">
              <span class="search-result-tag"><%= t.category %></span>
              <h3><%- highlightMatch(t.term, query) %></h3>
              <p><%- highlightMatch(t.definition, query) %></p>
            </a>
          <% }); %>
        </section>
      <% } %>

    <% } else if (query) { %>
      <div class="search-empty">
        <p>Skriv minst 2 tecken för att söka.</p>
      </div>
    <% } else { %>
      <div class="search-empty">
        <p style="color:#cbd5e1;">💡 Försök söka efter:</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:center;margin-top:1rem;">
          <% ['BATNA','förvirrad ton','Cialdini','SPIN','Columbo','break-up','mirroring','invändning','rollspel','Atomic Habits'].forEach(function(tip) { %>
            <a href="/sok?q=<%= encodeURIComponent(tip) %>" style="padding:0.4rem 0.85rem;background:rgba(99,102,241,0.12);color:#a5b4fc;border-radius:999px;text-decoration:none;font-size:0.85rem;"><%= tip %></a>
          <% }); %>
        </div>
      </div>
    <% } %>

  </main>

</body>
</html>
