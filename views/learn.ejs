<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Säljutbildning — Joakim Jaksen</title>
  <meta name="description" content="20 block som täcker hela säljprocessen — teori, video och prov. Byggt av Joakim Jaksen." />
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/recommendations.css" />
</head>
<body class="learn-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/dashboard" class="learn-nav-back">← Dashboard</a>
    <span class="learn-nav-title">Säljutbildning</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <%
    const completedCount = blocks.filter(b => progress && progress[b.id]?.completed).length;
    const total = blocks.length;
    const pct   = total > 0 ? Math.round((completedCount / total) * 100) : 0;
    const nextUnfinished = blocks.find(b => !(progress && progress[b.id]?.completed));
  %>

  <div class="learn-hero">
    <h1>Joakim Jaksens Säljutbildning</h1>
    <% if (role === 'free') { %>
      <p>Du har tillgång till <strong>Block 1 & 2</strong>. De övriga 18 blocken kräver Premium.</p>
      <a href="/upgrade" class="learn-upgrade-cta">⭐ Lås upp alla 20 block — 199 kr/mån →</a>
    <% } else { %>
      <p><%= completedCount %> av <%= total %> block avklarade</p>
      <% if (completedCount < total) { %>
        <div class="learn-progress-bar-wrap">
          <div class="learn-progress-bar"
               role="progressbar"
               aria-valuenow="<%= pct %>"
               aria-valuemin="0"
               aria-valuemax="100"
               aria-label="<%= completedCount %> av <%= total %> block avklarade">
            <div class="learn-progress-fill" style="width:<%= pct %>%;"></div>
          </div>
          <span class="learn-pct-label" aria-hidden="true"><%= pct %>%</span>
        </div>
        <% if (nextUnfinished) { %>
          <a href="/learn/<%= nextUnfinished.id %>" class="learn-continue-btn">Fortsätt: <%= nextUnfinished.title %> →</a>
        <% } %>
      <% } else { %>
        <div class="learn-completed-badge">🏆 Alla block avklarade!</div>
      <% } %>
    <% } %>
  </div>

  <main id="main-content">
  <div class="blocks-grid">
    <% blocks.forEach(function(block, i) { %>
      <% const isLocked = role === 'free' && !freeBlockIds.includes(block.id); %>
      <% const prog = (progress && progress[block.id]) || {}; %>
      <% const status = (blockStatus && blockStatus[block.id]) || { status: 'untouched', stepsDone: 0 }; %>
      <% const isMastered = status.status === 'mastered'; %>
      <% const isAdvanced = status.status === 'advanced'; %>
      <% const isQuizDone = status.status === 'quiz_done'; %>
      <% const isInProgress = status.status === 'in_progress'; %>
      <% const isNext = !isLocked && !isMastered && nextUnfinished && nextUnfinished.id === block.id; %>
      <a href="/learn/<%= block.id %>"
         class="block-card block-card-status-<%= status.status %> <%= isLocked ? 'block-locked' : '' %> <%= isMastered ? 'block-mastered' : '' %> <%= prog.completed ? 'block-completed' : '' %> <%= isNext ? 'block-next' : '' %>"
         style="--card-gradient: <%= block.gradient %>;">
        <div class="block-card-number">
          <% if (isMastered) { %>🏆<% } else if (isAdvanced) { %>⚡<% } else if (isQuizDone) { %>✓<% } else { %><%= i + 1 %><% } %>
        </div>
        <div class="block-card-icon"><%= isLocked ? '🔒' : block.icon %></div>
        <div class="block-card-body">
          <h3><%= block.title %></h3>
          <p><%= block.subtitle %></p>

          <% if (!isLocked && status.stepsDone > 0) { %>
            <div class="block-card-steps" aria-label="<%= status.stepsDone %> av 4 steg klara">
              <span class="bcs-dot <%= status.stepsDone >= 1 ? 'bcs-done' : '' %>" title="Läs">📖</span>
              <span class="bcs-dot <%= status.stepsDone >= 2 ? 'bcs-done' : '' %>" title="Öva">🎭</span>
              <span class="bcs-dot <%= status.stepsDone >= 3 ? 'bcs-done' : '' %>" title="Gör">🎯</span>
              <span class="bcs-dot <%= status.stepsDone >= 4 ? 'bcs-done' : '' %>" title="Reflektera">💭</span>
            </div>
          <% } %>

          <% if (prog.quiz_score !== undefined && prog.quiz_score !== null) { %>
            <span class="block-score-badge"><%= prog.quiz_score %>/<%= prog.quiz_total %> rätt</span>
          <% } %>
          <% if (isMastered) { %>
            <span class="block-mastered-badge">🏆 Bemästrad</span>
          <% } else if (isAdvanced) { %>
            <span class="block-advanced-badge">⚡ <%= status.stepsDone %>/4 steg</span>
          <% } else if (isNext) { %>
            <span class="block-next-badge">Fortsätt här →</span>
          <% } %>
          <% if (isLocked) { %>
            <span class="block-preview-hint">Förhandsgranskning →</span>
          <% } %>
        </div>
        <div class="block-card-arrow"><%= isLocked ? '👁' : (isMastered ? '↺' : '→') %></div>
      </a>
    <% }); %>
  </div>


  <script>
    // Animate progress bar on load (respects prefers-reduced-motion)
    (function() {
      const fill = document.querySelector('.learn-progress-fill');
      if (!fill) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const target = fill.style.width;
      fill.style.width = '0';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        fill.style.width = target;
      }));
    })();
  </script>

  </main>

  <!-- ── Mobile bottom navigation ──────────────────────────────────────────── -->
  <nav class="app-bottom-nav">
    <a href="/dashboard" class="app-bottom-nav-item">
      <span class="abn-icon">🏠</span>
      <span class="abn-label">Hem</span>
    </a>
    <a href="/learn" class="app-bottom-nav-item active">
      <span class="abn-icon">📚</span>
      <span class="abn-label">Utbildning</span>
    </a>
    <a href="/ordbok" class="app-bottom-nav-item">
      <span class="abn-icon">📖</span>
      <span class="abn-label">Ordbok</span>
    </a>
    <% if (role === 'free') { %>
      <a href="/upgrade" class="app-bottom-nav-item abn-upgrade">
        <span class="abn-icon">⭐</span>
        <span class="abn-label">Premium</span>
      </a>
    <% } else { %>
      <a href="/logout" class="app-bottom-nav-item">
        <span class="abn-icon">🚪</span>
        <span class="abn-label">Logga ut</span>
      </a>
    <% } %>
  </nav>

</body>
</html>
