<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Välkommen till <%= isPro ? 'Pro' : 'Premium' %> — Joakim Jaksen</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="learn-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <canvas id="confettiCanvas" style="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:999;"></canvas>

  <main id="main-content">
  <div class="success-wrap">
    <div class="upgrade-success-card">

      <!-- Confetti-style top glow -->
      <div class="us-glow"></div>

      <div class="us-icon">🎉</div>

      <% if (isPro && trialActive) { %>
        <div class="us-badge" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#0f172a;">🎁 Pro-trial aktiverad</div>
        <h1><%= username %>, du är inne.</h1>
        <p class="us-sub">
          Ditt Pro-trial är igång — du har <strong>24 timmar</strong> att utforska samtalsanalysen. Inget debiteras förrän efter trial. Avbryt när som helst i ditt konto.
        </p>
      <% } else if (isPro) { %>
        <div class="us-badge" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#0f172a;">🎙️ Pro aktiverat</div>
        <h1><%= username %>, du är inne.</h1>
        <p class="us-sub">
          Ditt konto är nu Pro. Du har Premium + samtalsanalys på riktiga kundsamtal — det enda som faktiskt flyttar nålen i längden.
        </p>
      <% } else { %>
        <div class="us-badge">⭐ Premium aktiverat</div>
        <h1><%= username %>, du är inne.</h1>
        <p class="us-sub">Ditt konto är nu Premium. Du har tillgång till alla block, AI-assistenten Jocke och allt som hjälper dig bli en bättre säljare — från och med nu.</p>
      <% } %>

      <!-- Next steps — tier-anpassade -->
      <div class="us-steps">
        <% if (isPro) { %>
          <div class="us-step">
            <div class="us-step-num">1</div>
            <div class="us-step-text">
              <strong>Ladda upp ditt första samtal</strong>
              <span>Spela in ett kundsamtal (mobil/Zoom/Teams), ladda upp, få konkret feedback om ~30 sek. Detta är Pro-funktionen.</span>
            </div>
          </div>
          <div class="us-step">
            <div class="us-step-num">2</div>
            <div class="us-step-text">
              <strong>Träna med Jocke (AI-rollspel)</strong>
              <span>Obegränsat antal rollspel. Öva invändningar, öppningssamtal, avslut — direkt i dashboarden.</span>
            </div>
          </div>
          <div class="us-step">
            <div class="us-step-num">3</div>
            <div class="us-step-text">
              <strong>Gå igenom blocken systematiskt</strong>
              <span>20+ block med teori, prov och uppdrag. Bygg grunden. Pro-feedback blir bättre när du har strukturen.</span>
            </div>
          </div>
        <% } else { %>
          <div class="us-step">
            <div class="us-step-num">1</div>
            <div class="us-step-text">
              <strong>Fortsätt där du slutade</strong>
              <span>Alla block är nu öppna. Hoppa direkt in i nästa block i din resa.</span>
            </div>
          </div>
          <div class="us-step">
            <div class="us-step-num">2</div>
            <div class="us-step-text">
              <strong>Testa Jocke</strong>
              <span>Din AI-säljcoach väntar. Öva en invändning, träna ett öppningssamtal — direkt i dashboarden.</span>
            </div>
          </div>
          <div class="us-step">
            <div class="us-step-num">3</div>
            <div class="us-step-text">
              <strong>Kör ett prov per block</strong>
              <span>Testa dig själv efter varje block. Din progress sparas automatiskt.</span>
            </div>
          </div>
        <% } %>
      </div>

      <div class="us-actions">
        <% if (isPro) { %>
          <a href="/pro/samtal/ny" class="us-btn-primary">🎙️ Ladda upp första samtalet →</a>
          <a href="/learn" class="us-btn-secondary">Bläddra block</a>
        <% } else { %>
          <a href="/learn" class="us-btn-primary">Börja lära dig nu →</a>
          <a href="/dashboard" class="us-btn-secondary">Till dashboarden</a>
        <% } %>
      </div>

      <p class="us-fine">Frågor? Kontakta oss på <a href="mailto:info@joakimjaksen.se">info@joakimjaksen.se</a> — vi svarar snabbt.</p>

    </div>
  </div>
  </main>

  <script>
    // Lightweight confetti burst (respects prefers-reduced-motion)
    (function() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.getElementById('confettiCanvas').style.display = 'none';
        return;
      }
      const canvas = document.getElementById('confettiCanvas');
      const ctx = canvas.getContext('2d');
      function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
      resize();
      window.addEventListener('resize', resize, { passive: true });

      const colors = ['#6366f1','#8b5cf6','#a78bfa','#f59e0b','#10b981','#818cf8','#fbbf24','#34d399'];
      const pieces = Array.from({ length: 120 }, () => ({
        x: Math.random() * canvas.width,
        y: Math.random() * -canvas.height,
        w: Math.random() * 8 + 4,
        h: Math.random() * 14 + 6,
        color: colors[Math.floor(Math.random() * colors.length)],
        vx: (Math.random() - 0.5) * 3,
        vy: Math.random() * 4 + 2,
        rot: Math.random() * 360,
        vrot: (Math.random() - 0.5) * 8,
        opacity: 1,
      }));

      let startTime = null;
      const duration = 4000; // 4 seconds

      function draw(ts) {
        if (!startTime) startTime = ts;
        const elapsed = ts - startTime;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        let alive = false;
        pieces.forEach(p => {
          if (p.y < canvas.height + 20) {
            alive = true;
            p.x  += p.vx;
            p.y  += p.vy;
            p.rot += p.vrot;
            p.vy += 0.05; // gravity
            if (elapsed > duration * 0.6) p.opacity = Math.max(0, p.opacity - 0.015);

            ctx.save();
            ctx.globalAlpha = p.opacity;
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rot * Math.PI / 180);
            ctx.fillStyle = p.color;
            ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
            ctx.restore();
          }
        });

        if (alive) requestAnimationFrame(draw);
        else canvas.style.display = 'none';
      }

      requestAnimationFrame(draw);
    })();
  </script>

</body>
</html>
