<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= block.title %> — Joakim Jaksen Säljutbildning</title>
  <meta name="description" content="<%= block.subtitle %> — Joakim Jaksens säljutbildning med teori, video och prov." />
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="block-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <!-- Reading progress bar (decorative — hidden from screen readers) -->
  <div id="readProgress" aria-hidden="true" style="position:fixed;top:0;left:0;height:3px;width:0;background:linear-gradient(90deg,#6366f1,#8b5cf6);z-index:1000;pointer-events:none;"></div>

  <% if (isTeaser) { %>
  <div class="teaser-top-bar">
    <span>⭐ Du ser en förhandsvisning — <strong><%= block.title %></strong> kräver Premium</span>
    <a href="/upgrade" class="teaser-top-btn">Uppgradera — 199 kr/mån →</a>
  </div>
  <% } %>

  <nav class="learn-nav">
    <a href="/learn" class="learn-nav-back">← Alla block</a>
    <span class="learn-nav-title"><%= block.title %></span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <!-- Block hero -->
  <div class="block-hero" style="background: <%= block.gradient %>;">
    <div class="block-hero-icon"><%= block.icon %></div>
    <div>
      <h1><%= block.title %></h1>
      <p><%= block.subtitle %></p>
      <% if (!isTeaser) { %>
        <span class="block-read-time">📖 ~<%= readTime %> min läsning</span>
      <% } %>
    </div>
    <% if (isTeaser) { %>
      <div class="block-hero-lock-badge">🔒 Premium</div>
    <% } else if (blockProg && blockProg.completed) { %>
      <div class="block-hero-done-badge">✓ Avklarad</div>
    <% } %>
  </div>

  <!-- Tabs -->
  <main id="main-content">
  <div class="tabs-wrapper">
    <div class="tabs" role="tablist" aria-label="Block <%= block.title %>">
      <button class="tab active" id="tab-btn-theory" data-tab="theory" onclick="showTab('theory', this)" role="tab" aria-selected="true" aria-controls="tab-theory" tabindex="0">📖 Teori</button>
      <button class="tab" id="tab-btn-video" data-tab="video" onclick="showTab('video', this)" role="tab" aria-selected="false" aria-controls="tab-video" tabindex="-1">🎬 Video</button>
      <button class="tab" id="tab-btn-quiz" data-tab="quiz" onclick="showTab('quiz', this)" role="tab" aria-selected="false" aria-controls="tab-quiz" tabindex="-1">🧠 Prov</button>
    </div>
  </div>

  <div class="tab-content-wrapper">

    <% if (isTeaser) { %>

      <!-- ── TEASER MODE — theory preview + paywall ──────────────────── -->
      <div id="tab-theory" class="tab-content active" role="tabpanel" aria-labelledby="tab-btn-theory">
        <div class="theory-body teaser-preview">
          <%- block.teaser %>
        </div>
        <div class="teaser-fade"></div>
        <div class="teaser-lock-wall">
          <div class="teaser-lock-inner">
            <div class="teaser-lock-icon"><%= block.icon %></div>
            <h3>Lås upp <%= block.title %></h3>
            <p>Du ser bara förhandsgranskningen. Hela blocket — komplett teori, videogenomgång och 10-frågors-prov — ingår i Premium.</p>
            <div class="teaser-checklist">
              <div class="teaser-check">📖 Komplett teori</div>
              <div class="teaser-check">🎬 Videogenomgång</div>
              <div class="teaser-check">🧠 10-frågorsprov</div>
              <div class="teaser-check">🤖 Jocke — din AI-säljcoach</div>
            </div>
            <a href="/upgrade" class="teaser-upgrade-cta">⭐ Uppgradera till Premium — 199 kr/mån →</a>
            <p class="teaser-price-hint">Avsluta när som helst. Säker betalning via Stripe.</p>
          </div>
        </div>
      </div>

      <div id="tab-video" class="tab-content" role="tabpanel" aria-labelledby="tab-btn-video">
        <div class="teaser-locked-tab">
          <div class="teaser-lock-icon">🎬</div>
          <h3>Videogenomgång: <%= block.title %></h3>
          <p>En kuraterad videogenomgång som visualiserar och fördjupar teorin. Ingår i Premium.</p>
          <a href="/upgrade" class="teaser-upgrade-cta">⭐ Uppgradera →</a>
        </div>
      </div>

      <div id="tab-quiz" class="tab-content" role="tabpanel" aria-labelledby="tab-btn-quiz">
        <div class="teaser-locked-tab">
          <div class="teaser-lock-icon">🧠</div>
          <h3>Prov: <%= block.title %></h3>
          <p>10 frågor som bekräftar att du verkligen förstått blocket. Din progress sparas. Ingår i Premium.</p>
          <a href="/upgrade" class="teaser-upgrade-cta">⭐ Uppgradera →</a>
        </div>
      </div>

    <% } else { %>

      <!-- ── FULL ACCESS MODE ────────────────────────────────────────── -->

      <!-- THEORY -->
      <div id="tab-theory" class="tab-content active" role="tabpanel" aria-labelledby="tab-btn-theory">
        <div class="theory-body">
          <%- block.theory %>
        </div>
        <!-- Bottom nudge toward quiz (shown after reading) -->
        <div class="theory-cta-row">
          <button class="theory-quiz-nudge" onclick="showTab('quiz', document.querySelector('[data-tab=quiz]'))">
            🧠 Redo för provet? Testa dina kunskaper →
          </button>
        </div>
      </div>

      <!-- VIDEO -->
      <div id="tab-video" class="tab-content" role="tabpanel" aria-labelledby="tab-btn-video">
        <div class="video-wrapper">
          <div class="video-label">Rekommenderad video om <strong><%= block.title %></strong></div>
          <div class="video-embed">
            <iframe
              src="https://www.youtube.com/embed/<%= block.youtubeId %>?rel=0&modestbranding=1"
              title="<%= block.title %>"
              frameborder="0"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>

      <!-- QUIZ -->
      <div id="tab-quiz" class="tab-content" role="tabpanel" aria-labelledby="tab-btn-quiz">
        <div class="quiz-wrapper" id="quizWrapper">
          <div class="quiz-header">
            <h2>🧠 Prov — <%= block.title %></h2>
            <p>10 frågor. Välj ett svar per fråga och klicka sedan "Rätta provet".</p>
          </div>

          <form id="quizForm">
            <% block.quiz.forEach(function(q, qi) { %>
              <fieldset class="quiz-question" id="qq-<%= qi %>">
                <legend class="quiz-q-text"><span class="q-num" aria-hidden="true"><%= qi + 1 %></span> <%= q.q %></legend>
                <div class="quiz-options">
                  <% q.options.forEach(function(opt, oi) { %>
                    <label class="quiz-option" data-qi="<%= qi %>" data-oi="<%= oi %>">
                      <input type="radio" name="q<%= qi %>" value="<%= oi %>" />
                      <span class="option-letter" aria-hidden="true"><%= ['A','B','C','D'][oi] %></span>
                      <span><%= opt %></span>
                    </label>
                  <% }); %>
                </div>
              </fieldset>
            <% }); %>

            <button type="button" class="quiz-submit-btn" onclick="submitQuiz()">Rätta provet →</button>
          </form>

          <!-- Result panel (hidden until submitted) -->
          <div id="quizResult" class="quiz-result" style="display:none;"></div>
        </div>
      </div>

    <% } %>

  </div>

  <!-- Block navigation -->
  </main>
  <div class="block-nav-footer">
    <% const idx = blocks.findIndex(b => b.id === block.id); %>
    <% if (idx > 0) { %>
      <a href="/learn/<%= blocks[idx-1].id %>" class="block-nav-btn" title="Föregående block (←)">← <%= blocks[idx-1].title %></a>
    <% } else { %>
      <span></span>
    <% } %>
    <a href="/learn" class="block-nav-btn outline">Alla block</a>
    <% if (idx < blocks.length - 1) { %>
      <a href="/learn/<%= blocks[idx+1].id %>" class="block-nav-btn" title="Nästa block (→)"><%= blocks[idx+1].title %> →</a>
    <% } else { %>
      <span></span>
    <% } %>
  </div>

  <% if (!isTeaser) { %>
  <!-- ── Jocke chat bubble (premium users only) ──────────────────────────── -->
  <button class="chat-bubble" id="chatBubble" onclick="toggleChat()" title="Fråga Jocke om <%= block.title %>" aria-label="Öppna chatt med Jocke" aria-expanded="false">
    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="white" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/>
    </svg>
  </button>

  <div class="chat-window" id="chatWindow" role="dialog" aria-label="Chatt med Jocke" aria-modal="true" aria-hidden="true">
    <div class="chat-header">
      <div class="chat-header-info">
        <div class="chat-avatar">J</div>
        <div>
          <strong>Jocke</strong>
          <span class="chat-status">● Online</span>
        </div>
      </div>
      <button class="chat-close" onclick="toggleChat()" aria-label="Stäng chatt">✕</button>
    </div>
    <div class="chat-messages" id="chatMessages">
      <div class="chat-msg assistant">
        <p>Du läser <strong><%= block.title %></strong>. Ställ en fråga, träna ett scenario eller be om ett konkret råd. 🎯</p>
      </div>
    </div>
    <div class="chat-input-area">
      <textarea id="chatInput" placeholder="Skriv ett meddelande..." rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
      <button onclick="sendMessage()" aria-label="Skicka meddelande">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="white" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M2 21l21-9L2 3v7l15 2-15 2z"/>
        </svg>
      </button>
    </div>
  </div>
  <% } %>

  <script>
    // ── Motion preference helper ────────────────────────────────────────────────
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Smooth-scroll wrapper that respects prefers-reduced-motion
    function safeScrollIntoView(el, opts) {
      el.scrollIntoView({ ...opts, behavior: prefersReducedMotion ? 'auto' : (opts.behavior || 'smooth') });
    }

    // ── Reading progress bar ────────────────────────────────────────────────────

    (function() {
      const bar = document.getElementById('readProgress');
      // Only apply transition when user accepts motion
      if (!prefersReducedMotion) {
        bar.style.transition = 'width 0.1s linear';
      }
      window.addEventListener('scroll', function() {
        const scrolled = window.scrollY;
        const total = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
      }, { passive: true });
    })();

    // ── Keyboard navigation ─────────────────────────────────────────────────────
    // Left/Right arrow → prev/next block (when not in an input/textarea/tab)
    document.addEventListener('keydown', function(e) {
      const tag = document.activeElement.tagName;
      const inInput = tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
      if (inInput) return;
      // Don't navigate blocks when arrow keys are used inside the tablist
      const inTab = document.activeElement.getAttribute('role') === 'tab';
      if (inTab) return;

      <% const kbIdx = blocks.findIndex(b => b.id === block.id); %>
      if (e.key === 'ArrowLeft') {
        <% if (kbIdx > 0) { %>
          window.location.href = '/learn/<%= blocks[kbIdx - 1].id %>';
        <% } %>
      } else if (e.key === 'ArrowRight') {
        <% if (kbIdx < blocks.length - 1) { %>
          window.location.href = '/learn/<%= blocks[kbIdx + 1].id %>';
        <% } %>
      } else if (e.key === 'Escape') {
        // Close chat if open
        const chatWindow = document.getElementById('chatWindow');
        if (chatWindow && chatWindow.classList.contains('open')) {
          toggleChat();
        }
      }
    });

    // ── Tabs ────────────────────────────────────────────────────────────────

    function showTab(name, btn) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
      document.querySelectorAll('.tab').forEach(el => {
        el.classList.remove('active');
        el.setAttribute('aria-selected', 'false');
        el.setAttribute('tabindex', '-1');
      });
      document.getElementById('tab-' + name).classList.add('active');
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      btn.setAttribute('tabindex', '0');
    }

    // Arrow-key navigation within the tablist (ARIA pattern)
    (function() {
      const tabBtns = Array.from(document.querySelectorAll('.tabs [role="tab"]'));
      tabBtns.forEach((btn, i) => {
        btn.addEventListener('keydown', function(e) {
          let next = -1;
          if (e.key === 'ArrowRight') next = (i + 1) % tabBtns.length;
          else if (e.key === 'ArrowLeft') next = (i - 1 + tabBtns.length) % tabBtns.length;
          else if (e.key === 'Home') next = 0;
          else if (e.key === 'End') next = tabBtns.length - 1;
          if (next !== -1) {
            e.preventDefault();
            showTab(tabBtns[next].dataset.tab, tabBtns[next]);
            tabBtns[next].focus();
          }
        });
      });
    })();

    <% if (!isTeaser) { %>
    // ── Quiz ────────────────────────────────────────────────────────────────

    const correctAnswers = <%- JSON.stringify(block.quiz.map(q => q.answer)).replace(/<\/script>/gi, '<\\/script>') %>;

    function submitQuiz() {
      const form = document.getElementById('quizForm');
      let score = 0;
      let allAnswered = true;

      correctAnswers.forEach((correct, qi) => {
        const selected = form.querySelector(`input[name="q${qi}"]:checked`);
        if (!selected) { allAnswered = false; return; }

        const value = parseInt(selected.value);
        const questionEl = document.getElementById('qq-' + qi);
        const options = questionEl.querySelectorAll('.quiz-option');

        options.forEach(opt => {
          opt.style.pointerEvents = 'none';
          const oi = parseInt(opt.dataset.oi);
          if (oi === correct) {
            opt.classList.add('correct');
          } else if (oi === value && value !== correct) {
            opt.classList.add('wrong');
          }
        });

        if (value === correct) score++;
      });

      if (!allAnswered) {
        // Find first unanswered question and scroll to it with inline error
        let errorEl = document.getElementById('quiz-inline-error');
        if (!errorEl) {
          errorEl = document.createElement('p');
          errorEl.id = 'quiz-inline-error';
          errorEl.setAttribute('role', 'alert');
          errorEl.style.cssText = 'color:#f87171;font-size:.875rem;margin:.75rem 0 0;font-weight:600;';
          document.querySelector('.quiz-submit-btn').insertAdjacentElement('beforebegin', errorEl);
        }
        errorEl.textContent = '⚠️ Svara på alla frågor innan du rättar provet.';

        // Scroll to and highlight first unanswered question
        for (let i = 0; i < correctAnswers.length; i++) {
          if (!form.querySelector(`input[name="q${i}"]:checked`)) {
            const unansweredEl = document.getElementById('qq-' + i);
            safeScrollIntoView(unansweredEl, { block: 'center' });
            unansweredEl.classList.add('unanswered-highlight');
            setTimeout(() => unansweredEl.classList.remove('unanswered-highlight'), 2000);
            break;
          }
        }
        return;
      }

      // Clear inline error if all answered
      const errEl = document.getElementById('quiz-inline-error');
      if (errEl) errEl.remove();

      const resultEl = document.getElementById('quizResult');
      const pct = Math.round((score / correctAnswers.length) * 100);
      const passed = pct >= 60;
      const emoji = pct >= 80 ? '🏆' : pct >= 60 ? '👍' : '📚';
      const msg   = pct >= 80 ? 'Utmärkt! Du behärskar det här blocket.'
                  : pct >= 60 ? 'Bra jobbat! Lite mer repetition gör dig till expert.'
                  : 'Läs igenom teorin igen — du klarar det!';

      <% const blockIdx = blocks.findIndex(b => b.id === block.id); %>
      <% const nextBlock = blocks[blockIdx + 1]; %>

      let nextBtnHtml = '';
      if (passed) {
        <% if (nextBlock) { %>
          <% if (role === 'free' && !freeBlockIds.includes(nextBlock.id)) { %>
            nextBtnHtml = `<a href="/upgrade" class="next-block-btn upgrade-next">⭐ Lås upp Block <%= blockIdx + 2 %>: <%= nextBlock.title %> →</a>`;
          <% } else { %>
            nextBtnHtml = `<a href="/learn/<%= nextBlock.id %>" class="next-block-btn">Nästa block: <%= nextBlock.title %> →</a>`;
          <% } %>
        <% } else { %>
          nextBtnHtml = `<a href="/learn" class="next-block-btn">🏆 Du har klarat alla block! Se översikt →</a>`;
        <% } %>
      }

      resultEl.innerHTML = `
        <div class="result-score">${emoji} ${score} / ${correctAnswers.length} rätt (${pct}%)</div>
        <p class="result-msg">${msg}</p>
        <div class="result-actions">
          <button onclick="retryQuiz()" class="retry-btn">Försök igen</button>
          ${nextBtnHtml}
        </div>
      `;
      resultEl.style.display = 'block';
      resultEl.setAttribute('tabindex', '-1');
      safeScrollIntoView(resultEl, {});
      setTimeout(() => resultEl.focus({ preventScroll: true }), prefersReducedMotion ? 0 : 400); // focus after scroll completes
      document.querySelector('.quiz-submit-btn').style.display = 'none';

      // Save result to server
      fetch('/quiz-result', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-csrf-token': '<%= csrfToken %>',
        },
        body: JSON.stringify({ blockId: '<%= block.id %>', score, total: correctAnswers.length }),
      }).catch(() => {});
    }

    function retryQuiz() {
      // Clear inline error if present
      const prevErr = document.getElementById('quiz-inline-error');
      if (prevErr) prevErr.remove();

      // Reset all radio buttons
      const form = document.getElementById('quizForm');
      form.querySelectorAll('input[type="radio"]').forEach(r => r.checked = false);

      // Remove correct/wrong styling and re-enable clicks
      form.querySelectorAll('.quiz-option').forEach(opt => {
        opt.classList.remove('correct', 'wrong');
        opt.style.pointerEvents = '';
      });

      // Hide result panel, show submit button
      document.getElementById('quizResult').style.display = 'none';
      document.querySelector('.quiz-submit-btn').style.display = '';

      // Scroll to top of quiz
      safeScrollIntoView(document.getElementById('quizWrapper'), {});
    }
    <% } %>

    // ── Jocke chat (premium users only) ─────────────────────────────────────
    <% if (!isTeaser) { %>
    let chatOpen = false;
    // Seed context so Jocke knows which block the user is on
    let messages = [
      { role: 'user', content: 'Jag läser just nu Block <%= blocks.findIndex(b => b.id === block.id) + 1 %>: <%= block.title %>.' },
      { role: 'assistant', content: 'Förstår! Du jobbar med <%= block.title %>. Ställ dina frågor eller berätta vilken situation du vill träna.' },
    ];

    function toggleChat() {
      chatOpen = !chatOpen;
      const win = document.getElementById('chatWindow');
      win.classList.toggle('open', chatOpen);
      // aria-hidden="true" when closed prevents browsers from treating this
      // as an open modal dialog and making the rest of the page inert.
      win.setAttribute('aria-hidden', chatOpen ? 'false' : 'true');
      document.getElementById('chatBubble').setAttribute('aria-expanded', chatOpen ? 'true' : 'false');
      if (chatOpen) {
        document.getElementById('chatInput').focus();
      } else {
        // Return focus to the bubble when chat is closed
        document.getElementById('chatBubble').focus();
      }
    }

    function handleKey(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    }

    async function sendMessage() {
      const input = document.getElementById('chatInput');
      const text = input.value.trim();
      if (!text) return;
      appendMessage('user', text);
      input.value = '';
      input.style.height = 'auto'; // reset height after clearing
      messages.push({ role: 'user', content: text });
      const typingId = showTyping();
      try {
        const res = await fetch('/chat', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-csrf-token': '<%= csrfToken %>',
          },
          body: JSON.stringify({ messages }),
        });
        const data = await res.json();
        removeTyping(typingId);
        if (!res.ok || data.error) {
          // Show error in UI but don't push it into message history
          appendMessage('assistant', data.error || 'Något gick fel. Försök igen.');
          return;
        }
        const reply = data.reply || 'Inget svar mottogs.';
        appendMessage('assistant', reply);
        messages.push({ role: 'assistant', content: reply });
      } catch (err) {
        removeTyping(typingId);
        appendMessage('assistant', 'Kunde inte nå Jocke just nu. Försök igen.');
      }
    }

    function appendMessage(role, text) {
      const box = document.getElementById('chatMessages');
      const div = document.createElement('div');
      div.className = `chat-msg ${role}`;
      div.innerHTML = `<p>${renderMarkdown(text)}</p>`;
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
    }

    function showTyping() {
      const box = document.getElementById('chatMessages');
      const div = document.createElement('div');
      div.className = 'chat-msg assistant typing-indicator';
      div.id = 'typing-' + Date.now();
      div.innerHTML = '<p><span></span><span></span><span></span></p>';
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
      return div.id;
    }

    function removeTyping(id) {
      const el = document.getElementById(id);
      if (el) el.remove();
    }

    function escapeHtml(text) {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }
    function renderMarkdown(raw) {
      let s = escapeHtml(raw);
      s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      s = s.replace(/(?<!\*)\*([^*\n]+?)\*(?!\*)/g, '<em>$1</em>');
      s = s.replace(/^[•\-] (.+)/gm, '<li>$1</li>');
      s = s.replace(/(<li>.*<\/li>)/gs, '<ul>$1</ul>');
      s = s.replace(/\n(?!<\/?(?:ul|li))/g, '<br>');
      s = s.replace(/<br>\s*(<ul>)/g, '$1');
      return s;
    }

    function autoResize(ta) {
      ta.style.height = 'auto';
      ta.style.height = Math.min(ta.scrollHeight, 120) + 'px';
    }
    <% } %>
  </script>

  <!-- ── Mobile bottom navigation ──────────────────────────────────────────── -->
  <nav class="app-bottom-nav">
    <a href="/dashboard" class="app-bottom-nav-item">
      <span class="abn-icon">🏠</span>
      <span class="abn-label">Hem</span>
    </a>
    <a href="/learn" class="app-bottom-nav-item active">
      <span class="abn-icon">📚</span>
      <span class="abn-label">Utbildning</span>
    </a>
    <a href="/ordbok" class="app-bottom-nav-item">
      <span class="abn-icon">📖</span>
      <span class="abn-label">Ordbok</span>
    </a>
    <% if (role === 'free') { %>
      <a href="/upgrade" class="app-bottom-nav-item abn-upgrade">
        <span class="abn-icon">⭐</span>
        <span class="abn-label">Premium</span>
