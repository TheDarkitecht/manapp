<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= block.title %> — Joakim Jaksen Säljutbildning</title>
  <meta name="description" content="<%= block.subtitle %> — Joakim Jaksens säljutbildning med teori, video och prov." />
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/journey.css" />
  <link rel="stylesheet" href="/recommendations.css" />
  <link rel="stylesheet" href="/gamification.css" />
</head>
<body class="block-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <!-- Reading progress bar (decorative — hidden from screen readers) -->
  <div id="readProgress" aria-hidden="true" style="position:fixed;top:0;left:0;height:3px;width:0;background:linear-gradient(90deg,#6366f1,#8b5cf6);z-index:1000;pointer-events:none;"></div>

  <% if (isTeaser) { %>
  <div class="teaser-top-bar">
    <span>⭐ Du ser en förhandsvisning — <strong><%= block.title %></strong> kräver Premium</span>
    <a href="/upgrade" class="teaser-top-btn">Uppgradera — 199 kr/mån →</a>
  </div>
  <% } %>

  <nav class="learn-nav">
    <a href="/learn" class="learn-nav-back">← Alla block</a>
    <span class="learn-nav-title"><%= block.title %></span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <!-- Block hero -->
  <div class="block-hero" style="background: <%= block.gradient %>;">
    <div class="block-hero-icon"><%= block.icon %></div>
    <div>
      <h1><%= block.title %></h1>
      <p><%= block.subtitle %></p>
      <% if (block.outcomeTitle) { %>
        <p class="block-hero-outcome">
          <span class="bho-eyebrow">Efter detta block</span>
          <span class="bho-text"><%= block.outcomeTitle %></span>
        </p>
      <% } %>
      <% if (!isTeaser) { %>
        <span class="block-read-time">
          📖 ~<%= readTime %> min läsning
          <% if (block.youtubeId) { %> · 🎬 ~10 min video<% } %>
          <% if (block.roleplays && block.roleplays.length) { %> · 🎭 ~<%= Math.max(3, block.roleplays.length * 3) %> min övning<% } %>
        </span>
      <% } %>
    </div>
    <% if (isTeaser) { %>
      <div class="block-hero-lock-badge">🔒 Premium</div>
    <% } else if (journey && journey.fullyMastered) { %>
      <div class="block-hero-done-badge">🏆 Bemästrad</div>
    <% } else if (blockProg && blockProg.completed) { %>
      <div class="block-hero-done-badge">✓ Prov klart</div>
    <% } %>
  </div>

  <!-- ════════════ FRÅGA JOCKE — floating button + overlay ════════════ -->
  <% if (!isTeaser && (role === 'premium' || role === 'admin')) { %>
  <button class="ask-jocke-fab" type="button" onclick="openAskJocke()" aria-label="Fråga Jocke om detta block">
    <span>💬</span>
    <span class="ajf-label">Fråga Jocke</span>
  </button>

  <div class="ask-jocke-overlay" id="askJockeOverlay" role="dialog" aria-labelledby="ajTitle" aria-modal="true" hidden>
    <div class="ask-jocke-panel">
      <header class="aj-header">
        <div>
          <div class="aj-eyebrow">💬 Jocke om</div>
          <h2 id="ajTitle"><%= block.title %></h2>
        </div>
        <button type="button" class="aj-close" onclick="closeAskJocke()" aria-label="Stäng">✕</button>
      </header>
      <div class="aj-chat" id="ajChat">
        <div class="aj-msg aj-msg-jocke">
          <strong>Jocke:</strong>
          <p>Du är i blocket "<%= block.title %>". Fråga mig vad som helst — exempel, förtydliganden, tillämpning i ditt fall. Jag har teorin framför mig.</p>
        </div>
      </div>
      <form id="ajForm" class="aj-form" autocomplete="off">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <textarea id="ajInput" placeholder="T.ex. 'Ge mig 3 exempel på förvirrad ton i B2B-samtal'" rows="2" maxlength="1200" required></textarea>
        <button type="submit" class="aj-send">Skicka</button>
      </form>
      <div class="aj-quick">
        <button type="button" onclick="ajQuick('Ge 3 konkreta exempel på den viktigaste tekniken i detta block')">🎯 Ge exempel</button>
        <button type="button" onclick="ajQuick('Sammanfatta detta block i 3 bullets')">📝 Sammanfatta</button>
        <button type="button" onclick="ajQuick('Hur tillämpar jag detta i mitt nästa kundsamtal?')">🚀 Tillämpning</button>
      </div>
    </div>
  </div>

  <script>
    (function(){
      const overlay = document.getElementById('askJockeOverlay');
      const chat    = document.getElementById('ajChat');
      const form    = document.getElementById('ajForm');
      const input   = document.getElementById('ajInput');
      const csrf    = <%- JSON.stringify(csrfToken) %>;
      const blockId = <%- JSON.stringify(block.id) %>;
      const messages = [];
      let sending = false;

      window.openAskJocke = () => {
        overlay.hidden = false;
        document.body.style.overflow = 'hidden';
        setTimeout(() => input.focus(), 80);
      };
      window.closeAskJocke = () => {
        overlay.hidden = true;
        document.body.style.overflow = '';
      };
      overlay.addEventListener('click', e => { if (e.target === overlay) closeAskJocke(); });
      document.addEventListener('keydown', e => { if (e.key === 'Escape' && !overlay.hidden) closeAskJocke(); });

      function escapeHtml(s){ return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

      function render(role, text) {
        const div = document.createElement('div');
        div.className = 'aj-msg aj-msg-' + (role === 'user' ? 'you' : 'jocke');
        const strong = document.createElement('strong');
        strong.textContent = role === 'user' ? 'Du:' : 'Jocke:';
        const p = document.createElement('p');
        p.innerHTML = escapeHtml(text).replace(/\n/g, '<br>');
        div.appendChild(strong); div.appendChild(p);
        chat.appendChild(div);
        chat.scrollTop = chat.scrollHeight;
      }

      function renderTyping() {
        const div = document.createElement('div');
        div.id = 'ajTyping';
        div.className = 'aj-msg aj-msg-jocke rp-typing';
        div.innerHTML = '<strong>Jocke:</strong><p><span></span><span></span><span></span></p>';
        chat.appendChild(div);
        chat.scrollTop = chat.scrollHeight;
      }
      function removeTyping() { const t = document.getElementById('ajTyping'); if (t) t.remove(); }

      async function send(text) {
        if (sending || !text || !text.trim()) return;
        sending = true;
        const clean = text.trim();
        messages.push({ role: 'user', content: clean });
        render('user', clean);
        input.value = '';
        renderTyping();
        try {
          const res = await fetch('/chat/block', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
            body: JSON.stringify({ blockId, messages })
          });
          removeTyping();
          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            render('assistant', '⚠️ ' + (err.error || 'Fel uppstod.'));
            return;
          }
          const data = await res.json();
          const reply = data.reply || 'Inget svar.';
          messages.push({ role: 'assistant', content: reply });
          render('assistant', reply);
        } catch (e) {
          removeTyping();
          render('assistant', '⚠️ Kunde inte nå servern.');
        } finally {
          sending = false;
        }
      }

      window.ajQuick = (text) => send(text);

      form.addEventListener('submit', e => { e.preventDefault(); send(input.value); });
      input.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); form.requestSubmit(); }
      });
    })();
  </script>
  <% } %>

  <main id="main-content">

  <!-- Milstolpe-celebration: visas när free-user klarat quiz på sista gratis-blocket -->
  <% if (typeof justUnlockedFreeTier !== 'undefined' && justUnlockedFreeTier) { %>
    <div role="status" style="margin:1rem 1.25rem;padding:1.75rem;background:linear-gradient(145deg, rgba(251,191,36,0.15), rgba(245,158,11,0.06));border:2px solid rgba(251,191,36,0.5);border-radius:16px;position:relative;overflow:hidden;">
      <div style="position:absolute;top:-20px;right:-20px;width:140px;height:140px;background:radial-gradient(circle,rgba(139,92,246,0.2),transparent 70%);border-radius:50%;pointer-events:none;"></div>
      <div style="position:relative;z-index:1;">
        <div style="font-size:2.5rem;margin-bottom:0.25rem;">🎉</div>
        <h2 style="color:#f1f5f9;font-size:1.4rem;margin:0 0 0.5rem;">Grymt, <%= username %> — du klarade gratis-tiern!</h2>
        <p style="color:#cbd5e1;font-size:0.98rem;line-height:1.5;margin:0 0 1.25rem;max-width:580px;">
          Du har visat att du tar det här på allvar. Nästa block (<strong>Block 3: Tonfall</strong>) är där invändningshanteringen startar — och resten av resan är 18 block lång.
        </p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
          <form method="POST" action="/upgrade/checkout" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="tier" value="premium" />
            <button type="submit" style="padding:0.85rem 1.5rem;background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#0f172a;border:none;border-radius:10px;font-weight:800;font-size:1rem;cursor:pointer;box-shadow:0 4px 12px rgba(251,191,36,0.35);">
              🔓 Fortsätt med Premium — 199 kr/mån →
            </button>
          </form>
          <a href="/priser" style="color:#a5b4fc;font-size:0.88rem;text-decoration:none;padding:0.85rem 1rem;">
            Se alla priser →
          </a>
        </div>
        <p style="color:#64748b;font-size:0.78rem;margin:1rem 0 0;">Ingen bindningstid. Säg upp när du vill.</p>
      </div>
    </div>
  <% } %>

  <!-- Välkomst-banner: visas första gången efter registrering -->
  <% if (typeof welcome !== 'undefined' && welcome) { %>
    <div role="status" style="margin:1rem 1.25rem;padding:1.25rem 1.5rem;background:linear-gradient(145deg, rgba(99,102,241,0.12), rgba(139,92,246,0.06));border:1px solid rgba(99,102,241,0.3);border-radius:14px;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
      <div style="font-size:2rem;flex-shrink:0;">🎯</div>
      <div style="flex:1;min-width:200px;">
        <div style="color:#f1f5f9;font-weight:800;font-size:1.05rem;margin-bottom:0.25rem;">Välkommen <%= username %> — du är inloggad!</div>
        <div style="color:#cbd5e1;font-size:0.9rem;">Du är i <strong>Block 1 av 20</strong>. Läs teorin, gör provet, och bygg vidare. Gratis-block är 1 och 2 — resten låses upp med Premium.</div>
      </div>
      <button type="button" onclick="this.parentElement.style.display='none'" aria-label="Dölj" style="background:none;border:none;color:#94a3b8;font-size:1.25rem;cursor:pointer;padding:0.25rem 0.5rem;">✕</button>
    </div>
  <% } %>

  <!-- Subtil coach-hint — visas bara om systemet har något relevant att säga -->
  <% if (!isTeaser && typeof coachHint !== 'undefined' && coachHint) { %>
    <div class="coach-hint coach-hint-<%= coachHint.tone %>" role="status">
      <span class="ch-icon"><%= coachHint.icon %></span>
      <span class="ch-msg"><%= coachHint.message %></span>
      <button class="ch-dismiss" type="button" onclick="this.parentElement.style.display='none'" aria-label="Dölj">✕</button>
    </div>
  <% } %>

  <!-- ════════════ KOMPAKT 4-STEGS-PROGRESS-STRIP ═══════════════════════════
       Tunn statusrad — visar var i blocket användaren är (1✓ Läs · 2 Öva · 3 Gör · 4 Reflektera).
       Inte huvudnavigation; bara orientering. Klickbar till respektive route.
  ═══════════════════════════════════════════════════════════════════════════ -->
  <% if (!isTeaser && journey) { %>
  <nav class="block-progress-strip" aria-label="Din 4-stegs-resa">
    <a href="/learn/<%= block.id %>/prov" class="bps-step <%= journey.theoryDone ? 'bps-done' : 'bps-current' %>" title="Steg 1: Läs teorin + ta provet">
      <span class="bps-icon"><% if (journey.theoryDone) { %>✓<% } else { %>📖<% } %></span>
      <span class="bps-label">Läs</span>
    </a>
    <span class="bps-connector <%= journey.theoryDone ? 'bps-done' : '' %>" aria-hidden="true"></span>
    <a href="<%= block.roleplays && block.roleplays.length ? '/learn/' + block.id + '/ova' : '#' %>"
       class="bps-step <%= journey.roleplayDone ? 'bps-done' : (journey.theoryDone ? 'bps-current' : 'bps-future') %>"
       <% if (!block.roleplays || !block.roleplays.length) { %>aria-disabled="true" tabindex="-1"<% } %>
       title="Steg 2: Öva med Jocke">
      <span class="bps-icon"><% if (journey.roleplayDone) { %>✓<% } else { %>🎭<% } %></span>
      <span class="bps-label">Öva</span>
    </a>
    <span class="bps-connector <%= journey.roleplayDone ? 'bps-done' : '' %>" aria-hidden="true"></span>
    <a href="<%= block.mission ? '/learn/' + block.id + '/uppdrag' : '#' %>"
       class="bps-step <%= journey.missionDone ? 'bps-done' : (journey.roleplayDone ? 'bps-current' : 'bps-future') %>"
       <% if (!block.mission) { %>aria-disabled="true" tabindex="-1"<% } %>
       title="Steg 3: Veckans uppdrag IRL">
      <span class="bps-icon"><% if (journey.missionDone) { %>✓<% } else { %>🎯<% } %></span>
      <span class="bps-label">Gör</span>
    </a>
    <span class="bps-connector <%= journey.missionDone ? 'bps-done' : '' %>" aria-hidden="true"></span>
    <a href="<%= block.reflections && block.reflections.length ? '/learn/' + block.id + '/reflektion' : '#' %>"
       class="bps-step <%= journey.reflectionDone ? 'bps-done' : (journey.missionDone ? 'bps-current' : 'bps-future') %>"
       <% if (!block.reflections || !block.reflections.length) { %>aria-disabled="true" tabindex="-1"<% } %>
       title="Steg 4: Reflektera">
      <span class="bps-icon"><% if (journey.reflectionDone) { %>✓<% } else { %>💭<% } %></span>
      <span class="bps-label">Reflektera</span>
    </a>
  </nav>
  <% } %>

  <!-- ═════════════════════════════════════════════════════════════════════
       LINJÄR LEKTIONS-FLOW
       Outcome → Video → Action → Teori → Bottom-CTA
       Tabs ersatta av en sammanhållen scrollyta. Quiz på egen route.
  ═════════════════════════════════════════════════════════════════════ -->

  <% if (isTeaser) { %>

    <!-- ── TEASER MODE — theory preview + paywall ──────────────────── -->
    <div class="lesson-wrap">
      <section class="lesson-section lesson-theory">
        <div class="theory-body teaser-preview">
          <%- block.teaser %>
        </div>
        <div class="teaser-fade"></div>
        <div class="teaser-lock-wall">
          <div class="teaser-lock-inner">
            <div class="teaser-lock-icon"><%= block.icon %></div>
            <h3>Lås upp <%= block.title %></h3>
            <p>Du ser bara förhandsgranskningen. Hela blocket — komplett teori, videogenomgång och 10-frågors-prov — ingår i Premium.</p>
            <div class="teaser-checklist">
              <div class="teaser-check">📖 Komplett teori</div>
              <div class="teaser-check">🎬 Videogenomgång</div>
              <div class="teaser-check">🧠 10-frågorsprov</div>
              <div class="teaser-check">🤖 Jocke — din AI-säljcoach</div>
            </div>
            <a href="/upgrade" class="teaser-upgrade-cta">⭐ Uppgradera till Premium — 199 kr/mån →</a>
            <p class="teaser-price-hint">Avsluta när som helst. Säker betalning via Stripe.</p>
          </div>
        </div>
      </section>
    </div>

  <% } else { %>

    <div class="lesson-wrap">

      <!-- ─── A. AUDIO-PLAYER — Joakims röst läser upp blocket (om uppladdat) ─── -->
      <% if (typeof blockAudio !== 'undefined' && blockAudio) { %>
      <section class="lesson-section lesson-audio" aria-labelledby="lesson-audio-h">
        <div class="audio-card">
          <div class="audio-card-header">
            <span class="audio-card-eyebrow">🎙️ Lyssna istället</span>
            <span class="audio-card-tip">Joakim läser upp hela blocket — perfekt på pendel/promenad.</span>
          </div>
          <audio
            id="blockAudio"
            controls
            preload="metadata"
            src="<%= blockAudio.url %>"
            data-block-id="<%= block.id %>"
            data-audio-version="<%= blockAudio.version %>"
            style="width:100%;"
          ></audio>
          <div class="audio-card-controls">
            <span class="audio-speed-label">Hastighet:</span>
            <button type="button" class="audio-speed-btn" data-speed="1" aria-pressed="true">1×</button>
            <button type="button" class="audio-speed-btn" data-speed="1.25">1,25×</button>
            <button type="button" class="audio-speed-btn" data-speed="1.5">1,5×</button>
            <button type="button" class="audio-speed-btn" data-speed="2">2×</button>
          </div>
        </div>
        <script>
          (function(){
            const audio = document.getElementById('blockAudio');
            if (!audio) return;
            const blockId = audio.dataset.blockId;
            const version = audio.dataset.audioVersion;
            const POS_KEY = 'audio-pos:' + blockId + ':v' + version;
            const SPEED_KEY = 'audio-speed';

            // Återställ senast lyssnade position så user kan fortsätta
            try {
              const saved = parseFloat(localStorage.getItem(POS_KEY));
              if (Number.isFinite(saved) && saved > 5) {
                audio.addEventListener('loadedmetadata', () => {
                  // Bara om saved är inom rimligt range (<= duration - 5s)
                  if (audio.duration && saved < audio.duration - 5) {
                    audio.currentTime = saved;
                  }
                }, { once: true });
              }
            } catch(_){}

            // Återställ hastighet (delas mellan block — om man gillar 1.5x är det globalt)
            try {
              const savedSpeed = parseFloat(localStorage.getItem(SPEED_KEY));
              if (Number.isFinite(savedSpeed) && savedSpeed >= 0.5 && savedSpeed <= 3) {
                audio.playbackRate = savedSpeed;
                applySpeedActive(savedSpeed);
              }
            } catch(_){}

            // Spara position löpande — debouncat så vi inte spammar localStorage
            let posSaveTimer = null;
            audio.addEventListener('timeupdate', () => {
              clearTimeout(posSaveTimer);
              posSaveTimer = setTimeout(() => {
                try { localStorage.setItem(POS_KEY, String(audio.currentTime)); } catch(_){}
              }, 1500);
            });
            audio.addEventListener('ended', () => {
              try { localStorage.removeItem(POS_KEY); } catch(_){}
            });

            // Hastighet-knappar
            function applySpeedActive(speed) {
              document.querySelectorAll('.audio-speed-btn').forEach(b => {
                const s = parseFloat(b.dataset.speed);
                const active = Math.abs(s - speed) < 0.01;
                b.setAttribute('aria-pressed', String(active));
                b.classList.toggle('active', active);
              });
            }
            document.querySelectorAll('.audio-speed-btn').forEach(btn => {
              btn.addEventListener('click', () => {
                const speed = parseFloat(btn.dataset.speed);
                audio.playbackRate = speed;
                applySpeedActive(speed);
                try { localStorage.setItem(SPEED_KEY, String(speed)); } catch(_){}
              });
            });
          })();
        </script>
      </section>
      <% } %>

      <!-- ─── 0. OUTCOME-CARD — vad du kommer kunna efter blocket ────── -->
      <% if (block.tldr || (block.concreteScripts && block.concreteScripts.length)) { %>
      <section class="lesson-section lesson-outcome" aria-labelledby="lesson-outcome-h">
        <div class="outcome-card">
          <div class="outcome-card-eyebrow">🎯 Det här ska sitta efter blocket</div>
          <% if (block.tldr) { %>
            <p class="outcome-card-tldr"><%= block.tldr %></p>
          <% } %>
          <% if (block.concreteScripts && block.concreteScripts.length) { %>
            <div class="outcome-card-scripts">
              <h3 id="lesson-outcome-h" class="outcome-card-scripts-title">Konkret — formuleringar du kommer kunna säga:</h3>
              <ul>
                <% block.concreteScripts.forEach(function(s) { %>
                  <li><%= s %></li>
                <% }); %>
              </ul>
            </div>
          <% } %>
        </div>
      </section>
      <% } %>

      <!-- ─── 1. VIDEO — primär leverans ─────────────────────────────── -->
      <section class="lesson-section lesson-video" aria-labelledby="lesson-video-h">
        <h2 id="lesson-video-h" class="lesson-section-eyebrow">🎬 Videogenomgång</h2>
        <% if (block.youtubeId) { %>
          <div class="video-embed">
            <iframe
              src="https://www.youtube.com/embed/<%= block.youtubeId %>?rel=0&modestbranding=1"
              title="<%= block.title %>"
              frameborder="0"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        <% } else { %>
          <!-- Subtil placeholder, INTE stor tom 16:9 — undvik halvfärdig-känsla -->
          <div class="video-pending-card">
            <span class="vpc-icon" aria-hidden="true">🎬</span>
            <div class="vpc-body">
              <strong>Videogenomgång kommer snart.</strong>
              <span>Layouten är förberedd — spelaren landar här när Joakim laddar upp inspelningen. Under tiden: läs teorin nedan och hoppa in i övningen.</span>
            </div>
          </div>
        <% } %>
      </section>

      <!-- ─── 2. ACTION-CARD — driv från konsumtion till handling ────── -->
      <% if (block.roleplays && block.roleplays.length) { %>
        <section class="lesson-section lesson-action">
          <div class="action-card">
            <div class="action-card-eyebrow">⚡ Gör detta nu</div>
            <h3 class="action-card-title">Träna det du precis sett — med Jocke</h3>
            <p class="action-card-desc">
              <%= block.roleplays.length %> rollspel där du tränar teknikerna i tryggt läge. Jocke spelar kunden. <strong>3 minuter</strong> kan flytta nålen mer än en hel teorisida till.
            </p>
            <a href="/learn/<%= block.id %>/ova" class="action-card-cta">🎭 Starta rollspel →</a>
          </div>
        </section>
      <% } %>

      <!-- ─── 3. TEORI — studiematerial under videon ─────────────────── -->
      <section class="lesson-section lesson-theory" aria-labelledby="lesson-theory-h">
        <h2 id="lesson-theory-h" class="lesson-section-eyebrow">📖 Studiematerial — fördjupa det videon visar</h2>
        <div class="theory-body">
          <%- block.theory %>
        </div>
      </section>

      <!-- ─── 4. BOTTOM-CTA — server-beräknat nästa-steg ─────────────── -->
      <% if (typeof nextBestStep !== 'undefined' && nextBestStep) { %>
      <section class="lesson-section lesson-next" aria-label="Nästa steg">
        <div class="next-step-card">
          <div class="nsc-eyebrow">Nästa steg</div>
          <div class="nsc-icon" aria-hidden="true"><%= nextBestStep.icon %></div>
          <h3 class="nsc-title"><%= nextBestStep.label %></h3>
          <p class="nsc-desc"><%= nextBestStep.desc %></p>
          <a href="<%= nextBestStep.href %>" class="nsc-cta"><%= nextBestStep.label %> →</a>
        </div>
      </section>
      <% } %>

    </div>

  <% } %>

  <!-- Block navigation -->
  </main>
  <div class="block-nav-footer">
    <% const idx = blocks.findIndex(b => b.id === block.id); %>
    <% if (idx > 0) { %>
      <a href="/learn/<%= blocks[idx-1].id %>" class="block-nav-btn" title="Föregående block (←)">← <%= blocks[idx-1].title %></a>
    <% } else { %>
      <span></span>
    <% } %>
    <a href="/learn" class="block-nav-btn outline">Alla block</a>
    <% if (idx < blocks.length - 1) { %>
      <a href="/learn/<%= blocks[idx+1].id %>" class="block-nav-btn" title="Nästa block (→)"><%= blocks[idx+1].title %> →</a>
    <% } else { %>
      <span></span>
    <% } %>
  </div>

  <% if (!isTeaser) { %>
  <!-- ── Jocke chat bubble (premium users only) ──────────────────────────── -->
  <button class="chat-bubble" id="chatBubble" onclick="toggleChat()" title="Fråga Jocke om <%= block.title %>" aria-label="Öppna chatt med Jocke" aria-expanded="false">
    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="white" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/>
    </svg>
  </button>

  <div class="chat-window" id="chatWindow" role="dialog" aria-label="Chatt med Jocke" aria-modal="true" aria-hidden="true">
    <div class="chat-header">
      <div class="chat-header-info">
        <div class="chat-avatar">J</div>
        <div>
          <strong>Jocke</strong>
          <span class="chat-status">● Online</span>
        </div>
      </div>
      <button class="chat-close" onclick="toggleChat()" aria-label="Stäng chatt">✕</button>
    </div>
    <div class="chat-messages" id="chatMessages">
      <div class="chat-msg assistant">
        <p>Du läser <strong><%= block.title %></strong>. Ställ en fråga, träna ett scenario eller be om ett konkret råd. 🎯</p>
      </div>
    </div>
    <div class="chat-input-area">
      <textarea id="chatInput" placeholder="Skriv ett meddelande..." rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
      <button onclick="sendMessage()" aria-label="Skicka meddelande">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="white" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M2 21l21-9L2 3v7l15 2-15 2z"/>
        </svg>
      </button>
    </div>
  </div>
  <% } %>

  <script>
    // ── Motion preference helper ────────────────────────────────────────────────
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Smooth-scroll wrapper that respects prefers-reduced-motion
    function safeScrollIntoView(el, opts) {
      el.scrollIntoView({ ...opts, behavior: prefersReducedMotion ? 'auto' : (opts.behavior || 'smooth') });
    }

    // ── Reading progress bar ────────────────────────────────────────────────────

    (function() {
      const bar = document.getElementById('readProgress');
      // Only apply transition when user accepts motion
      if (!prefersReducedMotion) {
        bar.style.transition = 'width 0.1s linear';
      }
      window.addEventListener('scroll', function() {
        const scrolled = window.scrollY;
        const total = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
      }, { passive: true });
    })();

    // ── Keyboard navigation ─────────────────────────────────────────────────────
    // Left/Right arrow → prev/next block (when not in an input/textarea)
    document.addEventListener('keydown', function(e) {
      const tag = document.activeElement.tagName;
      const inInput = tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
      if (inInput) return;

      <% const kbIdx = blocks.findIndex(b => b.id === block.id); %>
      if (e.key === 'ArrowLeft') {
        <% if (kbIdx > 0) { %>
          window.location.href = '/learn/<%= blocks[kbIdx - 1].id %>';
        <% } %>
      } else if (e.key === 'ArrowRight') {
        <% if (kbIdx < blocks.length - 1) { %>
          window.location.href = '/learn/<%= blocks[kbIdx + 1].id %>';
        <% } %>
      } else if (e.key === 'Escape') {
        // Close chat if open
        const chatWindow = document.getElementById('chatWindow');
        if (chatWindow && chatWindow.classList.contains('open')) {
          toggleChat();
        }
      }
    });

    // ── Legacy anchor-redirect ──────────────────────────────────────────────
    // Gamla URL:er / länkar med #tab-quiz, #tab-video, #tab-theory ska inte 404:a.
    // #tab-quiz → ny prov-route. #tab-theory → scrolla till teori-sektionen.
    // #tab-video → scrolla till video-sektionen.
    (function() {
      const h = window.location.hash;
      if (!h) return;
      if (h === '#tab-quiz') {
        window.location.replace('/learn/<%= block.id %>/prov');
        return;
      }
      const target = h === '#tab-theory' ? document.getElementById('lesson-theory-h')
                   : h === '#tab-video'  ? document.getElementById('lesson-video-h')
                   : null;
      if (target) {
        // Stripa hash så bookmarken är ren, scrolla mjukt till sektionen
        history.replaceState(null, '', window.location.pathname);
        target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' });
      }
    })();

    // (Quiz bor på /learn/:id/prov — egen sida nu. Ingen inline-quiz-JS här.)

    // ── Jocke chat (premium users only) ─────────────────────────────────────
    <% if (!isTeaser) { %>
    let chatOpen = false;
    // Seed context so Jocke knows which block the user is on
    let messages = [
      { role: 'user', content: 'Jag läser just nu Block <%= blocks.findIndex(b => b.id === block.id) + 1 %>: <%= block.title %>.' },
      { role: 'assistant', content: 'Förstår! Du jobbar med <%= block.title %>. Ställ dina frågor eller berätta vilken situation du vill träna.' },
    ];

    function toggleChat() {
      chatOpen = !chatOpen;
      const win = document.getElementById('chatWindow');
      win.classList.toggle('open', chatOpen);
      // aria-hidden="true" when closed prevents browsers from treating this
      // as an open modal dialog and making the rest of the page inert.
      win.setAttribute('aria-hidden', chatOpen ? 'false' : 'true');
      document.getElementById('chatBubble').setAttribute('aria-expanded', chatOpen ? 'true' : 'false');
      if (chatOpen) {
        document.getElementById('chatInput').focus();
      } else {
        // Return focus to the bubble when chat is closed
        document.getElementById('chatBubble').focus();
      }
    }

    function handleKey(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    }

    async function sendMessage() {
      const input = document.getElementById('chatInput');
      const text = input.value.trim();
      if (!text) return;
      appendMessage('user', text);
      input.value = '';
      input.style.height = 'auto'; // reset height after clearing
      messages.push({ role: 'user', content: text });
      const typingId = showTyping();
      try {
        const res = await fetch('/chat', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-csrf-token': '<%= csrfToken %>',
          },
          body: JSON.stringify({ messages }),
        });
        const data = await res.json();
        removeTyping(typingId);
        if (!res.ok || data.error) {
          // Show error in UI but don't push it into message history
          appendMessage('assistant', data.error || 'Något gick fel. Försök igen.');
          return;
        }
        const reply = data.reply || 'Inget svar mottogs.';
        appendMessage('assistant', reply);
        messages.push({ role: 'assistant', content: reply });
      } catch (err) {
        removeTyping(typingId);
        appendMessage('assistant', 'Kunde inte nå Jocke just nu. Försök igen.');
      }
    }

    function appendMessage(role, text) {
      const box = document.getElementById('chatMessages');
      const div = document.createElement('div');
      div.className = `chat-msg ${role}`;
      div.innerHTML = `<p>${renderMarkdown(text)}</p>`;
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
    }

    function showTyping() {
      const box = document.getElementById('chatMessages');
      const div = document.createElement('div');
      div.className = 'chat-msg assistant typing-indicator';
      div.id = 'typing-' + Date.now();
      div.innerHTML = '<p><span></span><span></span><span></span></p>';
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
      return div.id;
    }

    function removeTyping(id) {
      const el = document.getElementById(id);
      if (el) el.remove();
    }

    function escapeHtml(text) {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }
    function renderMarkdown(raw) {
      let s = escapeHtml(raw);
      s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      s = s.replace(/(?<!\*)\*([^*\n]+?)\*(?!\*)/g, '<em>$1</em>');
      s = s.replace(/^[•\-] (.+)/gm, '<li>$1</li>');
      s = s.replace(/(<li>.*<\/li>)/gs, '<ul>$1</ul>');
      s = s.replace(/\n(?!<\/?(?:ul|li))/g, '<br>');
      s = s.replace(/<br>\s*(<ul>)/g, '$1');
      return s;
    }

    function autoResize(ta) {
      ta.style.height = 'auto';
      ta.style.height = Math.min(ta.scrollHeight, 120) + 'px';
    }
    <% } %>
  </script>

  <!-- ── Mobile bottom navigation ──────────────────────────────────────────── -->
  <nav class="app-bottom-nav">
    <a href="/dashboard" class="app-bottom-nav-item">
      <span class="abn-icon">🏠</span>
      <span class="abn-label">Hem</span>
    </a>
    <a href="/learn" class="app-bottom-nav-item active">
      <span class="abn-icon">📚</span>
      <span class="abn-label">Utbildning</span>
    </a>
    <a href="/ordbok" class="app-bottom-nav-item">
      <span class="abn-icon">📖</span>
      <span class="abn-label">Ordbok</span>
    </a>
    <% if (role === 'free') { %>
      <a href="/upgrade" class="app-bottom-nav-item abn-upgrade">
        <span class="abn-icon">⭐</span>
        <span class="abn-label">Premium</span>
      </a>
    <% } else { %>
      <a href="/logout" class="app-bottom-nav-item">
        <span class="abn-icon">🚪</span>
        <span class="abn-label">Logga ut</span>
      </a>
    <% } %>
  </nav>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
