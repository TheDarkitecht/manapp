<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>⚡ Snabbversion: <%= block.title %> — Joakim Jaksen</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/journey.css" />
</head>
<body class="block-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/learn/<%= block.id %>" class="learn-nav-back">← Tillbaka till blocket</a>
    <span class="learn-nav-title">⚡ Snabbversion</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="snabb-wrap">

    <div class="snabb-hero" style="background: <%= block.gradient %>;">
      <div class="snabb-icon"><%= block.icon %></div>
      <div>
        <div class="snabb-eyebrow">Block <%= block.title %> — Snabbversion (2 min)</div>
        <h1><%= block.subtitle %></h1>
      </div>
    </div>

    <% if (block.quickVersion) { %>
      <div class="snabb-card">
        <h2>🧠 Essensen</h2>
        <ul class="snabb-essence">
          <% block.quickVersion.essence.forEach(function(e) { %>
            <li><%= e %></li>
          <% }); %>
        </ul>
      </div>

      <div class="snabb-card snabb-card-accent">
        <h2>🔑 Nyckeltekniken</h2>
        <p><%= block.quickVersion.keyTechnique %></p>
      </div>

      <div class="snabb-card snabb-card-action">
        <h2>⚡ Gör det här inom 24h</h2>
        <p><%= block.quickVersion.microAction %></p>
      </div>
    <% } else { %>
      <div class="snabb-card">
        <p>Snabbversion för detta block kommer snart. Gå till teorin under tiden.</p>
      </div>
    <% } %>

    <div class="snabb-cta-row">
      <a href="/learn/<%= block.id %>" class="jc-btn jc-btn-ghost">← Tillbaka</a>
      <% if (block.roleplays && block.roleplays.length && !journey.roleplayDone) { %>
        <a href="/learn/<%= block.id %>/ova" class="jc-btn">🎭 Redo att träna? Öva med Jocke →</a>
      <% } else if (block.mission && !journey.missionDone) { %>
        <a href="/learn/<%= block.id %>/uppdrag" class="jc-btn">🎯 Aktivera veckans uppdrag →</a>
      <% } else { %>
        <a href="/learn/<%= block.id %>" class="jc-btn">📖 Fortsätt med blocket →</a>
      <% } %>
    </div>

  </main>

  <!-- ── Mobile bottom navigation ─────────────────────────────────────────── -->
  <nav class="app-bottom-nav">
    <a href="/dashboard" class="app-bottom-nav-item">
      <span class="abn-icon">🏠</span>
      <span class="abn-label">Hem</span>
    </a>
    <a href="/learn" class="app-bottom-nav-item active">
      <span class="abn-icon">📚</span>
      <span class="abn-label">Utbildning</span>
    </a>
    <a href="/ordbok" class="app-bottom-nav-item">
      <span class="abn-icon">📖</span>
      <span class="abn-label">Ordbok</span>
    </a>
    <% if (role === 'free') { %>
      <a href="/upgrade" class="app-bottom-nav-item abn-upgrade">
        <span class="abn-icon">⭐</span>
        <span class="abn-label">Premium</span>
      </a>
    <% } else { %>
      <a href="/logout" class="app-bottom-nav-item">
        <span class="abn-icon">🚪</span>
        <span class="abn-label">Logga ut</span>
      </a>
    <% } %>
  </nav>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
