<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Säljare — Samtalsintelligens</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧑</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/call-analytics.css" />
</head>
<body class="learn-page ci-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/admin/calls" class="learn-nav-back">← Samtalsintelligens</a>
    <span class="learn-nav-title">🧑 Säljare</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="ci-wrap">

    <% if (!overview.length) { %>
      <div class="ci-empty">
        <p>Inga taggade säljare än. Lägg in säljare-namn vid uppladdning eller efteråt så fyller listan på sig.</p>
        <p><a href="/admin/calls/upload" class="ci-btn ci-btn-primary">⬆ Ladda upp samtal</a></p>
      </div>
    <% } else { %>
      <p class="ci-insights-meta">
        <strong><%= overview.length %></strong> säljare med taggade samtal. Klicka på en för att se full dashboard.
      </p>

      <div class="ci-table-wrap">
        <table class="ci-table">
          <thead>
            <tr>
              <th>Säljare</th>
              <th>Samtal</th>
              <th>Win-rate</th>
              <th>Sold</th>
              <th>Lost</th>
              <th>No-SMS</th>
              <th>Otaggade</th>
              <th>Minuter</th>
              <th>Senaste samtal</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% overview.forEach(function(s) { %>
              <tr>
                <td class="ci-td-name">
                  <a href="/admin/calls/salesperson/<%= encodeURIComponent(s.name) %>" style="color:#a5b4fc;text-decoration:none;font-weight:600;">
                    🧑 <%= s.name %>
                  </a>
                </td>
                <td class="ci-td-num"><%= s.total %></td>
                <td class="ci-td-num">
                  <% if (s.win_rate !== null) { %>
                    <strong style="color:<%= s.win_rate >= 50 ? '#6ee7b7' : (s.win_rate >= 25 ? '#fbbf24' : '#fca5a5') %>;">
                      <%= s.win_rate %>%
                    </strong>
                  <% } else { %>
                    <span style="color:#64748b;">—</span>
                  <% } %>
                </td>
                <td class="ci-td-num" style="color:#6ee7b7;"><%= s.sold %></td>
                <td class="ci-td-num" style="color:#fca5a5;"><%= s.lost %></td>
                <td class="ci-td-num" style="color:#fdba74;"><%= s.no_sms %></td>
                <td class="ci-td-num" style="color:#64748b;"><%= s.untagged %></td>
                <td class="ci-td-num"><%= s.total_minutes %></td>
                <td class="ci-td-date"><%= (s.last_call_at || '').slice(0, 16) %></td>
                <td>
                  <a class="ci-td-link" href="/admin/calls/salesperson/<%= encodeURIComponent(s.name) %>">Öppna →</a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <p class="ci-hint" style="margin-top:1rem;">
        <strong>Win-rate</strong> beräknas på taggade samtal (sold/(sold+lost+no_sms)). Otaggade exkluderas.
        Säljare med &lt; 5 taggade samtal har osäker statistik — vänta tills du har mer data.
      </p>
    <% } %>

  </main>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
