<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Case study — <%= job.title || job.original_name %></title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📤</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/call-analytics.css" />
</head>
<body class="learn-page ci-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/admin/calls/<%= job.id %>" class="learn-nav-back">← Till samtalet</a>
    <span class="learn-nav-title">📤 Case study</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="ci-wrap">

    <div class="ci-warn" style="margin-bottom:1rem;">
      <strong>⚠️ Granska anonymiseringen innan publicering.</strong>
      LLM:n har instruerats att maska namn, företag och personliga detaljer — men
      kontrollera alltid manuellt innan du klistrar in på hemsida eller LinkedIn.
    </div>

    <div class="ci-section">
      <header class="ci-section-header">
        <h2>📋 Case study (anonymiserad markdown)</h2>
        <div style="display:flex;gap:0.5rem;">
          <button type="button" class="ci-btn ci-btn-secondary" onclick="copyMarkdown()">📋 Kopiera markdown</button>
          <form method="POST" action="/admin/calls/<%= job.id %>/case-study" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="ci-btn ci-btn-ghost">↻ Generera om</button>
          </form>
        </div>
      </header>

      <div class="ci-case-study-grid">
        <div>
          <h3 class="ci-case-section-label">Förhandsvisning</h3>
          <article class="ci-analysis" id="renderedPreview"><%= markdown %></article>
        </div>
        <div>
          <h3 class="ci-case-section-label">Råmarkdown</h3>
          <textarea id="rawMarkdown" class="ci-case-raw" readonly><%= markdown %></textarea>
        </div>
      </div>
    </div>

  </main>

  <script>
    function copyMarkdown() {
      const ta = document.getElementById('rawMarkdown');
      navigator.clipboard.writeText(ta.value).then(() => {
        const btn = event.currentTarget;
        const orig = btn.textContent;
        btn.textContent = '✓ Kopierat';
        setTimeout(() => { btn.textContent = orig; }, 2000);
      });
    }

    // Client-side markdown-renderer (samma som detail.ejs)
    (function(){
      const el = document.getElementById('renderedPreview');
      if (!el) return;
      let html = el.textContent;
      html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
      html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
      html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
      html = html.replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>');
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
      html = html.replace(/^\- (.+)$/gm, '<li>$1</li>');
      html = html.replace(/(<li>[\s\S]*?<\/li>\n?)+/g, m => '<ul>' + m + '</ul>');
      html = html.split(/\n\n+/).map(p => {
        if (p.startsWith('<h') || p.startsWith('<ul') || p.startsWith('<li') || p.startsWith('<blockquote')) return p;
        return '<p>' + p.replace(/\n/g, '<br>') + '</p>';
      }).join('');
      el.innerHTML = html;
    })();
  </script>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
