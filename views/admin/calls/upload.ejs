<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bulk-uppladdning — Samtalsintelligens</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⬆</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/call-analytics.css" />
</head>
<body class="learn-page ci-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/admin/calls" class="learn-nav-back">← Samtalsintelligens</a>
    <span class="learn-nav-title">⬆ Bulk-uppladdning</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="ci-wrap">

    <div class="ci-card">
      <h1>Ladda upp samtal för analys</h1>
      <p class="ci-lead">
        Dra in upp till <strong>100 ljudfiler</strong>. Varje fil transkriberas med Whisper,
        analyseras av Jocke, och hamnar i historiken när den är klar.
        Worker processar en i taget för att undvika Groq rate-limits — räkna med ca 30–90 sek per samtal.
      </p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="ci-error">⚠️ <%= error %></div>
      <% } %>

      <% if (!r2Enabled) { %>
        <div class="ci-warn">
          <strong>⚠️ Lokal disk-läge:</strong> Filer sparas i <code>./uploads/calls/</code> eftersom R2-creds saknas.
          Bra för dev, men inte hållbart i produktion. Sätt <code>R2_ACCOUNT_ID</code>, <code>R2_ACCESS_KEY_ID</code>,
          <code>R2_SECRET_ACCESS_KEY</code> och <code>R2_BUCKET</code> i Railway-env.
        </div>
      <% } %>

      <form method="POST" action="/admin/calls/upload" enctype="multipart/form-data" id="bulkForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <!-- Metodik-val: vilken säljstil ska samtalen analyseras mot? -->
        <div class="ci-methodology-picker">
          <label for="methodology" class="ci-methodology-label">
            <strong>Vilken metodik analyseras detta mot?</strong>
            <span class="ci-methodology-help">Olika säljstilar har olika kriterier — välj den som matchar projektet. Du kan re-analysera senare mot en annan metodik.</span>
          </label>
          <select name="methodology" id="methodology" required class="ci-methodology-select">
            <% methodologies.forEach(function(m) { %>
              <option value="<%= m.id %>" <%= m.id === defaultMethodology ? 'selected' : '' %>>
                <%= m.name %>
              </option>
            <% }); %>
          </select>
          <p class="ci-methodology-desc" id="methodologyDesc"></p>

          <!-- Speaker diarization — opt-in per upload -->
          <label class="ci-speaker-toggle">
            <input type="checkbox" name="identifySpeakers" value="1" checked />
            <span>
              <strong>🎭 Identifiera talare (Säljare / Kund)</strong>
              <span class="ci-speaker-toggle-help">Gör transkriptet läsbart som dialog och ger AI:n bättre kontext. Lägger ~5 sek extra per samtal.</span>
            </span>
          </label>
        </div>

        <label class="ci-dropzone" id="dropZone">
          <input type="file" name="audio" id="fileInput" accept="audio/*" multiple required />
          <div class="ci-dz-icon">🎙️</div>
          <div class="ci-dz-label" id="dzLabel">Dra hit ljudfiler eller klicka för att välja</div>
          <div class="ci-dz-hint">mp3, m4a, wav, webm · upp till 100 filer · max 200 MB per fil</div>
        </label>

        <div id="fileList" class="ci-file-list" style="display:none;"></div>

        <div class="ci-submit-row">
          <button type="submit" id="submitBtn" class="ci-btn ci-btn-primary ci-btn-large" disabled>
            ⬆ Köa 0 samtal
          </button>
          <span class="ci-submit-hint">Du kan lämna sidan — workern processerar i bakgrunden.</span>
        </div>

        <div id="progress" style="display:none;margin-top:1.5rem;">
          <div class="ci-progress-bar"><div class="ci-progress-fill" id="progressFill"></div></div>
          <p class="ci-progress-text" id="progressText">Laddar upp…</p>
        </div>
      </form>
    </div>

  </main>

  <script>
    // Metodik-beskrivningar (synkade med services/prompts/feedback.js .description).
    // Viktigt: använd <%- %> (raw) för JSON-värdena — <%= %> HTML-escapar så
    // att " blir &quot; vilket bryter JS-syntax inuti <script>-taggen.
    const methodologyDescriptions = {
      <% methodologies.forEach(function(m, i) { %>
        <%- JSON.stringify(m.id) %>: <%- JSON.stringify(m.description) %><%- i < methodologies.length - 1 ? ',' : '' %>
      <% }); %>
    };

    // Window-level drag/drop-catch: hindrar browsern från att öppna
    // filen i ny flik om user släpper UTANFÖR dropzonen. Klassisk bugg —
    // utan detta tolkar Chrome en drop-outside som "visa filen" och
    // uppladdningen bryts tyst.
    ['dragover', 'drop'].forEach(ev => {
      window.addEventListener(ev, e => {
        // Tillåt events i själva dropzonen eller i file-inputen
        if (e.target.closest('#dropZone, #fileInput')) return;
        e.preventDefault();
      });
    });

    (function(){
      const methodologySelect = document.getElementById('methodology');
      const methodologyDesc = document.getElementById('methodologyDesc');
      function updateDesc() {
        const id = methodologySelect.value;
        methodologyDesc.textContent = methodologyDescriptions[id] || '';
      }
      methodologySelect.addEventListener('change', updateDesc);
      updateDesc();

      const input = document.getElementById('fileInput');
      const label = document.getElementById('dzLabel');
      const form = document.getElementById('bulkForm');
      const submitBtn = document.getElementById('submitBtn');
      const progress = document.getElementById('progress');
      const progressFill = document.getElementById('progressFill');
      const progressText = document.getElementById('progressText');
      const dropZone = document.getElementById('dropZone');
      const fileList = document.getElementById('fileList');

      function formatSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
      }

      function renderFileList() {
        const files = Array.from(input.files);
        if (!files.length) {
          fileList.style.display = 'none';
          label.textContent = 'Dra hit ljudfiler eller klicka för att välja';
          label.style.color = '';
          submitBtn.disabled = true;
          submitBtn.textContent = '⬆ Köa 0 samtal';
          return;
        }
        fileList.style.display = 'block';
        fileList.innerHTML = files.map((f, i) =>
          `<div class="ci-file-row"><span class="ci-file-name">${f.name}</span><span class="ci-file-size">${formatSize(f.size)}</span></div>`
        ).join('');
        const totalMB = files.reduce((s, f) => s + f.size, 0) / (1024 * 1024);
        label.textContent = `✓ ${files.length} filer valda (${totalMB.toFixed(1)} MB totalt)`;
        label.style.color = '#34d399';
        submitBtn.disabled = false;
        submitBtn.textContent = `⬆ Köa ${files.length} samtal`;
      }

      input.addEventListener('change', renderFileList);

      ['dragenter', 'dragover'].forEach(ev => {
        dropZone.addEventListener(ev, e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
      });
      ['dragleave', 'drop'].forEach(ev => {
        dropZone.addEventListener(ev, e => { e.preventDefault(); dropZone.classList.remove('drag-over'); });
      });
      dropZone.addEventListener('drop', e => {
        if (e.dataTransfer.files.length) {
          input.files = e.dataTransfer.files;
          renderFileList();
        }
      });

      form.addEventListener('submit', () => {
        submitBtn.disabled = true;
        submitBtn.textContent = '⏳ Laddar upp…';
        progress.style.display = 'block';
        progressText.textContent = `Laddar upp ${input.files.length} filer till servern…`;
        progressFill.style.width = '20%';
        // Vi kan inte mäta faktisk progress utan XHR — ge bara en visuell indikation.
        setTimeout(() => { progressFill.style.width = '60%'; progressText.textContent = 'Lagrar i objekt-storage…'; }, 2000);
        setTimeout(() => { progressFill.style.width = '90%'; progressText.textContent = 'Skapar jobb…'; }, 5000);
      });
    })();
  </script>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
