<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Insights — Samtalsintelligens</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📈</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/call-analytics.css" />
</head>
<body class="learn-page ci-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/admin/calls" class="learn-nav-back">← Samtalsintelligens</a>
    <span class="learn-nav-title">📈 Insights</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="ci-wrap">

    <!-- Filter -->
    <form method="GET" action="/admin/calls/insights" class="ci-insights-filters">
      <label class="ci-filter-field">
        <span>Säljare</span>
        <select name="salesperson">
          <option value="">Alla säljare</option>
          <% allSalespeople.forEach(function(s) { %>
            <option value="<%= s.name %>" <%= filters.salesperson === s.name ? 'selected' : '' %>>
              <%= s.name %> (<%= s.samtal %>)
            </option>
          <% }); %>
        </select>
      </label>
      <label class="ci-filter-field">
        <span>Metodik</span>
        <select name="methodology">
          <option value="">Alla metodiker</option>
          <% methodologies.forEach(function(m) { %>
            <option value="<%= m.id %>" <%= filters.methodology === m.id ? 'selected' : '' %>>
              <%= m.name %>
            </option>
          <% }); %>
        </select>
      </label>
      <label class="ci-filter-field">
        <span>Period</span>
        <select name="days">
          <option value="30"  <%= filters.days === 30  ? 'selected' : '' %>>Senaste 30 dagar</option>
          <option value="90"  <%= filters.days === 90  ? 'selected' : '' %>>Senaste 90 dagar</option>
          <option value="365" <%= filters.days === 365 ? 'selected' : '' %>>Senaste 12 månader</option>
        </select>
      </label>
      <button type="submit" class="ci-btn ci-btn-primary">Uppdatera</button>
    </form>

    <!-- Outcome-fördelning + win-rate -->
    <div class="ci-stats">
      <div class="ci-stat ci-stat-done">
        <span class="ci-stat-num"><%= stats.sold %></span>
        <span class="ci-stat-label">Sold</span>
      </div>
      <div class="ci-stat ci-stat-failed">
        <span class="ci-stat-num"><%= stats.lost %></span>
        <span class="ci-stat-label">Lost</span>
      </div>
      <div class="ci-stat">
        <span class="ci-stat-num" style="color:#fdba74;"><%= stats.no_sms %></span>
        <span class="ci-stat-label">No-SMS</span>
      </div>
      <div class="ci-stat">
        <span class="ci-stat-num"><%= stats.callback %></span>
        <span class="ci-stat-label">Callback</span>
      </div>
      <div class="ci-stat ci-stat-pending">
        <span class="ci-stat-num"><%= stats.untagged %></span>
        <span class="ci-stat-label">Otaggade</span>
      </div>
      <div class="ci-stat">
        <span class="ci-stat-num"><%= stats.win_rate !== null ? stats.win_rate + '%' : '—' %></span>
        <span class="ci-stat-label">Win-rate</span>
      </div>
    </div>

    <% if (phrases.insufficient) { %>
      <div class="ci-warn">
        <strong>För lite data för meningsfull jämförelse.</strong><br>
        Behöver minst 2 sold-samtal och 2 lost-samtal med detta filter.
        Just nu: <strong><%= phrases.soldCount %></strong> sold, <strong><%= phrases.lostCount %></strong> lost.
        Tagga fler samtal från detalj-sidan så fyller insights:en på sig.
      </div>
    <% } else { %>

      <p class="ci-insights-meta">
        Jämför ordanvändning i <strong><%= phrases.soldCount %></strong> sold-samtal mot
        <strong><%= phrases.lostCount %></strong> lost/no-sms-samtal.
        <strong>Lift</strong> = hur mycket oftare ordet förekommer i sold (1.0 = lika ofta, 2.0 = dubbelt så ofta).
      </p>

      <div class="ci-insights-grid">
        <!-- Winning phrases -->
        <section class="ci-section">
          <header class="ci-section-header">
            <h2>🏆 Winning words (oftare i sold)</h2>
          </header>
          <% if (!phrases.winning.length) { %>
            <p class="ci-empty">Inga ord uppfyller minimitrösken (3+ förekomster).</p>
          <% } else { %>
            <table class="ci-table ci-phrase-table">
              <thead>
                <tr><th>Ord</th><th>Lift</th><th>Sold/samtal</th><th>Lost/samtal</th></tr>
              </thead>
              <tbody>
                <% phrases.winning.forEach(function(p) { %>
                  <tr>
                    <td class="ci-phrase-word"><%= p.word %></td>
                    <td class="ci-phrase-lift ci-phrase-lift-up"><%= p.lift.toFixed(2) %>×</td>
                    <td class="ci-td-num"><%= p.sold_avg.toFixed(2) %></td>
                    <td class="ci-td-num"><%= p.lost_avg.toFixed(2) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </section>

        <!-- Losing phrases -->
        <section class="ci-section">
          <header class="ci-section-header">
            <h2>⚠️ Losing words (oftare i lost)</h2>
          </header>
          <% if (!phrases.losing.length) { %>
            <p class="ci-empty">Inga ord uppfyller minimitrösken (3+ förekomster).</p>
          <% } else { %>
            <table class="ci-table ci-phrase-table">
              <thead>
                <tr><th>Ord</th><th>Lift</th><th>Sold/samtal</th><th>Lost/samtal</th></tr>
              </thead>
              <tbody>
                <% phrases.losing.forEach(function(p) { %>
                  <tr>
                    <td class="ci-phrase-word"><%= p.word %></td>
                    <td class="ci-phrase-lift ci-phrase-lift-down"><%= p.lift.toFixed(2) %>×</td>
                    <td class="ci-td-num"><%= p.sold_avg.toFixed(2) %></td>
                    <td class="ci-td-num"><%= p.lost_avg.toFixed(2) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </section>
      </div>

      <p class="ci-hint">
        <strong>Hur ska du läsa detta?</strong> Lift > 1.5 i winning = signal.
        Det här är ord, inte fraser — för fras-extraktion behöver vi mer
        sofistikerad NLP (kommer i Fas 3). För nu: leta efter mönster i
        ord-listorna som matchar din magkänsla från coaching.
      </p>
    <% } %>

  </main>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
