<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= status %> — Joakim Jaksen</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <style>
    .err-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.25rem;
    }
    .err-card {
      max-width: 520px;
      width: 100%;
      padding: 3rem 2.5rem;
      background: linear-gradient(145deg, #1e293b, #0f172a);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 18px;
      text-align: center;
    }
    .err-icon {
      font-size: 3.5rem;
      margin-bottom: 1rem;
      line-height: 1;
    }
    .err-code {
      display: inline-block;
      padding: 0.35rem 0.9rem;
      background: rgba(99, 102, 241, 0.1);
      color: #a5b4fc;
      border: 1px solid rgba(99, 102, 241, 0.25);
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      margin-bottom: 0.75rem;
    }
    .err-card h1 {
      color: #f1f5f9;
      font-size: 1.75rem;
      margin: 0 0 0.75rem;
      line-height: 1.2;
    }
    .err-card p {
      color: #94a3b8;
      line-height: 1.6;
      margin: 0 0 1.75rem;
      font-size: 0.95rem;
    }
    .err-actions {
      display: flex;
      gap: 0.6rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .err-btn {
      padding: 0.85rem 1.5rem;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.92rem;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }
    .err-btn-primary {
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: #fff;
    }
    .err-btn-primary:hover { filter: brightness(1.1); }
    .err-btn-ghost {
      background: rgba(255, 255, 255, 0.04);
      color: #cbd5e1;
      border: 1px solid rgba(255, 255, 255, 0.12);
    }
    .err-btn-ghost:hover {
      border-color: rgba(99, 102, 241, 0.4);
      color: #f1f5f9;
    }
    .err-footer {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      color: #64748b;
      font-size: 0.8rem;
    }
    .err-footer a { color: #a5b4fc; text-decoration: none; }
    .err-footer a:hover { text-decoration: underline; }
  </style>
</head>
<body class="learn-page">

  <div class="err-wrap">
    <div class="err-card">
      <div class="err-icon"><%= icon %></div>
      <span class="err-code"><%= status %> · <%= codeLabel %></span>
      <h1><%= heading %></h1>
      <p><%= body %></p>

      <div class="err-actions">
        <% if (authenticated) { %>
          <a href="/dashboard" class="err-btn err-btn-primary">→ Till dashboarden</a>
          <a href="/learn" class="err-btn err-btn-ghost">Bläddra block</a>
        <% } else { %>
          <a href="/" class="err-btn err-btn-primary">→ Till startsidan</a>
          <a href="/login" class="err-btn err-btn-ghost">Logga in</a>
        <% } %>
      </div>

      <div class="err-footer">
        Behöver du hjälp? Mejla <a href="mailto:info@joakimjaksen.se">info@joakimjaksen.se</a>
        <% if (requestId) { %>
          <br><span style="font-family:monospace;font-size:0.72rem;opacity:0.6;">request-id: <%= requestId %></span>
        <% } %>
      </div>
    </div>
  </div>

</body>
</html>
