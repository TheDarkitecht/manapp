<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — Joakim Jaksen Säljutbildning</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/recommendations.css" />
  <link rel="stylesheet" href="/gamification.css" />
</head>
<body class="dash-page">

  <!-- ── Skip to main content (accessibility) ────────────────────────────── -->
  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <!-- ── Top navigation ─────────────────────────────────────────────────────── -->
  <header class="dash-topbar">
    <a href="/" class="dash-logo">🎯 Joakim Jaksen</a>
    <nav class="dash-nav-links">
      <a href="/learn" class="dash-nav-link">Utbildning</a>
      <a href="/ordbok" class="dash-nav-link">Säljordboken</a>
      <% if (role === 'admin') { %>
        <a href="/admin" class="dash-nav-link dash-nav-admin">⚙️ Admin</a>
      <% } %>
    </nav>
    <div class="dash-topbar-right">
      <span class="dash-username-badge"><%= username %></span>
      <a href="/logout" class="btn-logout">Logga ut</a>
    </div>
  </header>

  <!-- ── Toast notifications ──────────────────────────────────────────────── -->
  <div class="dash-toast" id="dashToast" style="display:none;"></div>

  <div class="dash-layout">

    <!-- ── LEFT SIDEBAR ──────────────────────────────────────────────────────── -->
    <aside class="dash-sidebar">
      <div class="sidebar-section">
        <div class="sidebar-user">
          <div class="sidebar-avatar"><%= username[0].toUpperCase() %></div>
          <div>
            <div class="sidebar-name"><%= username %></div>
            <div class="sidebar-role-badge role-<%= role %>">
              <% if (role === 'premium' || role === 'admin') { %>⭐ Premium<% } else { %>Gratis<% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Progress summary -->
      <div class="sidebar-section">
        <div class="sidebar-progress-label">
          Framgång: <%= completed %> / <%= role === 'free' ? 1 : totalBlocks %> block
        </div>
        <div class="sidebar-progress-bar"
             role="progressbar"
             aria-valuenow="<%= Math.round((completed / (role === 'free' ? 1 : totalBlocks)) * 100) %>"
             aria-valuemin="0"
             aria-valuemax="100"
             aria-label="<%= completed %> av <%= role === 'free' ? 1 : totalBlocks %> block avklarade">
          <div class="sidebar-progress-fill" style="width: <%= Math.round((completed / (role === 'free' ? 1 : totalBlocks)) * 100) %>%"></div>
        </div>
        <% if (role === 'free') { %>
          <p class="sidebar-progress-hint">Uppgradera för att låsa upp alla <%= totalBlocks %> block</p>
        <% } %>
      </div>

      <!-- Quick links -->
      <div class="sidebar-section sidebar-links">
        <a href="/learn" class="sidebar-link">📚 Säljutbildning</a>
        <a href="/sok" class="sidebar-link">🔍 Sök innehåll</a>
        <a href="/mina-framsteg" class="sidebar-link">📈 Mina framsteg</a>
        <a href="/loggbok" class="sidebar-link">📓 Loggboken</a>
        <a href="/pro" class="sidebar-link <%= (role === 'pro' || role === 'admin') ? 'sidebar-link-pro' : '' %>">
          🎙️ Samtalsanalys<% if (role !== 'pro' && role !== 'admin') { %> 🔒<% } %>
        </a>
        <a href="/ordbok" class="sidebar-link">📖 Säljordboken</a>
        <% if (role === 'premium' || role === 'pro' || role === 'admin') { %>
          <a href="/installningar#referral" class="sidebar-link">🎁 Bjud in & tjäna</a>
        <% } %>
        <a href="/installningar" class="sidebar-link">⚙️ Inställningar</a>
        <% if (role === 'free') { %>
          <a href="/upgrade" class="sidebar-link sidebar-link-upgrade">⭐ Uppgradera till Premium</a>
        <% } %>
      </div>

      <!-- Account section at bottom -->
      <div class="sidebar-section sidebar-account">
        <a href="/account" class="sidebar-link">🔐 Mitt konto</a>
        <% if (role === 'premium') { %>
          <form method="POST" action="/billing/portal" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="sidebar-billing-btn">Hantera prenumeration</button>
          </form>
        <% } %>
        <button onclick="toggleDeleteModal()" class="sidebar-delete-btn">Radera konto</button>
        <a href="/terms" class="sidebar-legal-link">Användarvillkor</a>
        <a href="/integritetspolicy" class="sidebar-legal-link">Integritetspolicy</a>
      </div>
    </aside>

    <!-- ── MAIN CONTENT ───────────────────────────────────────────────────────── -->
    <main class="dash-main" id="main-content">

      <% if (deleteError) { %>
        <div class="dash-alert dash-alert-error">Ange "RADERA" för att bekräfta att du vill radera ditt konto.</div>
      <% } %>

      <!-- ════════════ ADAPTIV DASHBOARD ═══════════════════════════════════ -->
      <%
        // Detektera "brand new"-användare (0 aktivitet alls).
        const isBrandNew = stats
          ? (stats.xp === 0 && stats.totalActionsLogged === 0 && stats.totalRoleplays === 0)
          : completed === 0;
      %>

      <% if (isBrandNew) { %>
      <!-- STARTER-VY för helt nya användare — fokuserat, icke-overwhelming -->
      <section class="starter-card">
        <div class="starter-header">
          <div class="starter-tag">🎯 Välkommen, <%= username %></div>
          <h1 class="starter-title">Låt oss få igång din resa.</h1>
          <p class="starter-sub">Tre enkla steg att komma igång. 10 minuter — och du är en helt annan säljare.</p>
        </div>

        <ol class="starter-steps">
          <li class="starter-step">
            <div class="ss-num">1</div>
            <div class="ss-body">
              <strong>📖 Läs Block 1 — Inledning</strong>
              <p>Vad sälj egentligen är. Varför skicklighet byggs genom träning — inte talang. 10 min.</p>
              <a href="/learn/inledning" class="ss-cta">Öppna Block 1 →</a>
            </div>
          </li>
          <li class="starter-step">
            <div class="ss-num">2</div>
            <div class="ss-body">
              <strong>🎭 Testa ett rollspel med Jocke</strong>
              <p>I Block 2 kan du öva "förvirrad ton" — Jocke spelar kunden. Ingen risk, bara träning.</p>
              <% if (role === 'free') { %>
                <span class="ss-locked">Rollspel ingår i Premium</span>
              <% } else { %>
                <a href="/learn/forsta-intrycket/ova" class="ss-cta ss-cta-ghost">Gå till övning</a>
              <% } %>
            </div>
          </li>
          <li class="starter-step">
            <div class="ss-num">3</div>
            <div class="ss-body">
              <strong>📓 Logga din första säljhandling</strong>
              <p>Gjort ett samtal idag? Skickat ett mejl? Logga det — det är där förändringen börjar.</p>
              <a href="/loggbok" class="ss-cta ss-cta-ghost">Öppna Loggboken</a>
            </div>
          </li>
        </ol>

        <div class="starter-footer">
          <p>Utbildningen har <strong>20 block</strong>, ett <strong>AI-rollspelssystem</strong> och ett <strong>prestationssystem</strong>. Allt väntar när du är redo.</p>
        </div>
      </section>

      <% } else { %>

      <!-- ════════════ Level-up-modal (elegant, dismissible) ════════════ -->
      <% if (gamEnabled && levelUp) { %>
      <div class="levelup-backdrop" id="levelUpBackdrop" role="dialog" aria-labelledby="levelUpTitle" aria-modal="true">
        <div class="levelup-modal">
          <div class="levelup-frame">
            <div class="levelup-eyebrow">Ny nivå</div>
            <h2 id="levelUpTitle" class="levelup-name"><%= levelUp.levelName %></h2>
            <div class="levelup-divider"></div>
            <p class="levelup-body"><%= levelUp.body %></p>

            <% if (levelUp.levelId >= 2) { %>
              <a href="/mina-framsteg/bevis/<%= levelUp.levelId %>" class="levelup-btn levelup-btn-primary">🏆 Se ditt bevis</a>
            <% } %>

            <form method="POST" action="/niva/sedd" class="levelup-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="levelId" value="<%= levelUp.levelId %>" />
              <button type="submit" class="levelup-btn <%= levelUp.levelId >= 2 ? 'levelup-btn-ghost' : '' %>">Fortsätt</button>
            </form>
          </div>
        </div>
      </div>
      <% } %>

      <!-- ════════════ Prestations-overview (när gamification PÅ) ════════════ -->
      <% if (gamEnabled && stats) { %>
      <section class="perf-overview">
        <div class="perf-level-card">
          <div class="perf-level-eyebrow">Nivå <%= stats.level.current.id %> av 5</div>
          <div class="perf-level-name"><%= stats.level.current.name %></div>
          <div class="perf-level-signal"><%= stats.level.current.signalizes %></div>
          <% if (stats.level.next) { %>
            <div class="perf-progress-bar" role="progressbar" aria-valuenow="<%= Math.round(stats.level.progress * 100) %>" aria-valuemin="0" aria-valuemax="100" aria-label="Progress mot <%= stats.level.next.name %>">
              <div class="perf-progress-fill" style="width: <%= Math.round(stats.level.progress * 100) %>%;"></div>
            </div>
            <div class="perf-progress-meta">
              <span><%= stats.xp %> XP</span>
              <span><%= stats.level.xpToNext %> XP till <%= stats.level.next.name %></span>
            </div>
          <% } else { %>
            <div class="perf-progress-meta perf-maxed"><strong><%= stats.xp %> XP</strong> — toppnivå uppnådd</div>
          <% } %>
        </div>

        <div class="perf-minor-stats">
          <div class="perf-stat">
            <div class="perf-stat-val">🔥 <%= stats.streak.current %></div>
            <div class="perf-stat-label">dagars streak</div>
            <% if (stats.streak.longest > stats.streak.current) { %>
              <div class="perf-stat-note">(bäst: <%= stats.streak.longest %>)</div>
            <% } %>
          </div>
          <div class="perf-stat">
            <div class="perf-stat-val"><%= stats.totalBlocksMastered %>/<%= totalBlocks %></div>
            <div class="perf-stat-label">bemästrade block</div>
          </div>
          <div class="perf-stat">
            <div class="perf-stat-val"><%= stats.totalActionsThisWeek %></div>
            <div class="perf-stat-label">actions denna vecka</div>
          </div>
          <div class="perf-stat">
            <div class="perf-stat-val"><%= stats.totalRoleplays %></div>
            <div class="perf-stat-label">rollspel genomförda</div>
          </div>
        </div>
      </section>

      <!-- Skill-radar -->
      <section class="perf-radar-section">
        <h3 class="perf-radar-title">Dina skills</h3>
        <p class="perf-radar-sub">Baserat på bemästrade block per område</p>
        <div class="perf-radar-list">
          <% stats.radar.forEach(function(dim) { %>
            <div class="perf-radar-item">
              <div class="perf-radar-head">
                <span class="perf-radar-icon"><%= dim.icon %></span>
                <span class="perf-radar-name"><%= dim.name %></span>
                <span class="perf-radar-score"><%= Math.round(dim.score * 100) %>%</span>
              </div>
              <div class="perf-radar-bar">
                <div class="perf-radar-fill" style="width: <%= Math.round(dim.score * 100) %>%;"></div>
              </div>
              <div class="perf-radar-meta"><%= dim.mastered %>/<%= dim.total %> block bemästrade</div>
            </div>
          <% }); %>
        </div>
      </section>

      <!-- Dagens challenge -->
      <% if (dailyChallenge) { %>
      <section class="perf-challenge <%= challengeCompleted ? 'perf-challenge-done' : '' %>">
        <div class="perf-challenge-head">
          <span class="perf-challenge-eyebrow">🎯 Dagens utmaning</span>
          <% if (challengeCompleted) { %>
            <span class="perf-challenge-badge">✓ Klar</span>
          <% } else { %>
            <span class="perf-challenge-xp">+<%= dailyChallenge.xp %> XP</span>
          <% } %>
        </div>
        <h3 class="perf-challenge-text"><%= dailyChallenge.text %></h3>
        <% if (!challengeCompleted) { %>
          <a href="/loggbok" class="jc-btn">Logga när du gjort det →</a>
        <% } else { %>
          <p class="perf-challenge-done-msg">Bra jobbat. Ny challenge imorgon.</p>
        <% } %>
      </section>
      <% } %>
      <% } %>

      <!-- ════════════ "Din plan" — adaptiv pedagogisk coach ════════════ -->
      <% if (recommendations && recommendations.length) { %>
      <section class="dash-plan" role="region" aria-label="Din personliga plan">
        <div class="dash-plan-header">
          <div>
            <span class="dash-plan-eyebrow">🧭 Din plan</span>
            <h2 class="dash-plan-title">Nästa steg som ger dig mest just nu</h2>
          </div>
          <button class="dash-plan-toggle" type="button" onclick="toggleDashPlan()" aria-expanded="true" aria-controls="dashPlanCards">Dölj</button>
        </div>
        <div class="dash-plan-cards" id="dashPlanCards">
          <% recommendations.forEach(function(rec) { %>
            <div class="dp-card dp-card-<%= rec.type %>" data-dismiss-key="<%= rec.dismissKey %>">
              <button class="dp-dismiss" type="button" onclick="dismissRecCard(this)" aria-label="Dölj den här rekommendationen">✕</button>
              <div class="dp-tag">
                <span class="dp-icon"><%= rec.icon %></span>
                <span class="dp-tag-label"><%= rec.tag %></span>
              </div>
              <h3 class="dp-card-title"><%= rec.title %></h3>
              <p class="dp-card-desc"><%= rec.description %></p>
              <a href="<%= rec.url %>" class="dp-card-cta"><%= rec.cta %> →</a>
            </div>
          <% }); %>
        </div>
      </section>
      <script>
        (function(){
          // Dölj-kort som användaren stängt (localStorage, session-baserad)
          document.querySelectorAll('.dp-card').forEach(card => {
            const key = card.getAttribute('data-dismiss-key');
            if (key && localStorage.getItem('dismiss-' + key)) {
              card.style.display = 'none';
            }
          });
          // Om alla är dolda — dölj hela sektionen
          const visible = [...document.querySelectorAll('.dp-card')].filter(c => c.style.display !== 'none');
          if (!visible.length) {
            const section = document.querySelector('.dash-plan');
            if (section) section.style.display = 'none';
          }
          // Kollapsat-läge (per-session)
          if (sessionStorage.getItem('dash-plan-collapsed') === '1') {
            const cards = document.getElementById('dashPlanCards');
            const btn = document.querySelector('.dash-plan-toggle');
            if (cards) cards.style.display = 'none';
            if (btn) { btn.textContent = 'Visa'; btn.setAttribute('aria-expanded', 'false'); }
          }
        })();
        function dismissRecCard(btn) {
          const card = btn.closest('.dp-card');
          const key = card.getAttribute('data-dismiss-key');
          if (key) localStorage.setItem('dismiss-' + key, '1');
          card.style.display = 'none';
          const visible = [...document.querySelectorAll('.dp-card')].filter(c => c.style.display !== 'none');
          if (!visible.length) {
            const section = document.querySelector('.dash-plan');
            if (section) section.style.display = 'none';
          }
        }
        function toggleDashPlan() {
          const cards = document.getElementById('dashPlanCards');
          const btn = document.querySelector('.dash-plan-toggle');
          if (!cards || !btn) return;
          const hidden = cards.style.display === 'none';
          cards.style.display = hidden ? '' : 'none';
          btn.textContent = hidden ? 'Dölj' : 'Visa';
          btn.setAttribute('aria-expanded', hidden ? 'true' : 'false');
          sessionStorage.setItem('dash-plan-collapsed', hidden ? '0' : '1');
        }
      </script>
      <% } %>

      <!-- ── FREE USER — Onboarding / Upsell ──────────────────────────────── -->
      <% if (role === 'free') { %>

        <section class="dash-onboarding">
          <div class="onboarding-header">
            <h1>Välkommen, <%= username %>! 🎯</h1>
            <p>Du har tillgång till <strong>Block 1 — Inledning</strong> och <strong>Block 2 — Första Intrycket</strong>. Börja här.</p>
          </div>
          <div class="onboarding-steps">
            <a href="/learn/inledning" class="onboarding-step <% if (progress['inledning']?.completed) { %>step-done<% } %>">
              <div class="step-num"><% if (progress['inledning']?.completed) { %>✓<% } else { %>1<% } %></div>
              <div class="step-body">
                <strong>Läs Block 1 — Inledning</strong>
                <span>Vad sälj egentligen är. Retoriken. Varför säljare alltid behövs.</span>
              </div>
              <span class="step-arrow">→</span>
            </a>
            <a href="/learn/forsta-intrycket" class="onboarding-step <% if (progress['forsta-intrycket']?.completed) { %>step-done<% } %>">
              <div class="step-num"><% if (progress['forsta-intrycket']?.completed) { %>✓<% } else { %>2<% } %></div>
              <div class="step-body">
                <strong>Läs Block 2 — Första Intrycket</strong>
                <span>De första 7 sekunderna. Mehrabians regel. Hur du öppnar ett samtal.</span>
              </div>
              <span class="step-arrow">→</span>
            </a>
            <div class="onboarding-step step-locked">
              <div class="step-num">🔒</div>
              <div class="step-body">
                <strong>Block 3–20 — Låsta med Premium</strong>
                <span>Tonfall, prospektering, invändningar, avslutstekniker, förhandling och mer.</span>
              </div>
              <a href="/upgrade" class="step-upgrade-btn">Uppgradera →</a>
            </div>
          </div>
        </section>

        <section class="dash-upsell">
          <div class="upsell-card">
            <div class="upsell-left">
              <div class="upsell-tag">⭐ Premium</div>
              <h2>Lås upp alla 20 block</h2>
              <p>Teori, video och prov per block. AI-assistenten Jocke. Allt du behöver för att prestera på riktigt.</p>
              <ul class="upsell-list">
                <li>✅ 18 avancerade block (Block 3–20)</li>
                <li>✅ Tonfall & psykologisk påverkan, invändningar, avslut, förhandling</li>
                <li>✅ LinkedIn, videosamtal, e-post</li>
                <li>✅ AI-assistenten Jocke — din personlige säljcoach</li>
                <li>✅ Mental styrka, AI-verktyg & rekommenderad läsning</li>
              </ul>
            </div>
            <div class="upsell-right">
              <div class="upsell-price">199 kr<span>/mån</span></div>
              <a href="/upgrade" class="upsell-btn">Uppgradera nu →</a>
              <p class="upsell-fine">Avsluta när som helst. Säker betalning via Stripe.</p>
            </div>
          </div>
        </section>

      <% } else { %>

        <!-- ── PREMIUM USER — Progress overview ───────────────────────────── -->
        <section class="dash-progress-overview">
          <div class="progress-header">
            <div>
              <h1>Välkommen tillbaka, <%= username %>! 🎯</h1>
              <p><%= completed %> av <%= totalBlocks %> block avklarade</p>
            </div>
            <a href="/learn" class="dash-continue-btn">
              <% const nextBlock = blocks.find(b => !progress[b.id]?.completed); %>
              <% if (nextBlock) { %>
                Fortsätt: <%= nextBlock.title %> →
              <% } else { %>
                Se alla block →
              <% } %>
            </a>
          </div>

          <div class="progress-blocks-mini">
            <% blocks.forEach(function(b, i) { %>
              <a href="/learn/<%= b.id %>" class="mini-block <% if (progress[b.id]?.completed) { %>mini-done<% } %>"
                 title="<%= b.title %><% if (progress[b.id]?.quiz_score !== undefined) { %> — <%= progress[b.id].quiz_score %>/<%= progress[b.id].quiz_total %><% } %>">
                <% if (progress[b.id]?.completed) { %>✓<% } else { %><%= i+1 %><% } %>
              </a>
            <% }); %>
          </div>
        </section>

        <!-- Continue from where left off -->
        <section class="dash-continue-section">
          <h2>Nästa steg</h2>
          <div class="continue-cards">
            <% const nextUnfinished = blocks.filter(b => !progress[b.id]?.completed).slice(0, 3); %>
            <% nextUnfinished.forEach(function(b) { %>
              <a href="/learn/<%= b.id %>" class="continue-card" style="--card-gradient: <%= b.gradient %>;">
                <div class="cc-icon"><%= b.icon %></div>
                <div class="cc-body">
                  <h4><%= b.title %></h4>
                  <p><%= b.subtitle %></p>
                </div>
                <span class="cc-arrow">→</span>
              </a>
            <% }); %>
            <% if (nextUnfinished.length === 0) { %>
              <div class="dash-all-done">
                <div class="all-done-icon">🏆</div>
                <h3>Imponerande — du har klarat alla block!</h3>
                <p>Fortsätt med Säljordboken eller revidera ett block du vill repetera.</p>
                <a href="/ordbok" class="upsell-btn">Säljordboken →</a>
              </div>
            <% } %>
          </div>
        </section>

      <% } %>

      <!-- ── NOTES ───────────────────────────────────────────────────────────── -->
      <section class="dash-notes-section">
        <div class="notes-header">
          <h2>Mina anteckningar</h2>
          <div class="notes-header-right">
            <% if (notes.length >= 40) { %>
              <span class="notes-limit-badge <%= notes.length >= 50 ? 'notes-limit-full' : '' %>">
                <%= notes.length %>/50
              </span>
            <% } %>
            <button class="btn-new-note" onclick="toggleForm()" <%= notes.length >= 50 ? 'disabled title="Max 50 anteckningar nådd"' : '' %>>+ Ny anteckning</button>
          </div>
        </div>

        <div class="note-form-section" id="noteForm" style="display:none;">
          <form method="POST" action="/notes" class="note-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label for="noteContent" class="visually-hidden">Anteckningsinnehåll</label>
            <textarea name="content" id="noteContent" placeholder="Skriv din anteckning här..." rows="4" required autofocus maxlength="2000" oninput="updateNoteCount(this)"></textarea>
          <div class="note-char-count" id="noteCharCount" style="text-align:right;font-size:0.72rem;color:#475569;margin-top:0.25rem;">0 / 2000</div>
            <div class="form-actions">
              <button type="submit">Spara</button>
              <button type="button" class="btn-cancel" onclick="toggleForm()">Avbryt</button>
            </div>
          </form>
        </div>

        <% if (notes.length === 0) { %>
          <p class="empty-state">Du har inga anteckningar ännu. Skapa din första när du hittar något värdefullt i utbildningen.</p>
        <% } %>
        <div class="notes-grid">
          <% notes.forEach(function(note) { %>
            <div class="note-card">
              <p class="note-content"><%= note.content %></p>
              <div class="note-footer">
                <span class="note-date"><%= (note.created_at || '').slice(0,10) %></span>
                <form method="POST" action="/notes/<%= note.id %>/delete" class="delete-form"
                      onsubmit="return confirm('Ta bort den här anteckningen?')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn-delete">Ta bort</button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
      </section>

      <% } %> <!-- slut: isBrandNew else-gren -->

    </main>
  </div>

  <!-- ── Delete account modal ──────────────────────────────────────────────── -->
  <div class="modal-backdrop" id="deleteModal" onclick="closeDeleteModal(event)" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
    <div class="modal delete-modal">
      <div class="privacy-header">
        <h2 id="deleteModalTitle">⚠️ Radera konto</h2>
        <button class="modal-close-btn" aria-label="Stäng dialog">✕</button>
      </div>
      <div class="privacy-body">
        <p>Detta raderar ditt konto, alla anteckningar och all progress permanent. Det går <strong>inte att ångra</strong>.</p>
        <p>Skriv <strong>RADERA</strong> i fältet nedan för att bekräfta.</p>
        <form method="POST" action="/account/delete" class="delete-confirm-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="text" name="confirmDelete" placeholder="RADERA" class="delete-confirm-input" autocomplete="off" />
          <button type="submit" class="delete-confirm-btn">Radera mitt konto permanent</button>
        </form>
      </div>
    </div>
  </div>

  <!-- ── Jocke chat bubble (premium only) ─────────────────────────────────── -->
  <% if (role === 'premium' || role === 'admin') { %>
  <button class="chat-bubble" id="chatBubble" onclick="toggleChat()" title="Chatta med Jocke" aria-label="Öppna chatt med Jocke" aria-expanded="false">
    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="white" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/>
    </svg>
  </button>

  <div class="chat-window" id="chatWindow" role="dialog" aria-label="Chatt med Jocke" aria-modal="true" aria-hidden="true">
    <div class="chat-header">
      <div class="chat-header-info">
        <div class="chat-avatar">J</div>
        <div>
          <strong>Jocke</strong>
          <span class="chat-status">● Online</span>
        </div>
      </div>
      <button class="chat-close" onclick="toggleChat()" aria-label="Stäng chatt">✕</button>
    </div>
    <div class="chat-messages" id="chatMessages">
      <div class="chat-msg assistant">
        <p>Hej! Jag är Jocke — din säljcoach här. Vad kan jag hjälpa dig med? 🎯</p>
      </div>
    </div>
    <div class="chat-input-area">
      <textarea id="chatInput" placeholder="Skriv ett meddelande..." rows="1" onkeydown="handleKey(event)" oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,120)+'px'"></textarea>
      <button onclick="sendMessage()" aria-label="Skicka meddelande">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="white" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M2 21l21-9L2 3v7l15 2-15 2z"/>
        </svg>
      </button>
    </div>
  </div>
  <% } %>

  <!-- ── Mobile bottom navigation ──────────────────────────────────────────── -->
  <nav class="app-bottom-nav">
    <a href="/dashboard" class="app-bottom-nav-item">
      <span class="abn-icon">🏠</span>
      <span class="abn-label">Hem</span>
    </a>
    <a href="/learn" class="app-bottom-nav-item">
      <span class="abn-icon">📚</span>
      <span class="abn-label">Utbildning</span>
    </a>
    <a href="/ordbok" class="app-bottom-nav-item">
      <span class="abn-icon">📖</span>
      <span class="abn-label">Ordbok</span>
    </a>
    <% if (role === 'free') { %>
      <a href="/upgrade" class="app-bottom-nav-item abn-upgrade">
        <span class="abn-icon">⭐</span>
        <span class="abn-label">Premium</span>
      </a>
    <% } else { %>
      <a href="/logout" class="app-bottom-nav-item">
        <span class="abn-icon">🚪</span>
        <span class="abn-label">Logga ut</span>
      </a>
    <% } %>
  </nav>

  <script>
    // Motion preference helper
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Animate sidebar progress bar on load
    (function() {
      const fill = document.querySelector('.sidebar-progress-fill');
      if (!fill) return;
      if (prefersReducedMotion) { return; } // skip animation when reduced motion is preferred
      const target = fill.style.width;
      fill.style.width = '0';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        fill.style.width = target;
      }));
    })();
  </script>

  <script>
    // Highlight active bottom nav item
    (function() {
      const p = window.location.pathname;
      document.querySelectorAll('.app-bottom-nav-item').forEach(a => {
        const h = a.getAttribute('href');
        if (h === '/dashboard' && p === '/dashboard') a.classList.add('active');
        else if (h === '/learn' && (p === '/learn' || p.startsWith('/learn/'))) a.classList.add('active');
        else if (h === '/ordbok' && p === '/ordbok') a.classList.add('active');
        else if (h === '/upgrade' && p === '/upgrade') a.classList.add('active');
      });
    })();
  </script>

  <script>
    // Toast system
    function showToast(msg, type) {
      const el = document.getElementById('dashToast');
      el.textContent = msg;
      el.style.cssText = `
        display:flex; position:fixed; bottom:5.5rem; left:50%; transform:translateX(-50%);
        background:${type === 'success' ? '#10b981' : '#ef4444'};
        color:#fff; padding:.65rem 1.25rem; border-radius:8px; font-weight:600;
        font-size:.875rem; z-index:500; box-shadow:0 4px 20px rgba(0,0,0,0.4);
        animation:toastIn 0.2s ease;
      `;
      setTimeout(() => { el.style.display = 'none'; }, 3000);
    }

    // Check for flash params and clean URL
    (function() {
      const p = new URLSearchParams(window.location.search);
      if (p.get('note_saved') === '1') {
        showToast('✓ Anteckning sparad!', 'success');
        history.replaceState({}, '', '/dashboard');
      }
      if (p.get('note_deleted') === '1') {
        showToast('✓ Anteckning borttagen.', 'success');
        history.replaceState({}, '', '/dashboard');
      }
      if (p.get('note_limit') === '1') {
        showToast('⚠️ Max 50 anteckningar nådd — ta bort några för att spara fler.', 'error');
        history.replaceState({}, '', '/dashboard');
      }
      if (p.get('deleteError') === '1') {
        // Error message is already shown server-side; just clean the URL
        history.replaceState({}, '', '/dashboard');
      }
    })();

    function toggleForm() {
      const f = document.getElementById('noteForm');
      const isOpening = f.style.display === 'none';
      f.style.display = isOpening ? 'block' : 'none';
      if (isOpening) {
        const ta = document.getElementById('noteContent');
        if (ta) {
          ta.value = '';
          updateNoteCount(ta);
          // Smooth scroll to form then focus
          f.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'nearest' });
          setTimeout(() => ta.focus(), prefersReducedMotion ? 0 : 150);
        }
      }
    }

    function updateNoteCount(ta) {
      const el = document.getElementById('noteCharCount');
      if (el) {
        const n = ta.value.length;
        el.textContent = n + ' / 2000';
        el.style.color = n > 1800 ? '#f87171' : '#475569';
      }
    }

    let _deleteModalOpener = null; // track opener for focus return

    function toggleDeleteModal() {
      _deleteModalOpener = document.activeElement; // remember opener
      document.getElementById('deleteModal').classList.add('open');
      // Auto-focus the confirmation input for keyboard users
      setTimeout(() => document.querySelector('.delete-confirm-input')?.focus(), 80);
    }
    function closeDeleteModal(e) {
      const modal = document.getElementById('deleteModal');
      if (!e || e.target === modal) {
        modal.classList.remove('open');
        // Return focus to opener (e.g. "Radera konto" button)
        if (_deleteModalOpener) { _deleteModalOpener.focus(); _deleteModalOpener = null; }
      }
    }

    // Wire the close button to also restore focus
    document.querySelector('#deleteModal .modal-close-btn')?.addEventListener('click', function() {
      closeDeleteModal(null);
    });

    // Escape key: close chat if open, or close delete modal if open
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        const chatWindow = document.getElementById('chatWindow');
        if (chatWindow && chatWindow.classList.contains('open')) {
          toggleChat(); return;
        }
        const modal = document.getElementById('deleteModal');
        if (modal && modal.classList.contains('open')) {
          closeDeleteModal(null);
        }
      }
    });

    <% if (role === 'premium' || role === 'admin') { %>
    let chatOpen = false;
    // Seed Jocke with the user's progress so answers stay relevant
    let messages = [
      { role: 'user',      content: 'Jag är <%= username %> och har klarat <%= completed %> av <%= totalBlocks %> säljblock.' },
      { role: 'assistant', content: 'Bra, <%= username %>! Jag vet var du är i utbildningen. Fråga på — eller berätta vilken situation du vill träna.' },
    ];
    function toggleChat() {
      chatOpen = !chatOpen;
      const win = document.getElementById('chatWindow');
      win.classList.toggle('open', chatOpen);
      // aria-hidden="true" when closed prevents browsers from treating this
      // as an open modal dialog and making the rest of the page inert.
      win.setAttribute('aria-hidden', chatOpen ? 'false' : 'true');
      document.getElementById('chatBubble').setAttribute('aria-expanded', chatOpen ? 'true' : 'false');
      if (chatOpen) {
        document.getElementById('chatInput').focus();
      } else {
        document.getElementById('chatBubble').focus();
      }
    }
    function handleKey(e) {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    }
    async function sendMessage() {
      const input = document.getElementById('chatInput');
      const text = input.value.trim();
      if (!text) return;
      appendMessage('user', text);
      input.value = '';
      input.style.height = 'auto';
      messages.push({ role: 'user', content: text });
      const typingId = showTyping();
      try {
        const res = await fetch('/chat', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-csrf-token': '<%= csrfToken %>',
          },
          body: JSON.stringify({ messages }),
        });
        const data = await res.json();
        removeTyping(typingId);
        if (!res.ok || data.error) {
          // Show error in UI but don't push it into message history
          appendMessage('assistant', data.error || 'Något gick fel. Försök igen.');
          return;
        }
        const reply = data.reply || 'Inget svar mottogs.';
        appendMessage('assistant', reply);
        messages.push({ role: 'assistant', content: reply });
      } catch {
        removeTyping(typingId);
        appendMessage('assistant', 'Kunde inte nå Jocke just nu. Försök igen.');
      }
    }
    function appendMessage(role, text) {
      const box = document.getElementById('chatMessages');
      const div = document.createElement('div');
      div.className = `chat-msg ${role}`;
      div.innerHTML = `<p>${renderMarkdown(text)}</p>`;
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
    }
    function showTyping() {
      const box = document.getElementById('chatMessages');
      const div = document.createElement('div');
      div.className = 'chat-msg assistant typing-indicator';
      div.id = 'typing-' + Date.now();
      div.innerHTML = '<p><span></span><span></span><span></span></p>';
      box.appendChild(div); box.scrollTop = box.scrollHeight;
      return div.id;
    }
    function removeTyping(id) { const el = document.getElementById(id); if (el) el.remove(); }
    function escapeHtml(t) {
      return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
    function renderMarkdown(raw) {
      // Simple markdown: escape HTML, then apply inline formatting + list items
      let s = escapeHtml(raw);
      // Bold: **text**
      s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      // Italic: *text* (single asterisk, not adjacent to word char on both sides handled)
      s = s.replace(/(?<!\*)\*([^*\n]+?)\*(?!\*)/g, '<em>$1</em>');
      // Bullet list items starting with - or •
      s = s.replace(/^[•\-] (.+)/gm, '<li>$1</li>');
      s = s.replace(/(<li>.*<\/li>)/gs, '<ul>$1</ul>');
      // Newlines → <br> (but not inside <ul>)
      s = s.replace(/\n(?!<\/?(?:ul|li))/g, '<br>');
      s = s.replace(/<br>\s*(<ul>)/g, '$1');
      return s;
    }
    <% } %>
  </script>
  <script src="/heartbeat.js" defer></script>
</body>
</html>
