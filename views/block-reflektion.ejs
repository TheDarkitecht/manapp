<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>💭 Reflektion: <%= block.title %> — Joakim Jaksen</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/journey.css" />
  <link rel="stylesheet" href="/recommendations.css" />
</head>
<body class="block-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/learn/<%= block.id %>" class="learn-nav-back">← Tillbaka till blocket</a>
    <span class="learn-nav-title">💭 Reflektion</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="reflektion-wrap">

    <div class="reflektion-header">
      <div class="uppdrag-eyebrow">Steg 4 av 4: Reflektera</div>
      <h1>💭 Stäng cirkeln</h1>
      <p>Metakognition — att tänka på vad du lärt dig — är det som faktiskt gör att det fastnar. Skriv fritt. Ingen bedömer.</p>
    </div>

    <% if (block.reflections && block.reflections.length) { %>

      <% const answeredIdxs = new Set(reflections.map(r => r.prompt_idx)); %>

      <div class="reflektion-list">
        <% block.reflections.forEach(function(prompt, idx){ %>
          <% const prior = reflections.filter(r => r.prompt_idx === idx); %>
          <div class="reflektion-card <%= answeredIdxs.has(idx) ? 'reflektion-card-answered' : '' %>">
            <div class="reflektion-q">
              <span class="reflektion-num"><%= idx + 1 %></span>
              <p><%= prompt %></p>
              <% if (answeredIdxs.has(idx)) { %><span class="reflektion-check">✓</span><% } %>
            </div>

            <% if (prior.length) { %>
              <div class="reflektion-prior">
                <% prior.forEach(function(r){ %>
                  <div class="reflektion-prior-item">
                    <span class="reflektion-prior-date"><%= new Date(r.created_at).toLocaleDateString('sv-SE') %></span>
                    <p><%= r.response %></p>
                  </div>
                <% }); %>
              </div>
            <% } %>

            <form method="POST" action="/learn/<%= block.id %>/reflektion/spara" class="reflektion-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="promptIdx" value="<%= idx %>" />
              <textarea name="response" rows="3" maxlength="3000" placeholder="Skriv ditt svar ..."></textarea>
              <button type="submit" class="reflektion-save"><%= answeredIdxs.has(idx) ? 'Lägg till ett till svar' : 'Spara reflektion' %></button>
            </form>
          </div>
        <% }); %>
      </div>

      <% if (journey.fullyMastered) { %>
        <div class="reflektion-complete">
          <div class="reflektion-complete-icon">🏆</div>
          <h2>Du har bemästrat blocket</h2>
          <p>Alla 4 steg gjorda. Reflektioner sparas för alltid — du kan alltid återvända och läsa dina egna ord.</p>

          <% if (typeof nextSuggestion !== 'undefined' && nextSuggestion && nextSuggestion.block) { %>
            <div class="reflektion-next-suggestion">
              <span class="rns-label">Rekommenderat nästa:</span>
              <strong><%= nextSuggestion.block.icon %> <%= nextSuggestion.block.title %></strong>
              <p class="rns-reason"><%= nextSuggestion.reason %></p>
              <div class="rns-actions">
                <a href="/learn/<%= nextSuggestion.block.id %>" class="jc-btn">Starta <%= nextSuggestion.block.title %> →</a>
                <a href="/learn" class="jc-btn jc-btn-ghost">Visa alla block</a>
              </div>
            </div>
          <% } else { %>
            <a href="/learn" class="jc-btn">📚 Välj nästa block</a>
          <% } %>
        </div>
      <% } %>

    <% } else { %>
      <p>Inga reflektionsfrågor för detta block ännu.</p>
    <% } %>

    <div class="snabb-cta-row">
      <a href="/learn/<%= block.id %>" class="jc-btn jc-btn-ghost">← Tillbaka till blocket</a>
    </div>

  </main>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
