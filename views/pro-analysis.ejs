<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Analys: <%= analysis.title || 'Samtal' %> — Pro</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎙️</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/gamification.css" />
  <link rel="stylesheet" href="/pro.css" />
</head>
<body class="block-page pro-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/pro" class="learn-nav-back">← Samtalsanalys</a>
    <span class="learn-nav-title">🎙️ <%= analysis.title || 'Samtal' %></span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="pro-wrap">

    <div class="pro-analysis-header">
      <div class="pro-hero-badge">⚡ PRO · Samtalsanalys</div>
      <h1><%= analysis.title || 'Samtal' %></h1>
      <div class="pro-analysis-meta">
        <%= new Date(analysis.created_at).toLocaleString('sv-SE', { dateStyle: 'long', timeStyle: 'short' }) %>
        <% if (analysis.duration_sec) { %>
          · Längd: <%= Math.floor(analysis.duration_sec / 60) %>:<%= String(analysis.duration_sec % 60).padStart(2, '0') %>
        <% } %>
        · Status: <strong class="pro-status pro-status-<%= analysis.status %>-text"><%= analysis.status %></strong>
      </div>
    </div>

    <% if (analysis.status === 'transcribing' || analysis.status === 'analyzing' || analysis.status === 'pending') { %>
      <div class="pro-processing">
        <div class="pro-processing-icon">⏳</div>
        <h2>Analys pågår...</h2>
        <p>Detta tar vanligtvis 30–90 sekunder. <strong>Vänta några sekunder och uppdatera sidan.</strong></p>
        <meta http-equiv="refresh" content="8">
        <script>setTimeout(() => window.location.reload(), 8000);</script>
      </div>
    <% } else if (analysis.status === 'failed') { %>
      <div class="pro-error-card">
        <div class="pro-processing-icon">⚠️</div>
        <h2>Analysen misslyckades</h2>
        <p><%= analysis.error_message || 'Okänt fel' %></p>
        <p style="color:#94a3b8;font-size:0.9rem;">Denna uppladdning räknas INTE mot din månadsgräns. Prova att ladda upp på nytt.</p>
        <a href="/pro/samtal/ny" class="jc-btn">Försök igen →</a>
      </div>
    <% } else { %>

      <!-- ═══ Analys (done) ═══ -->
      <div class="pro-analysis-grid">

        <!-- AI-feedback — huvudkolumnen -->
        <section class="pro-analysis-main">
          <h2>🎯 Jockes feedback</h2>
          <div class="pro-analysis-content" id="analysisContent"><%= analysis.analysis || '' %></div>
        </section>

        <!-- Transkribering — sidokolumn, expanderbar -->
        <section class="pro-transcript-side">
          <details class="pro-transcript-details">
            <summary>📝 Full transkribering (klicka för att expandera)</summary>
            <div class="pro-transcript-text"><%= analysis.transcript || '' %></div>
          </details>
        </section>
      </div>

    <% } %>

    <!-- Actions -->
    <div class="pro-analysis-actions">
      <a href="/pro/samtal/ny" class="jc-btn">🎙️ Ladda upp nytt samtal</a>
      <a href="/pro" class="jc-btn jc-btn-ghost">← Alla analyser</a>
      <form method="POST" action="/pro/samtal/<%= analysis.id %>/delete" style="display:inline;" onsubmit="return confirm('Radera denna analys? Går ej att ångra.');">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="pro-delete-btn">🗑️ Radera analys</button>
      </form>
    </div>

  </main>

  <script>
    // Enkel markdown-renderer för analys-innehållet (server skickar markdown-text)
    (function(){
      const el = document.getElementById('analysisContent');
      if (!el) return;
      let html = el.textContent;
      // Headings
      html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
      html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
      // Bold
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      // Italic / quotes
      html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
      // Lists
      html = html.replace(/^\- (.+)$/gm, '<li>$1</li>');
      html = html.replace(/(<li>[\s\S]*?<\/li>\n?)+/g, m => '<ul>' + m + '</ul>');
      // Paragraphs
      html = html.split(/\n\n+/).map(p => {
        if (p.startsWith('<h') || p.startsWith('<ul') || p.startsWith('<li')) return p;
        return '<p>' + p.replace(/\n/g, '<br>') + '</p>';
      }).join('');
      el.innerHTML = html;
    })();
  </script>

  <!-- ── Mobile bottom navigation (consistent med /dashboard, /learn, /ordbok) ── -->
  <nav class="app-bottom-nav">
    <a href="/dashboard" class="app-bottom-nav-item">
      <span class="abn-icon">🏠</span>
      <span class="abn-label">Hem</span>
    </a>
    <a href="/learn" class="app-bottom-nav-item">
      <span class="abn-icon">📚</span>
      <span class="abn-label">Utbildning</span>
    </a>
    <a href="/ordbok" class="app-bottom-nav-item">
      <span class="abn-icon">📖</span>
      <span class="abn-label">Ordbok</span>
    </a>
    <a href="/pro" class="app-bottom-nav-item abn-upgrade active">
      <span class="abn-icon">🎙️</span>
      <span class="abn-label">Pro</span>
    </a>
  </nav>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
