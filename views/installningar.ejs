<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inställningar — Joakim Jaksen</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚙️</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/gamification.css" />
</head>
<body class="block-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/dashboard" class="learn-nav-back">← Dashboard</a>
    <span class="learn-nav-title">⚙️ Inställningar</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content" class="settings-wrap">

    <h1>Inställningar</h1>
    <% if (saved) { %>
      <div class="lb-saved" role="status" aria-live="polite">✓ Inställning sparad</div>
    <% } %>

    <form method="POST" action="/installningar" class="settings-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="settings-section">
        <h2>Prestationssystem</h2>
        <p class="settings-desc">XP, nivåer, streak och dagliga challenges. Data samlas fortfarande — du kan alltid slå på det senare utan att förlora historiken.</p>

        <label class="settings-toggle">
          <input type="checkbox" name="gamification_enabled" <%= prefs.gamification_enabled !== false ? 'checked' : '' %> />
          <span class="toggle-slider"></span>
          <span class="toggle-label">Visa XP, nivåer, streak och challenges</span>
        </label>

        <div class="settings-hint">
          <strong>När PÅ:</strong> nivå-badge, XP-räknare, streak-flame, skill-radar, dagens challenge och loggboken-statistik visas.<br>
          <strong>När AV:</strong> ren kurs. Bara teori, övningar, prov, uppdrag och reflektion. Loggboken fungerar fortfarande men utan statistik.
        </div>
      </div>

      <div class="settings-section">
        <h2>Veckovisa mejl</h2>
        <p class="settings-desc">Kort sammanfattning varje söndag — din vecka i siffror, nästa utmaning, återkopplande nudge. Inga försäljningsmejl. Håller dig i rytmen.</p>

        <label class="settings-toggle">
          <input type="checkbox" name="email_retention" <%= prefs.email_retention !== false ? 'checked' : '' %> />
          <span class="toggle-slider"></span>
          <span class="toggle-label">Skicka veckovisa sammanfattningar + påminnelser om jag blir inaktiv</span>
        </label>

        <div class="settings-hint">
          <strong>Innehåll:</strong> din vecka i stats, dagens challenge, länk tillbaka till dashboarden. Om du inte loggat in på 14+ dagar får du en vänlig "vi saknar dig"-nudge (max 1 var 30:e dag).<br>
          <strong>Avprenumerera:</strong> en-klicks-länk finns i varje mejl. Du får alltid kvar kontohantering (lösenordsreset, kvitton) oavsett.
        </div>
      </div>

      <div class="settings-actions">
        <button type="submit" class="lb-submit">Spara</button>
        <a href="/dashboard" class="jc-btn jc-btn-ghost">Tillbaka</a>
      </div>
    </form>

    <!-- ═══════════════════════════════════════════════════════════════════
         REFERRAL — dela med kollegor & vänner
    ═══════════════════════════════════════════════════════════════════ -->
    <% if (referralCode) { %>
    <div class="settings-section" style="margin-top:2rem;background:linear-gradient(145deg, rgba(251,191,36,0.06), rgba(245,158,11,0.02));border-color:rgba(251,191,36,0.25);">
      <h2>🎁 Bjud in kollegor</h2>
      <p class="settings-desc">Dela din länk. När någon registrerar sig via din länk och blir Premium/Pro får du <strong>1 månad gratis</strong> på din prenumeration.</p>

      <div style="padding:1rem;background:rgba(0,0,0,0.25);border-radius:10px;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
        <code id="referralLink" style="flex:1;color:#fde68a;font-family:monospace;font-size:0.85rem;word-break:break-all;min-width:200px;"><%= referralUrl %></code>
        <button type="button" onclick="copyReferral()" id="copyRefBtn" style="padding:0.5rem 0.85rem;background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#0f172a;border:none;border-radius:8px;font-weight:700;cursor:pointer;font-size:0.85rem;">📋 Kopiera</button>
      </div>

      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
        <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent(referralUrl) %>" target="_blank" rel="noopener" style="padding:0.5rem 1rem;background:rgba(99,102,241,0.1);color:#a5b4fc;text-decoration:none;border-radius:8px;font-size:0.85rem;border:1px solid rgba(99,102,241,0.25);">💼 LinkedIn</a>
        <a href="mailto:?subject=Kolla%20in%20Joakim%20Jaksens%20S%C3%A4ljutbildning&body=Tjena!%20Jag%20har%20testat%20den%20h%C3%A4r%20och%20den%20%C3%A4r%20riktigt%20bra:%20<%= encodeURIComponent(referralUrl) %>" style="padding:0.5rem 1rem;background:rgba(99,102,241,0.1);color:#a5b4fc;text-decoration:none;border-radius:8px;font-size:0.85rem;border:1px solid rgba(99,102,241,0.25);">✉️ E-post</a>
        <a href="https://wa.me/?text=<%= encodeURIComponent('Kolla in Joakim Jaksens Säljutbildning: ' + referralUrl) %>" target="_blank" rel="noopener" style="padding:0.5rem 1rem;background:rgba(16,185,129,0.1);color:#34d399;text-decoration:none;border-radius:8px;font-size:0.85rem;border:1px solid rgba(16,185,129,0.25);">💬 WhatsApp</a>
      </div>

      <div style="padding:1rem;background:rgba(255,255,255,0.03);border-radius:10px;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:0.75rem;">
          <div style="text-align:center;">
            <div style="font-size:1.75rem;font-weight:800;color:#f1f5f9;"><%= referralStats.total %></div>
            <div style="font-size:0.75rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;">Inbjudna</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:1.75rem;font-weight:800;color:#fbbf24;"><%= referralStats.paid %></div>
            <div style="font-size:0.75rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;">Betalande</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:1.75rem;font-weight:800;color:#34d399;"><%= referralStats.credits ? referralStats.credits.earned : 0 %></div>
            <div style="font-size:0.75rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;">Mån. intjänade</div>
          </div>
        </div>

        <% if (referralStats.credits && referralStats.credits.pending > 0) { %>
          <div style="margin-top:1rem;padding:0.85rem 1rem;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.25);border-radius:10px;">
            <div style="color:#34d399;font-weight:700;font-size:0.9rem;margin-bottom:0.25rem;">
              ✨ Du har <%= referralStats.credits.pending %> gratismånad<%= referralStats.credits.pending === 1 ? '' : 'er' %> att tillgodoräkna dig
            </div>
            <div style="color:#94a3b8;font-size:0.78rem;">
              Joakim drar av detta från nästa faktura. Ingen åtgärd behövs från dig — det syns automatiskt när det är tid att fakturera.
            </div>
          </div>
        <% } %>

        <% if (referralStats.referrals && referralStats.referrals.length) { %>
          <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid rgba(255,255,255,0.06);">
            <p style="margin:0 0 0.5rem;color:#94a3b8;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.05em;">Inbjudna</p>
            <% referralStats.referrals.forEach(function(r) { %>
              <div style="display:flex;justify-content:space-between;padding:0.4rem 0;font-size:0.85rem;color:#cbd5e1;">
                <span><%= r.username %></span>
                <span style="color:<%= r.role === 'premium' || r.role === 'pro' || r.role === 'admin' ? '#34d399' : '#64748b' %>;">
                  <%= r.role === 'pro' ? '⚡ Pro' : r.role === 'premium' ? '✓ Premium' : r.role === 'admin' ? 'Admin' : 'Gratis' %>
                </span>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>

      <div class="settings-hint" style="margin-top:1rem;">
        <strong>Hur fungerar det?</strong> Dela din länk på LinkedIn, i mejl eller via WhatsApp. När någon registrerar sig via din länk och blir betalande kund → jag (Joakim) tillgodoräknar dig 1 månad gratis vid nästa fakturering. Ingen trixande, bara äkta uppskattning för att hjälpa andra säljare.
      </div>
    </div>
    <% } %>

    <script>
      function copyReferral() {
        const link = document.getElementById('referralLink').textContent.trim();
        const btn = document.getElementById('copyRefBtn');
        if (navigator.clipboard) {
          navigator.clipboard.writeText(link).then(() => {
            btn.textContent = '✓ Kopierat';
            setTimeout(() => { btn.textContent = '📋 Kopiera'; }, 2000);
          });
        }
      }
    </script>

  </main>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
