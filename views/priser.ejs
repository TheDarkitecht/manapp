  <!-- Structured data — ItemList av prisplaner (Google rich snippets) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Joakim Jaksens Säljutbildning",
    "description": "Online säljutbildning med 20 block, AI-samtalsanalys och workshops för team.",
    "brand": {
      "@type": "Brand",
      "name": "Joakim Jaksen"
    },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "SEK",
      "lowPrice": "0",
      "highPrice": "599",
      "offerCount": "4",
      "offers": [
        {
          "@type": "Offer",
          "name": "Gratis",
          "price": "0",
          "priceCurrency": "SEK",
          "description": "Block 1-2 gratis, grundläggande kurs"
        },
        {
          "@type": "Offer",
          "name": "Premium",
          "price": "199",
          "priceCurrency": "SEK",
          "description": "Alla 20 block, full kurs, inget bindningstid",
          "priceValidUntil": "2027-12-31"
        },
        {
          "@type": "Offer",
          "name": "Pro",
          "price": "599",
