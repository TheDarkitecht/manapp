<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Joakim Jaksen — Logga in</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</head>
<body class="auth-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <!-- ── Left panel — branding ─────────────────────────────────────────── -->
  <div class="auth-left">
    <div class="auth-left-inner">
      <div class="auth-logo">🎯 Joakim Jaksen</div>
      <h1 class="auth-headline">Bli säljaren<br>du alltid kunnat vara.</h1>
      <p class="auth-sub">Säljutbildning som faktiskt fungerar — byggd av en säljare, för säljare.</p>
      <ul class="auth-features">
        <li><span class="feat-icon">✅</span> 16 säljblock med teori, video & prov</li>
        <li><span class="feat-icon">✅</span> 60+ termer i Säljordboken</li>
        <li><span class="feat-icon">✅</span> AI-assistent alltid tillgänglig</li>
        <li><span class="feat-icon">✅</span> Premium-kurser med inspelade videos</li>
      </ul>
    </div>
  </div>

  <!-- ── Right panel — forms ────────────────────────────────────────────── -->
  <main id="main-content" class="auth-right">
    <div class="auth-form-wrap">

      <!-- Tab switcher -->
      <div class="auth-tabs" role="tablist" aria-label="Autentiseringsformulär">
        <button class="auth-tab active" id="tabLogin" onclick="showTab('login')" role="tab" aria-selected="true" aria-controls="panelLogin" tabindex="0">Logga in</button>
        <button class="auth-tab" id="tabRegister" onclick="showTab('register')" role="tab" aria-selected="false" aria-controls="panelRegister" tabindex="-1">Skapa konto</button>
      </div>

      <!-- ── Login form ──────────────────────────────────────────────── -->
      <div id="panelLogin" role="tabpanel" aria-labelledby="tabLogin">

        <% if (error) { %>
          <p class="auth-error"><%= error %></p>
        <% } %>
        <% if (success) { %>
          <p class="auth-success"><%= success %></p>
        <% } %>

        <form method="POST" action="/login" class="auth-form" onsubmit="authLoading(this)">
          <div class="field-group">
            <label for="username">Användarnamn</label>
            <input type="text" id="username" name="username" placeholder="ditt_användarnamn" required autocomplete="username" />
          </div>
          <div class="field-group">
            <label for="password">Lösenord</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password" />
          </div>
          <button type="submit" class="auth-btn">Logga in →</button>
        </form>

        <p class="auth-switch"><a href="/forgot-password" class="link-btn">Glömt lösenordet?</a></p>
        <p class="auth-switch">Inget konto? <button onclick="showTab('register')" class="link-btn">Skapa ett gratis konto</button></p>
      </div>

      <!-- ── Register form ───────────────────────────────────────────── -->
      <div id="panelRegister" role="tabpanel" aria-labelledby="tabRegister" style="display:none;">

        <% if (registerError && registerError !== '__open_register__') { %>
          <p class="auth-error"><%= registerError %></p>
        <% } %>

        <form method="POST" action="/register" class="auth-form">
          <div class="field-group">
            <label for="reg-username">Användarnamn</label>
            <input type="text" id="reg-username" name="username" placeholder="välj_ett_namn" required autocomplete="username" />
          </div>
          <div class="field-group">
            <label for="reg-email">E-postadress</label>
            <input type="email" id="reg-email" name="email" placeholder="din@email.com" required autocomplete="email" />
          </div>
          <div class="field-group">
            <label for="reg-password">Lösenord <span class="hint">(minst 8 tecken)</span></label>
            <input type="password" id="reg-password" name="password" placeholder="••••••••" required minlength="8" maxlength="128" autocomplete="new-password" oninput="checkPasswordMatch()" />
            <div class="password-strength" id="pwStrength" style="display:none;">
              <div class="pw-bar"><div class="pw-fill" id="pwFill" aria-hidden="true"></div></div>
              <span class="pw-label" id="pwLabel" aria-live="polite" aria-atomic="true"></span>
            </div>
          </div>
          <div class="field-group">
            <label for="reg-confirm">Bekräfta lösenord</label>
            <input type="password" id="reg-confirm" name="confirmPassword" placeholder="••••••••" required autocomplete="new-password" oninput="checkPasswordMatch()" />
            <p class="pw-match-error" id="pwMatchError" role="alert" style="display:none;color:#f87171;font-size:.78rem;margin:.3rem 0 0;">⚠️ Lösenorden matchar inte.</p>
          </div>

          <!-- GDPR consent -->
          <label class="gdpr-label">
            <input type="checkbox" name="gdpr" value="1" required />
            <span>
              Jag godkänner att mina uppgifter (användarnamn, e-post och lösenord i krypterad form) lagras och behandlas i enlighet med
              <button type="button" class="link-btn" onclick="openPrivacy()">integritetspolicyn</button>.
            </span>
          </label>

          <!-- Cloudflare Turnstile CAPTCHA -->
          <div class="cf-turnstile" data-sitekey="<%= turnstileSiteKey %>" data-theme="dark" style="margin-bottom:1rem;"></div>

          <button type="submit" class="auth-btn" id="registerBtn">Skapa konto →</button>
        </form>

        <p class="auth-switch">Har du ett konto? <button onclick="showTab('login')" class="link-btn">Logga in</button></p>
      </div>

    </div>
  </main>

  <!-- ── Privacy policy modal ───────────────────────────────────────────── -->
  <div class="modal-backdrop" id="privacyBackdrop" onclick="closePrivacy(event)" role="dialog" aria-modal="true" aria-labelledby="privacyModalTitle">
    <div class="modal privacy-modal">
      <div class="privacy-header">
        <h2 id="privacyModalTitle">Integritetspolicy</h2>
        <button class="modal-close-btn" aria-label="Stäng integritetspolicy">✕</button>
      </div>
      <div class="privacy-body">
        <p><strong>Senast uppdaterad:</strong> April 2026</p>

        <h4>Vilka uppgifter samlar vi in?</h4>
        <p>Vi samlar in ditt <strong>användarnamn</strong>, din <strong>e-postadress</strong> och ditt <strong>lösenord i krypterad form</strong> (vi lagrar aldrig ditt lösenord i klartext). Vi sparar även tidpunkten för din registrering och ditt GDPR-godkännande.</p>

        <h4>Varför samlar vi in uppgifterna?</h4>
        <p>Uppgifterna används uteslutande för att ge dig tillgång till plattformen, skicka relevant kommunikation om ditt konto och förbättra tjänsten.</p>

        <h4>Hur länge sparas uppgifterna?</h4>
        <p>Dina uppgifter sparas så länge ditt konto är aktivt. Du kan när som helst begära att ditt konto raderas.</p>

        <h4>Delar vi dina uppgifter?</h4>
        <p>Nej. Vi delar inte dina personuppgifter med tredje part i marknadsföringssyfte.</p>

        <h4>Dina rättigheter (GDPR)</h4>
        <ul>
          <li>Rätt till tillgång — begär en kopia av dina uppgifter</li>
          <li>Rätt till rättelse — begär att felaktiga uppgifter korrigeras</li>
          <li>Rätt till radering — begär att ditt konto och uppgifter raderas</li>
          <li>Rätt att återkalla samtycke — kontakta oss så raderar vi ditt konto</li>
        </ul>

        <h4>Kontakt</h4>
        <p>Vid frågor om din data — kontakta oss via plattformens support.</p>
      </div>
    </div>
  </div>

  <script>
    function authLoading(form) {
      const btn = form.querySelector('button[type="submit"]');
      if (btn) {
        btn.disabled = true;
        btn.textContent = '⏳ Väntar…';
      }
    }

    function showTab(tab) {
      const isLogin = tab === 'login';
      document.getElementById('panelLogin').style.display    = isLogin ? 'block' : 'none';
      document.getElementById('panelRegister').style.display = isLogin ? 'none' : 'block';

      const loginBtn    = document.getElementById('tabLogin');
      const registerBtn = document.getElementById('tabRegister');

      loginBtn.classList.toggle('active', isLogin);
      loginBtn.setAttribute('aria-selected', isLogin ? 'true' : 'false');
      loginBtn.setAttribute('tabindex', isLogin ? '0' : '-1');

      registerBtn.classList.toggle('active', !isLogin);
      registerBtn.setAttribute('aria-selected', isLogin ? 'false' : 'true');
      registerBtn.setAttribute('tabindex', isLogin ? '-1' : '0');
    }

    // Arrow-key navigation for auth tablist
    (function() {
      const authTabs = [
        document.getElementById('tabLogin'),
        document.getElementById('tabRegister'),
      ];
      authTabs.forEach((btn, i) => {
        btn.addEventListener('keydown', function(e) {
          let next = -1;
          if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = (i + 1) % authTabs.length;
          else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = (i - 1 + authTabs.length) % authTabs.length;
          if (next !== -1) {
            e.preventDefault();
            showTab(next === 0 ? 'login' : 'register');
            authTabs[next].focus();
          }
        });
      });
    })();

    let _privacyOpener = null; // track opener for focus return

    function openPrivacy() {
      _privacyOpener = document.activeElement;
      document.getElementById('privacyBackdrop').classList.add('open');
      // Focus the close button for keyboard users
      setTimeout(() => document.querySelector('#privacyBackdrop .modal-close-btn')?.focus(), 50);
    }

    function closePrivacy(e) {
      const backdrop = document.getElementById('privacyBackdrop');
      if (!e || e.target === backdrop) {
        backdrop.classList.remove('open');
        if (_privacyOpener) { _privacyOpener.focus(); _privacyOpener = null; }
      }
    }

    // Wire the close button and Escape key
    document.querySelector('#privacyBackdrop .modal-close-btn')?.addEventListener('click', function() {
      closePrivacy(null);
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && document.getElementById('privacyBackdrop').classList.contains('open')) {
        closePrivacy(null);
      }
    });

    // Password strength + match
    function checkPasswordMatch() {
      const pw  = document.getElementById('reg-password').value;
      const cfm = document.getElementById('reg-confirm').value;
      const strengthEl = document.getElementById('pwStrength');
      const fillEl = document.getElementById('pwFill');
      const labelEl = document.getElementById('pwLabel');
      const matchErr = document.getElementById('pwMatchError');

      // Strength meter
      if (pw.length > 0) {
        strengthEl.style.display = 'flex';
        let score = 0;
        if (pw.length >= 8)  score++;
        if (pw.length >= 12) score++;
        if (/[A-Z]/.test(pw)) score++;
        if (/[0-9]/.test(pw)) score++;
        if (/[^a-zA-Z0-9]/.test(pw)) score++;
        const levels = [
          { pct: '20%', color: '#ef4444', label: 'Mycket svagt' },
          { pct: '40%', color: '#f97316', label: 'Svagt' },
          { pct: '60%', color: '#eab308', label: 'Okej' },
          { pct: '80%', color: '#22c55e', label: 'Bra' },
          { pct: '100%', color: '#10b981', label: 'Starkt' },
        ];
        const lvl = levels[Math.min(score, levels.length) - 1] || levels[0];
        fillEl.style.width = lvl.pct;
        fillEl.style.background = lvl.color;
        labelEl.textContent = lvl.label;
        labelEl.style.color = lvl.color;
      } else {
        strengthEl.style.display = 'none';
      }

      // Match check
      if (cfm.length > 0) {
        matchErr.style.display = pw !== cfm ? 'block' : 'none';
      } else {
        matchErr.style.display = 'none';
      }
    }

    // Block submit if passwords don't match; add loading state on pass
    document.querySelector('#panelRegister form').addEventListener('submit', function(e) {
      const pw  = document.getElementById('reg-password').value;
      const cfm = document.getElementById('reg-confirm').value;
      if (pw !== cfm) {
        e.preventDefault();
        document.getElementById('pwMatchError').style.display = 'block';
        document.getElementById('reg-confirm').focus();
        return;
      }
      // Passwords match — apply loading state
      const btn = document.getElementById('registerBtn');
      if (btn) { btn.disabled = true; btn.textContent = '⏳ Skapar konto…'; }
    });

    // If there was a register error (or /register shortcut), auto-switch to register tab
    <% if (registerError) { %>
      showTab('register');
    <% } %>
  </script>
</body>
</html>
