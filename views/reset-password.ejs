<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nytt lösenord — Joakim Jaksen</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="learn-page">
  <div class="success-wrap">
    <div class="success-card">
      <div class="success-icon">🔒</div>
      <h1>Nytt lösenord</h1>

      <% if (error) { %>
        <p class="auth-error" style="margin-bottom:1rem;"><%= error %></p>
      <% } %>

      <% if (token) { %>
        <form method="POST" action="/reset-password/<%= token %>" style="width:100%;">
          <div class="field-group" style="text-align:left;margin-bottom:1rem;">
            <label style="color:#94a3b8;font-size:0.85rem;">Nytt lösenord <span style="color:#64748b;">(minst 6 tecken)</span></label>
            <input type="password" name="password" placeholder="••••••••" required
              style="width:100%;padding:0.75rem 1rem;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#f1f5f9;font-size:1rem;margin-top:0.35rem;" />
          </div>
          <div class="field-group" style="text-align:left;margin-bottom:1.25rem;">
            <label style="color:#94a3b8;font-size:0.85rem;">Bekräfta lösenord</label>
            <input type="password" name="confirmPassword" placeholder="••••••••" required
              style="width:100%;padding:0.75rem 1rem;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#f1f5f9;font-size:1rem;margin-top:0.35rem;" />
          </div>
          <button type="submit" class="success-btn" style="width:100%;margin-bottom:0;">
            Spara nytt lösenord →
          </button>
        </form>
      <% } else { %>
        <p style="color:#94a3b8;">Begär en ny länk nedan.</p>
        <a href="/forgot-password" class="success-btn" style="display:block;">Begär ny länk →</a>
      <% } %>

      <a href="/" class="success-link">← Tillbaka till inloggning</a>
    </div>
  </div>
</body>
</html>
