<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nytt lösenord — Joakim Jaksen</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="learn-page">
  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>
  <main id="main-content">
  <div class="success-wrap">
    <div class="success-card">
      <div class="success-icon">🔒</div>
      <h1>Nytt lösenord</h1>

      <% if (error) { %>
        <p class="auth-error" style="margin-bottom:1rem;"><%= error %></p>
      <% } %>

      <% if (token) { %>
        <form method="POST" action="/reset-password/<%= token %>" style="width:100%;" onsubmit="return validateReset(event)">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="field-group" style="text-align:left;margin-bottom:1rem;">
            <label for="resetPw" style="color:#94a3b8;font-size:0.85rem;">Nytt lösenord <span style="color:#64748b;">(minst 8 tecken)</span></label>
            <input type="password" id="resetPw" name="password" placeholder="••••••••" required minlength="8" maxlength="128"
              autocomplete="new-password"
              style="width:100%;padding:0.75rem 1rem;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#f1f5f9;font-size:1rem;margin-top:0.35rem;"
              oninput="checkResetMatch()" />
            <div id="resetPwStrength" style="display:none;align-items:center;gap:0.6rem;margin-top:0.5rem;">
              <div style="flex:1;height:4px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden;">
                <div id="resetPwFill" style="height:100%;width:0;transition:width 0.2s,background 0.2s;background:#ef4444;border-radius:2px;" aria-hidden="true"></div>
              </div>
              <span id="resetPwLabel" aria-live="polite" aria-atomic="true" style="font-size:0.72rem;font-weight:700;min-width:80px;text-align:right;"></span>
            </div>
          </div>
          <div class="field-group" style="text-align:left;margin-bottom:1.25rem;">
            <label for="resetCfm" style="color:#94a3b8;font-size:0.85rem;">Bekräfta lösenord</label>
            <input type="password" id="resetCfm" name="confirmPassword" placeholder="••••••••" required
              autocomplete="new-password"
              style="width:100%;padding:0.75rem 1rem;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#f1f5f9;font-size:1rem;margin-top:0.35rem;"
              oninput="checkResetMatch()" />
            <p id="resetMatchErr" style="display:none;color:#f87171;font-size:.78rem;margin:.3rem 0 0;">⚠️ Lösenorden matchar inte.</p>
          </div>
          <button type="submit" class="success-btn" style="width:100%;margin-bottom:0;">
            Spara nytt lösenord →
          </button>
        </form>
        <script>
          function checkResetMatch() {
            const pw = document.getElementById('resetPw').value;
            const cfm = document.getElementById('resetCfm').value;
            document.getElementById('resetMatchErr').style.display =
              (cfm.length > 0 && pw !== cfm) ? 'block' : 'none';

            const strengthEl = document.getElementById('resetPwStrength');
            const fillEl = document.getElementById('resetPwFill');
            const labelEl = document.getElementById('resetPwLabel');
            if (pw.length > 0) {
              strengthEl.style.display = 'flex';
              let score = 0;
              if (pw.length >= 8)  score++;
              if (pw.length >= 12) score++;
              if (/[A-Z]/.test(pw)) score++;
              if (/[0-9]/.test(pw)) score++;
              if (/[^a-zA-Z0-9]/.test(pw)) score++;
              const levels = [
                { pct: '20%',  color: '#ef4444', label: 'Mycket svagt' },
                { pct: '40%',  color: '#f97316', label: 'Svagt' },
                { pct: '60%',  color: '#eab308', label: 'Okej' },
                { pct: '80%',  color: '#22c55e', label: 'Bra' },
                { pct: '100%', color: '#10b981', label: 'Starkt' },
              ];
              const lvl = levels[Math.min(score, levels.length) - 1] || levels[0];
              fillEl.style.width = lvl.pct;
              fillEl.style.background = lvl.color;
              labelEl.textContent = lvl.label;
              labelEl.style.color = lvl.color;
            } else {
              strengthEl.style.display = 'none';
            }
          }
          function validateReset(e) {
            const pw = document.getElementById('resetPw').value;
            const cfm = document.getElementById('resetCfm').value;
            if (pw !== cfm) {
              e.preventDefault();
              document.getElementById('resetMatchErr').style.display = 'block';
              return false;
            }
            return true;
          }
        </script>
      <% } else { %>
        <p style="color:#94a3b8;">Begär en ny länk nedan.</p>
        <a href="/forgot-password" class="success-btn" style="display:block;">Begär ny länk →</a>
      <% } %>

      <a href="/login" class="success-link">← Tillbaka till inloggning</a>
    </div>
  </div>
  </main>
</body>
</html>
