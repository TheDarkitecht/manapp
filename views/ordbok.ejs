<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Säljordboken — 60+ termer — Joakim Jaksen</title>
  <meta name="description" content="60+ viktiga säljtermer förklarade — SPIN, BANT, FAB, BATNA och mer. Din referensguide i sälj." />
  <meta name="robots" content="noindex" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="learn-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/dashboard" class="learn-nav-back">← Dashboard</a>
    <span class="learn-nav-title">Säljordboken</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <!-- Hero -->
  <main id="main-content">
  <div class="learn-hero">
    <h1>Säljordboken</h1>
    <p><%= terms.length %> termer · Sök, filtrera och lär dig språket</p>
  </div>

  <!-- Search + filter bar -->
  <div class="ordbok-controls">
    <div class="ordbok-search-wrap">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
      </svg>
      <input
        type="text"
        id="searchInput"
        placeholder="Sök term… (tryck / för att söka)"
        oninput="filterTerms()"
        autocomplete="off"
        aria-label="Sök bland säljtermer"
      />
    </div>

    <div class="ordbok-filters" id="filterBtns" role="group" aria-label="Filtrera termer">
      <button class="filter-btn active" data-cat="Alla" onclick="setCategory('Alla', this)" aria-pressed="true">Alla</button>
      <% categories.forEach(function(cat) { %>
        <button class="filter-btn" data-cat="<%= cat %>" onclick="setCategory('<%= cat %>', this)" aria-pressed="false"><%= cat %></button>
      <% }); %>
    </div>
  </div>

  <!-- Count indicator -->
  <div class="ordbok-count" id="termCount" aria-live="polite" aria-atomic="true"></div>

  <!-- Terms grid -->
  <div class="ordbok-grid" id="termGrid">
    <% terms.forEach(function(t) { %>
      <div
        class="term-card"
        data-term="<%= t.term.toLowerCase() %>"
        data-def="<%= t.definition.toLowerCase() %>"
        data-cat="<%= t.category %>"
      >
        <div class="term-card-top">
          <h3 class="term-name"><%= t.term %></h3>
          <span class="term-cat"><%= t.category %></span>
        </div>
        <p class="term-def"><%= t.definition %></p>
        <% if (t.blockId) { %>
          <a href="/learn/<%= t.blockId %>" class="term-link" title="<%= blockTitles[t.blockId] || 'Läs block' %>">Läs block →</a>
        <% } %>
      </div>
    <% }); %>
  </div>

  <!-- Empty state -->
  <div class="ordbok-empty" id="emptyState" role="status" aria-live="polite" style="display:none;">
    <p>Inga termer matchade <span id="emptyQuery"></span> — prova ett annat sökord eller välj en annan kategori.</p>
  </div>

  <script>
    let activeCategory = 'Alla';

    function setCategory(cat, btn) {
      activeCategory = cat;
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      filterTerms();
    }

    function filterTerms() {
      const query = document.getElementById('searchInput').value.toLowerCase().trim();
      const cards = document.querySelectorAll('.term-card');
      let visible = 0;

      cards.forEach(card => {
        const matchCat  = activeCategory === 'Alla' || card.dataset.cat === activeCategory;
        const matchText = !query || card.dataset.term.includes(query) || card.dataset.def.includes(query);
        const show = matchCat && matchText;
        card.style.display = show ? 'flex' : 'none';
        if (show) visible++;
      });

      document.getElementById('termCount').textContent =
        visible === cards.length ? '' : `${visible} träffar`;
      const emptyState = document.getElementById('emptyState');
      emptyState.style.display = visible === 0 ? 'block' : 'none';
      if (visible === 0) {
        const eq = document.getElementById('emptyQuery');
        if (eq) eq.textContent = query ? `"${query}"` : 'vald kategori';
      }
    }

    // Init count
    filterTerms();

    // "/" key focuses search (like GitHub / Notion)
    document.addEventListener('keydown', function(e) {
      if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
        e.preventDefault();
        document.getElementById('searchInput').focus();
        document.getElementById('searchInput').select();
      }
      if (e.key === 'Escape' && document.activeElement === document.getElementById('searchInput')) {
        document.getElementById('searchInput').value = '';
        document.getElementById('searchInput').blur();
        filterTerms();
      }
    });
  </script>

  </main>

  <!-- ── Mobile bottom navigation ──────────────────────────────────────────── -->
  <nav class="app-bottom-nav">
    <a href="/dashboard" class="app-bottom-nav-item">
      <span class="abn-icon">🏠</span>
      <span class="abn-label">Hem</span>
    </a>
    <a href="/learn" class="app-bottom-nav-item">
      <span class="abn-icon">📚</span>
      <span class="abn-label">Utbildning</span>
    </a>
    <a href="/ordbok" class="app-bottom-nav-item active">
      <span class="abn-icon">📖</span>
      <span class="abn-label">Ordbok</span>
    </a>
    <% if (role === 'free') { %>
      <a href="/upgrade" class="app-bottom-nav-item abn-upgrade">
        <span class="abn-icon">⭐</span>
        <span class="abn-label">Premium</span>
      </a>
    <% } else { %>
      <a href="/logout" class="app-bottom-nav-item">
        <span class="abn-icon">🚪</span>
        <span class="abn-label">Logga ut</span>
      </a>
    <% } %>
  </nav>

</body>
</html>
