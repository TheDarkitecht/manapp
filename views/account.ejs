<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mitt konto — Joakim Jaksen</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎯</text></svg>" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="learn-page">

  <a href="#main-content" class="skip-to-main">Hoppa till innehåll</a>

  <nav class="learn-nav">
    <a href="/dashboard" class="learn-nav-back">← Dashboard</a>
    <span class="learn-nav-title">🔐 Mitt konto</span>
    <span class="learn-nav-user"><%= username %></span>
  </nav>

  <main id="main-content">
  <div class="success-wrap">
    <div class="success-card">
      <div class="success-icon">🔐</div>
      <h1>Byt lösenord</h1>
      <p style="color:#94a3b8;margin:0 0 1.25rem;">Inloggad som <strong><%= username %></strong><% if (email) { %> · <%= email %><% } %></p>

      <% if (pwOk) { %>
        <p class="auth-error" style="background:#064e3b;color:#6ee7b7;border:1px solid #065f46;margin-bottom:1rem;">
          ✓ Lösenordet är uppdaterat.
        </p>
      <% } %>

      <% if (pwError) { %>
        <p class="auth-error" style="margin-bottom:1rem;">
          <% if (pwError === 'current')   { %>⚠️ Nuvarande lösenord är fel.
          <% } else if (pwError === 'short') { %>⚠️ Det nya lösenordet måste vara minst 8 tecken.
          <% } else if (pwError === 'long')  { %>⚠️ Lösenordet får inte vara längre än 128 tecken.
          <% } else if (pwError === 'match') { %>⚠️ Lösenorden matchar inte.
          <% } else if (pwError === 'same')  { %>⚠️ Nytt lösenord får inte vara samma som det nuvarande.
          <% } else if (pwError === 'ratelimit') { %>🔒 För många försök. Försök igen om en timme.
          <% } else { %>⚠️ Något gick fel. Försök igen.
          <% } %>
        </p>
      <% } %>

      <form method="POST" action="/account/change-password" style="width:100%;" onsubmit="return validateAcc(event)">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div class="field-group" style="text-align:left;margin-bottom:1rem;">
          <label for="accCurrent" style="color:#94a3b8;font-size:0.85rem;">Nuvarande lösenord</label>
          <input type="password" id="accCurrent" name="currentPassword" placeholder="••••••••" required
            autocomplete="current-password"
            style="width:100%;padding:0.75rem 1rem;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#f1f5f9;font-size:1rem;margin-top:0.35rem;" />
        </div>

        <div class="field-group" style="text-align:left;margin-bottom:1rem;">
          <label for="accNew" style="color:#94a3b8;font-size:0.85rem;">Nytt lösenord <span style="color:#64748b;">(minst 8 tecken)</span></label>
          <input type="password" id="accNew" name="newPassword" placeholder="••••••••" required minlength="8" maxlength="128"
            autocomplete="new-password"
            style="width:100%;padding:0.75rem 1rem;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#f1f5f9;font-size:1rem;margin-top:0.35rem;"
            oninput="checkAccMatch()" />
          <!-- Password strength-meter — live-feedback medan användaren skriver -->
          <div id="accPwStrength" style="display:none;align-items:center;gap:0.6rem;margin-top:0.5rem;">
            <div style="flex:1;height:4px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden;">
              <div id="accPwFill" style="height:100%;width:0;transition:width 0.2s,background 0.2s;background:#ef4444;border-radius:2px;" aria-hidden="true"></div>
            </div>
            <span id="accPwLabel" aria-live="polite" aria-atomic="true" style="font-size:0.72rem;font-weight:700;min-width:80px;text-align:right;"></span>
          </div>
        </div>

        <div class="field-group" style="text-align:left;margin-bottom:1.25rem;">
          <label for="accConfirm" style="color:#94a3b8;font-size:0.85rem;">Bekräfta nytt lösenord</label>
          <input type="password" id="accConfirm" name="confirmPassword" placeholder="••••••••" required
            autocomplete="new-password"
            style="width:100%;padding:0.75rem 1rem;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#f1f5f9;font-size:1rem;margin-top:0.35rem;"
            oninput="checkAccMatch()" />
          <p id="accMatchErr" style="display:none;color:#f87171;font-size:.78rem;margin:.3rem 0 0;">⚠️ Lösenorden matchar inte.</p>
        </div>

        <button type="submit" class="success-btn" style="width:100%;margin-bottom:0;">
          Spara nytt lösenord →
        </button>
      </form>

      <a href="/dashboard" class="success-link">← Tillbaka till dashboard</a>
    </div>

    <!-- Pro-trial-status — visas endast när användaren är i gratis-trial -->
    <% if (typeof proTrial !== 'undefined' && proTrial.active) { %>
    <div class="success-card" style="margin-top:1.5rem;border-color:rgba(251,191,36,0.4);background:linear-gradient(145deg,rgba(251,191,36,0.08),rgba(245,158,11,0.02));">
      <h2 style="color:#fbbf24;margin:0 0 0.5rem;font-size:1.15rem;">🎁 Du är i Pro-trial</h2>
      <p style="color:#cbd5e1;margin:0 0 1.25rem;font-size:0.9rem;line-height:1.5;">
        <strong><%= proTrial.hoursLeft %> timmar kvar</strong> — slutar <%= proTrial.endsAtDate %>.
        Om du inte avbryter innan dess debiteras ditt kort <strong>599 kr</strong> för första månaden.
        Ett klick nedan avbryter direkt utan kostnad.
      </p>
      <form method="POST" action="/pro/cancel-trial" style="margin:0;"
            onsubmit="return confirm('Avbryt Pro-trialen nu? Du får tillbaka gratis-status direkt och ingen debitering sker.');">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" style="padding:0.75rem 1.25rem;background:rgba(239,68,68,0.12);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);border-radius:10px;font-weight:600;font-size:0.9rem;cursor:pointer;">
          Avbryt trial nu →
        </button>
      </form>
    </div>
    <% } %>

    <!-- Flash-meddelande efter cancel-trial -->
    <% if (typeof trialCancelled !== 'undefined' && trialCancelled) { %>
      <div role="status" aria-live="polite" style="margin-top:1rem;padding:1rem 1.25rem;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);border-radius:10px;color:#34d399;font-size:0.9rem;">
        ✓ Pro-trialen är avbruten. Ingen debitering kommer att ske. Tack för att du testade!
      </div>
    <% } %>
    <% if (typeof trialCancelError !== 'undefined' && trialCancelError) { %>
      <div role="alert" aria-live="assertive" style="margin-top:1rem;padding:1rem 1.25rem;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:10px;color:#fca5a5;font-size:0.9rem;">
        ⚠️ Kunde inte avbryta trialen automatiskt. Öppna Stripe-portalen nedan och avbryt manuellt — eller mejla info@joakimjaksen.se så hjälper vi dig.
      </div>
    <% } %>

    <!-- Stripe customer portal — self-serve cancel, uppdatera kort, ladda ner kvitton -->
    <% if (role === 'premium' || role === 'pro') { %>
    <div class="success-card" style="margin-top:1.5rem;">
      <h2 style="color:#f1f5f9;margin:0 0 0.5rem;font-size:1.15rem;">💳 Hantera prenumeration</h2>
      <p style="color:#94a3b8;margin:0 0 1.25rem;font-size:0.9rem;line-height:1.5;">
        Uppdatera betalkort, ladda ner kvitton, pausa eller säg upp —
        allt via Stripes säkra kundportal.
      </p>
      <form method="POST" action="/billing/portal" style="margin:0;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" style="padding:0.75rem 1.25rem;background:rgba(139,92,246,0.12);color:#c4b5fd;border:1px solid rgba(139,92,246,0.3);border-radius:10px;font-weight:600;font-size:0.9rem;cursor:pointer;">
          Öppna Stripe-portalen →
        </button>
      </form>
    </div>
    <% } %>

    <!-- Stripe invoice-history — listas direkt i appen, ingen portal-bounce -->
    <% if (typeof invoices !== 'undefined' && invoices && invoices.length > 0) { %>
    <div class="success-card" style="margin-top:1.5rem;text-align:left;">
      <h2 style="color:#f1f5f9;margin:0 0 0.5rem;font-size:1.15rem;text-align:center;">📄 Fakturor & kvitton</h2>
      <p style="color:#94a3b8;margin:0 0 1.25rem;font-size:0.9rem;line-height:1.5;text-align:center;">
        Alla dina betalningar — klicka PDF:en för officiellt kvitto.
      </p>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <% invoices.forEach(function(inv) {
          const dt = new Date(inv.createdAt);
          const dateStr = dt.toLocaleDateString('sv-SE', { year: 'numeric', month: 'short', day: 'numeric' });
          const amount = Math.round(inv.amountPaid / 100);
          const currency = (inv.currency || 'sek').toUpperCase();
          const isPaid = inv.status === 'paid';
          const isOpen = inv.status === 'open';
          const isDraft = inv.status === 'draft';
          const isVoid = inv.status === 'void' || inv.status === 'uncollectible';
          const statusColor = isPaid ? '#34d399' : isOpen ? '#fbbf24' : isVoid ? '#64748b' : '#94a3b8';
          const statusText = isPaid ? 'Betald' : isOpen ? 'Väntar' : isDraft ? 'Utkast' : isVoid ? 'Annullerad' : inv.status;
        %>
          <div style="display:grid;grid-template-columns:1fr auto auto auto;gap:0.75rem;align-items:center;padding:0.75rem 1rem;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05);border-radius:8px;font-size:0.88rem;">
            <div style="min-width:0;">
              <div style="color:#f1f5f9;font-weight:600;"><%= dateStr %></div>
              <div style="color:#64748b;font-size:0.75rem;"><%= inv.description || 'Prenumeration' %></div>
            </div>
            <div style="color:#cbd5e1;font-variant-numeric:tabular-nums;font-weight:700;white-space:nowrap;">
              <%= amount %> <%= currency %>
            </div>
            <div>
              <span style="display:inline-block;padding:0.15rem 0.5rem;border-radius:999px;font-size:0.72rem;font-weight:700;background:rgba(<%= isPaid ? '16,185,129' : isOpen ? '251,191,36' : '100,116,139' %>,0.15);color:<%= statusColor %>;">
                <%= statusText %>
              </span>
            </div>
            <div style="display:flex;gap:0.35rem;">
              <% if (inv.pdfUrl) { %>
                <a href="<%= inv.pdfUrl %>" target="_blank" rel="noopener" title="Ladda ner som PDF"
                   aria-label="Ladda ner faktura <%= inv.number || '' %> som PDF"
                   style="padding:0.3rem 0.55rem;background:rgba(99,102,241,0.12);color:#a5b4fc;text-decoration:none;border-radius:6px;font-size:0.78rem;font-weight:600;border:1px solid rgba(99,102,241,0.25);">
                  PDF
                </a>
              <% } %>
              <% if (inv.hostedUrl) { %>
                <a href="<%= inv.hostedUrl %>" target="_blank" rel="noopener" title="Öppna i Stripe"
                   aria-label="Visa faktura <%= inv.number || '' %> i webbläsaren"
                   style="padding:0.3rem 0.55rem;background:rgba(255,255,255,0.04);color:#cbd5e1;text-decoration:none;border-radius:6px;font-size:0.78rem;font-weight:600;border:1px solid rgba(255,255,255,0.1);">
                  Visa
                </a>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
      <p style="color:#64748b;font-size:0.75rem;margin:1rem 0 0;text-align:center;">
        Visar upp till 24 senaste. Äldre finns i Stripe-portalen.
      </p>
    </div>
    <% } else if (role === 'premium' || role === 'pro') { %>
    <!-- Empty state för premium/pro-users som inte har fakturor än (ny trial/nyss börjat) -->
    <div class="success-card" style="margin-top:1.5rem;">
      <h2 style="color:#f1f5f9;margin:0 0 0.5rem;font-size:1.15rem;">📄 Fakturor & kvitton</h2>
      <p style="color:#94a3b8;margin:0;font-size:0.9rem;line-height:1.5;">
        Inga fakturor än — du är antingen i trial-period eller har precis börjat.
        När din första betalning har gått igenom dyker kvittot upp här automatiskt.
      </p>
    </div>
    <% } %>

    <!-- GDPR: data-export — Artikel 20 rätt till portabilitet -->
    <div class="success-card" style="margin-top:1.5rem;">
      <h2 style="color:#f1f5f9;margin:0 0 0.5rem;font-size:1.15rem;">🗂️ Ladda ner min data</h2>
      <p style="color:#94a3b8;margin:0 0 1.25rem;font-size:0.9rem;line-height:1.5;">
        Enligt GDPR Artikel 20 har du rätt att få ut all data vi lagrar om dig i maskinläsbart format.
        Exporten innehåller profil, block-framsteg, reflektioner, rollspel, uppdrag, loggbok, sidvisningar och referrals.
        Exkluderar krypterat lösenord (av säkerhetsskäl).
      </p>
      <a href="/account/export.json"
         style="display:inline-block;padding:0.75rem 1.25rem;background:rgba(99,102,241,0.12);color:#a5b4fc;border:1px solid rgba(99,102,241,0.3);border-radius:10px;text-decoration:none;font-weight:600;font-size:0.9rem;">
        ⬇ Ladda ner (JSON)
      </a>
      <p style="color:#64748b;margin:1rem 0 0;font-size:0.78rem;">
        Max 3 exporter per timme. Filen laddas ner direkt, inte via mejl.
      </p>
    </div>
  </div>
  </main>

  <script>
    function checkAccMatch() {
      const pw  = document.getElementById('accNew').value;
      const cfm = document.getElementById('accConfirm').value;
      document.getElementById('accMatchErr').style.display =
        (cfm.length > 0 && pw !== cfm) ? 'block' : 'none';

      // Password strength (samma logik som registrera-sidan)
      const strengthEl = document.getElementById('accPwStrength');
      const fillEl = document.getElementById('accPwFill');
      const labelEl = document.getElementById('accPwLabel');
      if (pw.length > 0) {
        strengthEl.style.display = 'flex';
        let score = 0;
        if (pw.length >= 8)  score++;
        if (pw.length >= 12) score++;
        if (/[A-Z]/.test(pw)) score++;
        if (/[0-9]/.test(pw)) score++;
        if (/[^a-zA-Z0-9]/.test(pw)) score++;
        const levels = [
          { pct: '20%',  color: '#ef4444', label: 'Mycket svagt' },
          { pct: '40%',  color: '#f97316', label: 'Svagt' },
          { pct: '60%',  color: '#eab308', label: 'Okej' },
          { pct: '80%',  color: '#22c55e', label: 'Bra' },
          { pct: '100%', color: '#10b981', label: 'Starkt' },
        ];
        const lvl = levels[Math.min(score, levels.length) - 1] || levels[0];
        fillEl.style.width = lvl.pct;
        fillEl.style.background = lvl.color;
        labelEl.textContent = lvl.label;
        labelEl.style.color = lvl.color;
      } else {
        strengthEl.style.display = 'none';
      }
    }
    function validateAcc(e) {
      const pw  = document.getElementById('accNew').value;
      const cfm = document.getElementById('accConfirm').value;
      if (pw !== cfm) {
        e.preventDefault();
        document.getElementById('accMatchErr').style.display = 'block';
        return false;
      }
      return true;
    }
    // Clean ?pwOk=1 / ?pwError=… from the URL after rendering so a refresh doesn't re-show the flash
    (function() {
      const p = new URLSearchParams(window.location.search);
      if (p.has('pwOk') || p.has('pwError')) {
        history.replaceState({}, '', '/account');
      }
    })();
  </script>

  <script src="/heartbeat.js" defer></script>
</body>
</html>
