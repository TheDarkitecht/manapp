# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database file. On Railway, set to /data/users.db for persistence.
DB_PATH=/data/users.db

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-secret

# ── App URL ───────────────────────────────────────────────────────────────────
# Full URL of the app (used for email links, Stripe redirects)
APP_URL=https://app.joakimjaksen.se

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
# From address (must be a verified Resend sender)
# RESEND_FROM=Joakim Jaksen <noreply@joakimjaksen.se>

# ── Groq (AI chat — Jocke) ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Cloudflare Turnstile (CAPTCHA on registration) ────────────────────────────
TURNSTILE_SITE_KEY=1x...
TURNSTILE_SECRET_KEY=1x...

# ── Emergency admin password reset ────────────────────────────────────────────
# Set temporarily, deploy, then remove. Will reset admin account password on startup.
# ADMIN_RESET_PASSWORD=newSecurePassword123
